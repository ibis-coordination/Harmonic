{
  "name": "@ibis-coordination/harmonic-bridge",
  "version": "0.1.0",
  "description": "Webhook bridge daemon for running Harmonic AI agents on your own hardware.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "harmonic-bridge": "dist/bin.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
