    "dev": "tsx src/cli.ts"
  },
  "dependencies": {
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ibis-coordination/Harmonic.git",
    "directory": "harmonic-bridge"
  },
  "homepage": "https://github.com/ibis-coordination/Harmonic/tree/main/harmonic-bridge#readme",
  "bugs": {
    "url": "https://github.com/ibis-coordination/Harmonic/issues"
  },
  "keywords": [
    "harmonic",
    "agent",
    "mcp",
    "webhook",
    "daemon"
  ]
