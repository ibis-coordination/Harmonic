# ---------------------------------------------------------------------------
# Plaintext LAYOUT for the infra / third-party secrets file.
#
# This .example is committed for reference. The REAL file is `secrets.enc.env`
# in this directory, SOPS-encrypted with age (see .sops.yaml). Workflow:
#
#   cp secrets.env.example secrets.enc.env
#   # fill in real values (many come from `terraform output`)
#   sops -e -i secrets.enc.env        # encrypt in place, then commit the cipher
#
# At deploy time scripts/deploy.sh decrypts this into per-key files under
# /run/secrets/ (tmpfs), which the compose `secrets:` overlay mounts.
#
# SCOPE: this file holds infra + third-party secrets only. App-internal
# secrets (SECRET_KEY_BASE, AGENT_RUNNER_SECRET) belong in Rails encrypted
# credentials (config/credentials.yml.enc) — different owner, blast radius,
# and rotation cadence. See docs/INFRASTRUCTURE.md.
# ---------------------------------------------------------------------------

# From `terraform output -raw database_url`
DATABASE_URL=postgres://harmonic:CHANGEME@private-db-host:25060/harmonic_production?sslmode=require

# Generate: openssl rand -hex 24
REDIS_PASSWORD=CHANGEME

# DigitalOcean Spaces (ActiveStorage) — from terraform outputs
DO_SPACES_ACCESS_KEY_ID=CHANGEME
DO_SPACES_SECRET_ACCESS_KEY=CHANGEME
DO_SPACES_REGION=nyc3
DO_SPACES_BUCKET=harmonic-example-storage
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com

# AWS SES SMTP credentials (minted from an IAM user; NOT created by terraform)
SMTP_USERNAME=CHANGEME
SMTP_PASSWORD=CHANGEME

# Stripe (billing + AI gateway)
STRIPE_API_KEY=CHANGEME
STRIPE_GATEWAY_KEY=CHANGEME
STRIPE_WEBHOOK_SECRET=CHANGEME

# OAuth
GITHUB_CLIENT_SECRET=CHANGEME

# Optional ops integrations
SENTRY_DSN=
SLACK_WEBHOOK_URL=
METRICS_AUTH_TOKEN=
