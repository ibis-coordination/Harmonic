# EXAMPLE SOPS creation rules for the OPTIONAL SOPS+age adapter. OPTIONAL — not
# used by the repo. Copy this to `.sops.yaml` NEXT TO your bring-your-own
# encrypted file, OUTSIDE this repo (a private secrets repo or provisioning
# store). The encrypted file, and this config, never belong upstream.
#
# The matching age PRIVATE key lives only on the server
# (/opt/harmonic/secrets/age.key) and on operators' machines — never in the
# repo, never in Terraform state.
#
# Generate a key pair:  age-keygen -o age.key   (the public line is the recipient)
# Replace the placeholder recipient below with your real age public key.

creation_rules:
  - path_regex: secrets\.enc\.env$
    age: >-
      age1qqqplaceholderqqqreplace0me0with0a0real0age0public0key0xxxxxxxxxxx
    # Encrypt values only; keep keys readable so diffs of the ciphertext still
    # show WHICH var changed, just not the value.
    unencrypted_regex: "^(#.*)?$"
