<% unless block_exists_with_author? %>
<article class="pulse-feed-item<%= " pulse-feed-item-#{item_status}" if item_status %>"
         data-pulse-filter-target="feedItem"
         data-item-type="<%= @type %>"
         data-controller="card-navigate"
         data-card-navigate-url-value="<%= @item.path %>"
         data-action="click->card-navigate#navigate auxclick->card-navigate#navigate keydown->card-navigate#keydown"
         role="link"
         tabindex="0"
         aria-label="<%= "View #{display_type.downcase}: #{item_title.to_s.strip.presence || '(untitled)'}" %>">
  <div class="pulse-feed-item-header">
    <div class="pulse-feed-item-type">
      <% if is_comment? %>
        <%= helpers.octicon 'comment', height: 16 %>
      <% elsif is_statement? %>
        <%= helpers.octicon 'law', height: 16 %>
      <% elsif is_summary? %>
        <%= helpers.octicon 'book', height: 16 %>
      <% else %>
        <i class="<%= @type.downcase %>-icon icon-sm"></i>
      <% end %>
      <span><%= display_type %></span>
    </div>
    <div class="pulse-feed-item-meta">
      <% if display_author %>
        <a href="<%= display_author.path %>" class="pulse-feed-item-author">
          <%= render "shared/avatar", user: display_author %>
          <span><%= display_author.display_name %></span>
        </a>
        <% if representation? %>
          <span class="pulse-representation-label">on behalf of <%= helpers.link_to @created_by.display_name, @created_by.path %></span>
        <% end %>
      <% else %>
        <span>Anonymous</span>
      <% end %>
      &middot; <%= helpers.timeago(@created_at) %>
    </div>
  </div>
  <div class="pulse-feed-item-body">
    <% if is_comment? && T.unsafe(@item).commentable %>
      <div class="pulse-feed-item-reply">
        <%= helpers.octicon 'reply' %>
        <span>Replying to</span>
        <%= render 'shared/inline_resource_item', resource: T.unsafe(@item).commentable %>
      </div>
    <% elsif is_statement? && T.unsafe(@item).statementable %>
      <div class="pulse-feed-item-reply">
        <%= helpers.octicon 'law' %>
        <span>Statement on</span>
        <%= render 'shared/inline_resource_item', resource: T.unsafe(@item).statementable %>
      </div>
    <% elsif is_summary? && T.unsafe(@item).summarizable %>
      <div class="pulse-feed-item-reply">
        <%= helpers.octicon 'book' %>
        <span>Summary of</span>
        <%= render 'shared/inline_resource_item', resource: T.unsafe(@item).summarizable %>
      </div>
    <% end %>
    <% if show_title? %>
      <div class="pulse-feed-item-title">
        <a href="<%= @item.path %>"><%= helpers.strip_tags(helpers.markdown(item_title)).presence || "(Untitled)" %></a>
      </div>
    <% end %>
    <% if item_content.present? %>
      <div class="pulse-feed-item-content markdown-body" data-controller="card-expand">
        <div data-card-expand-target="body" class="pulse-feed-item-content-clamped">
          <%= helpers.markdown(item_content) %>
        </div>
        <button type="button"
                class="pulse-feed-item-content-toggle"
                data-card-expand-target="toggle"
                data-action="click->card-expand#toggle"
                data-no-navigate
                aria-expanded="false"
                hidden>Show more</button>
      </div>
    <% end %>

    <%# Type-specific content %>
    <% case @type %>
    <% when 'Note' %>
      <% if T.unsafe(@item).respond_to?(:media_items) && T.unsafe(@item).media_items.any? %>
        <%= render 'shared/note_media_feed_strip', note: @item %>
      <% end %>
    <% when 'Decision' %>
      <%
        # Three render modes for the options/results strip:
        #   - Executive / lottery: option titles only, sourced from `options`
        #     (results aren't computed the same way for these subtypes).
        #   - Vote decision + show_decision_results?: option titles + tallies,
        #     sourced from `results` (ordered by accepted_yes DESC — the
        #     ranking the viewer is allowed to see).
        #   - Vote decision + !show_decision_results?: option titles only,
        #     sourced from `options.order(:created_at)`. CRITICAL: must NOT
        #     use `results`, because the decision_results view orders by
        #     accepted_yes DESC and the ranking itself leaks the standing
        #     to viewers who haven't voted yet (blind-taste-test bypass).
        if T.unsafe(@item).is_executive? || T.unsafe(@item).is_lottery?
          decision_titles = T.unsafe(@item).options.order(:created_at).first(5).map(&:title)
          decision_results_with_counts = nil
        elsif show_decision_results?
          decision_results_with_counts = T.unsafe(@item).results.first(5)
          decision_titles = decision_results_with_counts.map(&:option_title)
        else
          decision_titles = T.unsafe(@item).options.order(:created_at).first(5).map(&:title)
          decision_results_with_counts = nil
        end
      %>
      <% if decision_titles.any? %>
        <div class="pulse-decision-options">
          <% decision_titles.each_with_index do |title, index| %>
            <% result = decision_results_with_counts && decision_results_with_counts[index] %>
            <div class="pulse-decision-option<%= ' pulse-decision-option-winner' if result && index == 0 && @item.closed? %>">
              <span><%= title %></span>
              <% if result %>
                <span class="pulse-option-votes"><%= result.accepted_yes %> accept &middot; <%= result.preferred %> prefer</span>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    <% when 'Commitment' %>
      <% if is_calendar_event_commitment? %>
        <div class="pulse-event-when">
          <%= helpers.octicon 'calendar', height: 14 %>
          <strong><%= T.unsafe(@item).formatted_time_range %></strong>
          <% if T.unsafe(@item).location.present? %>
            &middot; <%= helpers.octicon 'location', height: 14 %> <%= T.unsafe(@item).location %>
          <% end %>
        </div>
        <% if critical_mass > 0 %>
          <div class="pulse-commitment-progress">
            <div class="pulse-progress-bar">
              <div class="pulse-progress-fill" style="width: <%= progress_percent %>%"></div>
            </div>
            <div class="pulse-progress-label">
              <span><%= participant_count %> attending</span>
              <% if remaining > 0 %>
                <span>need <%= remaining %> more</span>
              <% end %>
            </div>
          </div>
        <% else %>
          <div class="pulse-commitment-progress">
            <div class="pulse-progress-label">
              <span><%= participant_count %> attending</span>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="pulse-commitment-progress">
          <div class="pulse-progress-bar">
            <div class="pulse-progress-fill" style="width: <%= progress_percent %>%"></div>
          </div>
          <div class="pulse-progress-label">
            <% verb = is_policy_commitment? ? "signed" : "committed" %>
            <span><%= participant_count %> of <%= critical_mass %> <%= verb %></span>
            <% if remaining > 0 %>
              <span><%= remaining %> more needed</span>
            <% else %>
              <span>Critical mass reached!</span>
            <% end %>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>
  <div class="pulse-feed-item-footer">
    <% case @type %>
    <% when 'Note' %>
      <% if @current_user && !user_has_read? %>
        <%# Unread: the pulse-action controller wraps the button and the count
            block so a successful confirm updates the "N confirmed" figure live
            (revealing it, and the viewer's avatar, on the first confirmation). %>
        <div data-controller="pulse-action" data-pulse-action-url-value="<%= @item.path %>/actions/confirm_read" data-pulse-action-loading-text-value="Confirming..." data-pulse-action-confirmed-text-value="Confirmed">
          <button type="button" class="pulse-feed-action-btn" data-pulse-action-target="button" data-action="click->pulse-action#performAction"><%= helpers.octicon 'book' %> Confirm read</button>
          <div class="pulse-confirmed-reads" data-pulse-action-target="readCount" <%= "hidden" if read_count.zero? %>>
            <div class="pulse-confirmed-avatars">
              <% if read_count.zero? %>
                <span class="pulse-confirmed-self" data-pulse-action-target="selfAvatar" hidden><%= render "shared/avatar", user: @current_user, css_class: "pulse-confirmed-avatar" %></span>
              <% end %>
              <% read_confirmations_scope.includes(:user).select(:user_id).distinct.limit(3).each do |event| %>
                <%= render "shared/avatar", user: event.user, css_class: "pulse-confirmed-avatar" %>
              <% end %>
              <% if read_count > 3 %>
                <div class="pulse-confirmed-avatar">+<%= read_count - 3 %></div>
              <% end %>
            </div>
            <span data-pulse-action-target="count"><%= read_count %> confirmed</span>
          </div>
        </div>
      <% else %>
        <%# Anonymous (login CTA) or already-confirmed: static count, no live update. %>
        <% if @current_user.nil? %>
          <a href="/login" data-redirect-to-resource="<%= @item.path %>" class="pulse-feed-action-btn-link"><%= helpers.octicon 'sign-in' %> Log in to confirm reading</a>
        <% else %>
          <button type="button" class="pulse-feed-action-btn pulse-feed-action-btn-disabled" disabled><%= helpers.octicon 'book' %> Confirmed</button>
        <% end %>
        <% if read_count > 0 %>
          <div class="pulse-confirmed-reads">
            <div class="pulse-confirmed-avatars">
              <% read_confirmations_scope.includes(:user).select(:user_id).distinct.limit(3).each do |event| %>
                <%= render "shared/avatar", user: event.user, css_class: "pulse-confirmed-avatar" %>
              <% end %>
              <% if read_count > 3 %>
                <div class="pulse-confirmed-avatar">+<%= read_count - 3 %></div>
              <% end %>
            </div>
            <span><%= read_count %> confirmed</span>
          </div>
        <% end %>
      <% end %>
    <% when 'Decision' %>
      <% if @item.closed? %>
        <button type="button" class="pulse-feed-action-btn pulse-feed-action-btn-disabled" disabled><%= helpers.octicon 'check-circle' %> Closed <%= helpers.time_ago_in_words(T.unsafe(@item).deadline) %> ago</button>
      <% elsif @current_user.nil? && !(T.unsafe(@item).is_executive? || T.unsafe(@item).is_lottery?) %>
        <a href="/login" data-redirect-to-resource="<%= @item.path %>" class="pulse-feed-action-btn-link"><%= helpers.octicon 'sign-in' %> Log in to vote</a>
      <% elsif T.unsafe(@item).is_executive? || T.unsafe(@item).is_lottery? %>
        <a href="<%= @item.path %>" class="pulse-feed-action-btn-link"><%= helpers.octicon 'check-circle' %> View</a>
      <% elsif user_has_voted? %>
        <button type="button" class="pulse-feed-action-btn pulse-feed-action-btn-disabled" disabled><%= helpers.octicon 'check-circle' %> Voted</button>
      <% else %>
        <a href="<%= @item.path %>" class="pulse-feed-action-btn-link"><%= helpers.octicon 'check-circle' %> Vote</a>
      <% end %>
    <% when 'Commitment' %>
      <% if @item.closed? %>
        <button type="button" class="pulse-feed-action-btn pulse-feed-action-btn-disabled" disabled><%= helpers.octicon 'person' %> Closed <%= helpers.time_ago_in_words(T.unsafe(@item).deadline) %> ago</button>
      <% elsif @current_user.nil? %>
        <a href="/login" data-redirect-to-resource="<%= @item.path %>" class="pulse-feed-action-btn-link"><%= helpers.octicon 'sign-in' %> Log in to <%= join_action_label.downcase %></a>
      <% elsif user_has_joined? %>
        <button type="button" class="pulse-feed-action-btn pulse-feed-action-btn-disabled" disabled><%= helpers.octicon 'check' %> <%= joined_label %></button>
      <% else %>
        <div data-controller="pulse-action" data-pulse-action-url-value="<%= @item.path %>/actions/join_commitment" data-pulse-action-loading-text-value="<%= join_action_label %>..." data-pulse-action-confirmed-text-value="<%= joined_label %>">
          <button type="button" class="pulse-feed-action-btn" data-pulse-action-target="button" data-action="click->pulse-action#performAction"><%= helpers.octicon join_action_icon %> <%= join_action_label %></button>
        </div>
      <% end %>
    <% end %>
  </div>
</article>
<% end %>
