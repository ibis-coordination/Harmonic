<div class="pulse-feed-item-author">
  <%= render AvatarComponent.new(user: display_author) %>
  <a href="<%= display_author.path %>" class="pulse-feed-item-author">
    <strong><%= display_author.display_name %></strong>
  </a>
  <% if representation? %>
    <span class="pulse-representation-label">on behalf of <%= helpers.link_to author.display_name, author.path %></span>
  <% elsif author.ai_agent? && author.parent %>
    <span class="pulse-ai-agent-label">(managed by <%= helpers.link_to author.parent.display_name, author.parent.path %>)</span>
  <% end %>
  <% if @verb.present? %>
    <span><%= @verb %></span>
  <% end %>
  <span class="pulse-timestamp"><%= helpers.timeago(@resource.created_at) %></span>
</div>
<% if show_task_run_link? %>
  <% tr = task_run %>
  <% if tr %>
    <div class="pulse-task-run-link">
      <%= helpers.octicon 'workflow', height: 12 %>
      <%= helpers.link_to "View task run", helpers.ai_agent_run_path(author.handle, tr.id) %>
    </div>
  <% end %>
<% end %>
<% if updated? %>
  <div class="pulse-feed-item-updated">
    <span>Updated <%= helpers.timeago(@resource.updated_at) %></span>
    <% if @resource.updated_by && @resource.updated_by != author %>
      <span>by <%= helpers.link_to @resource.updated_by.display_name, @resource.updated_by.path %></span>
    <% end %>
  </div>
<% end %>
