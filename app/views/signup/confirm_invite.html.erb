<div class="pulse-auth-page">
  <div class="pulse-auth-error">
    <div class="pulse-auth-error-icon">
      <%= inline_avatar @invite.collective, variant: :thumbnail,
                        style: "width:64px;height:64px;border-radius:12px;font-size:24px;" %>
    </div>
    <h1 class="pulse-auth-title">You're invited to join <br/><%= @invite.collective.name %></h1>
    <p class="pulse-auth-subtitle">
      on <code><%= @current_tenant.subdomain %>.<%= ENV['HOSTNAME'] %></code>
    </p>

    <% if @invite.collective.agent_funding? %>
      <p class="pulse-body-text" style="text-align:left;">
        <strong><%= @invite.collective.name %></strong> is an agent funding collective.
        Joining is consenting to fund its agents: each LLM call one of its agents makes
        is billed to one member's own prepaid balance, chosen at random per call. The
        collective never holds funds. Joining requires active billing with prepaid
        credits; leaving ends your participation.
      </p>
    <% end %>

    <%= form_with url: accept_invite_path, method: :post, class: "pulse-auth-form", local: true do %>
      <%= render "shared/bot_protection_fields" %>
      <input type="hidden" name="code" value="<%= @invite.code %>">
      <% unless @current_tenant.tenant_users.exists?(user: @current_user) %>
        <div style="margin-bottom: 12px;">
          <label for="handle-field" class="pulse-form-hint" style="display: block; margin-bottom: 4px;">
            Your handle on <code><%= @current_tenant.subdomain %>.<%= ENV['HOSTNAME'] %></code>
          </label>
          <div style="display: flex; align-items: center; gap: 8px;">
            <span aria-hidden="true" style="font-weight: 600; color: var(--color-fg-muted);">@</span>
            <%# margin-bottom: 0 — the auth-form input margin would otherwise
                offset the flex centering of the @ prefix %>
            <input type="text" name="handle" id="handle-field" class="pulse-form-input"
                   style="flex: 1; margin-bottom: 0;"
                   value="<%= @suggested_handle %>" autocomplete="off" spellcheck="false"
                   data-controller="handle-input" data-action="input->handle-input#sanitize"
                   pattern="[a-z0-9_\-]*" title="Lowercase letters, numbers, dashes, and underscores">
          </div>
          <p class="pulse-form-hint" style="margin: 4px 0 0 0;">
            You can change this later in your settings.
          </p>
        </div>
      <% end %>
      <div class="pulse-form-actions">
        <button type="submit" class="pulse-action-btn pulse-action-btn-primary">Accept and join</button>
      </div>
    <% end %>

    <div class="pulse-form-actions" style="justify-content:center;margin-top:12px;">
      <a href="<%= invite_required_path %>" class="pulse-auth-link">Use a different code</a>
    </div>

    <div style="background:var(--color-canvas-subtle);padding:16px;border-radius:6px;margin:24px 0;text-align:left;">
      <p class="pulse-form-hint" style="margin:0 0 8px 0;">Signed in as:</p>
      <p style="margin:0;font-size:14px;">
        <strong><%= @current_user.name %></strong>
        <br><span style="color:var(--color-fg-muted);"><%= @current_user.email %></span>
      </p>
    </div>

    <div class="pulse-form-actions" style="justify-content:center;">
      <%= button_to 'Log out', '/logout', method: :delete, class: "pulse-action-btn",
          params: { push_endpoint: "" },
          form: { data: { controller: "logout", action: "submit->logout#prepare" } } %>
    </div>
  </div>
</div>
