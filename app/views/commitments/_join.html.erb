<%
  if @commitment.is_policy?
    action_label = "Sign"
    joined_label = "Signed"
    join_icon = "check"
    joined_message = "Your signature has been recorded."
    visibility_message = "Your signature will be visible to all members of #{@current_collective.name}."
    closed_message = "This policy is closed."
  elsif @commitment.is_calendar_event?
    action_label = "RSVP"
    joined_label = "RSVP'd"
    join_icon = "calendar"
    joined_message = "Your RSVP has been recorded."
    visibility_message = "Your RSVP will be visible to all members of #{@current_collective.name}."
    closed_message = "RSVPs are closed."
  else
    action_label = "Join"
    joined_label = "Joined"
    join_icon = "person-add"
    joined_message = "Your participation has been recorded."
    visibility_message = "Your participation will be visible to all members of #{@current_collective.name}."
    closed_message = "This commitment is closed."
  end
%>
<% if @commitment.closed? && @current_user %>
  <% if @commitment_participant.committed? %>
    <p class="pulse-join-status">
      <button class="pulse-action-btn pulse-action-btn-disabled" disabled>
        <%= octicon 'check', height: 14 %>
        <%= joined_label %>
      </button>
      <span class="pulse-join-message"><%= joined_message %></span>
    </p>
  <% else %>
    <p class="pulse-join-closed"><%= closed_message %></p>
  <% end %>
<% elsif @commitment.closed? %>
  <p class="pulse-join-closed"><%= closed_message %></p>
<% elsif @current_user %>
  <% if @commitment_participant.committed? %>
    <p class="pulse-join-status">
      <button class="pulse-action-btn pulse-action-btn-disabled" disabled>
        <%= octicon 'check', height: 14 %>
        <%= joined_label %>
      </button>
      <span class="pulse-join-message"><%= joined_message %></span>
    </p>
  <% else %>
    <p class="pulse-join-action">
      <button
        class="pulse-action-btn"
        data-action="click->commitment#join mouseenter->commitment#joinButtonMouseEnter mouseleave->commitment#joinButtonMouseLeave"
        data-commitment-target="joinButton"
        data-url="<%= @commitment.path + '/join.html' %>"
        >
        <%= octicon join_icon, height: 14 %>
        <%= action_label %>
      </button>
      <% unless @current_collective.private_workspace? %>
      <span class="pulse-join-message" data-commitment-target="joinButtonMessage">
        <%= visibility_message %>
      </span>
      <% end %>
    </p>
  <% end %>
  <% unless @commitment.is_calendar_event? %>
    <p class="pulse-join-info">
      <% if @commitment.is_policy? %>
        This policy only takes effect if critical mass is achieved.
      <% else %>
        Commitments only take effect if critical mass is achieved.
      <% end %>
      <%= render 'reciprocal_commitment_tooltip' %>
    </p>
  <% end %>
<% else %>
  <%= render "shared/login_to_act", verb: "#{action_label.downcase} this commitment", resource_path: @commitment.path %>
<% end %>
