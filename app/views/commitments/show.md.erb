<% if @commitment.deleted? %>
# Commitment [deleted]

This commitment has been deleted<%= " by the author" if @commitment.deleted_by_id == @commitment.created_by_id %>.

| created_by | @<%= @commitment.created_by.handle %> |
| created_at | <%= @commitment.created_at %> |
<% else %>
<%
  type_label = if @commitment.is_policy?
                 "Policy"
               elsif @commitment.is_calendar_event?
                 "Event"
               else
                 "Commitment"
               end
%>
# <%= type_label %>: [<%= @commitment.title %>](<%= @commitment.path %>)

| created_at | <%= @commitment.created_at %> |
| updated_at | <%= @commitment.updated_at %> |
| deadline | <%= @commitment.deadline %> |
| time remaining | <%= @commitment.deadline > Time.now ? distance_of_time_in_words(Time.now, @commitment.deadline) : 'Deadline passed' %> |
<% if @commitment.is_calendar_event? %>
| starts_at | <%= @commitment.starts_at %> |
| ends_at | <%= @commitment.ends_at %> |
| when | <%= @commitment.formatted_time_range %> |
<% if @commitment.location.present? %>
| location | <%= @commitment.location %> |
<% end %>
| status | <%= @commitment.event_status %> |
<% end %>
<% if @commitment.description.present? %>
<% truncated_description = truncate_content(@commitment.description) %>

## Description

```markdown
<%= truncated_description.gsub(/```/, '\\`\\`\\`') %>
```
<% notice = markdown_truncation_notice(@commitment.description, truncated_description, url: @commitment.path) %>
<%= notice if notice %>
<% end %>

## Status

Progress bar: `<%= '#' * (@commitment.progress_percentage / 2) %><%= '_' * ((100 - @commitment.progress_percentage) / 2) %>` <%= @commitment.progress_percentage %>%

<% noun = @commitment.metric_name.singularize -%>
__<%= @commitment.participant_count %>__ of __<%= @commitment.critical_mass %>__ <%= noun.pluralize(@commitment.critical_mass) %> needed to reach critical mass.
<% unless @commitment.critical_mass_achieved? -%>
__<%= @commitment.remaining_needed_for_critical_mass %>__ more <%= noun.pluralize(@commitment.remaining_needed_for_critical_mass) %> needed.
<% end -%>
<% if @commitment.critical_mass_achieved? -%>
Critical mass achieved! 🎉
<% end -%>

## <%= @commitment.metric_name.capitalize %>

<%
  participant_verb = if @commitment.is_policy?
                       'signed'
                     elsif @commitment.is_calendar_event?
                       'RSVP\'d'
                     else
                       'committed'
                     end
-%>
<% @commitment.committed_participants.order(committed_at: :desc).limit(@participants_list_limit).each do |participant| -%>
* __<%= participant.user&.name || 'Anonymous' %>__ <%= participant_verb %> <%= time_ago_in_words(participant.committed_at) %> ago.
<% end -%>
<% if @commitment.participant_count > @participants_list_limit -%>
* + <%= @commitment.participant_count - @participants_list_limit %> more</span>
<% elsif @commitment.participant_count == 0 -%>
No <%= @commitment.metric_name %> yet.
<% end -%>

<%= render 'shared/backlinks', resource: @commitment %>
<%= render 'shared/attachments_section', resource: @commitment %>
<%= render 'shared/comments_section', resource: @commitment %>
<% if @current_user && @commitment.created_by_id != @current_user.id && !@already_reported %>

---

[Report this commitment](<%= @commitment.path %>/report)
<% end %>
<% end %>
