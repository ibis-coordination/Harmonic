<%= render 'shared/pulse_breadcrumb', items: [
  [@current_tenant.subdomain, @current_tenant.path],
  [@current_collective.name, @current_collective.path],
  'Funding Pool'
] %>

<article class="pulse-resource-detail">
  <header class="pulse-resource-header">
    <div class="pulse-resource-header-top">
      <span class="pulse-resource-type-label">
        <%= octicon 'credit-card', height: 14, class: 'pulse-resource-icon' %>
        Funding Pool
      </span>
    </div>
    <h1 class="pulse-resource-title"><%= @current_collective.name %>'s Funding Pool</h1>
  </header>

  <div class="pulse-resource-body">
    <% if flash[:notice] %>
      <div class="pulse-notice pulse-notice-success" style="margin-bottom: 20px;"><%= flash[:notice] %></div>
    <% end %>
    <% if flash[:alert] %>
      <div class="pulse-notice pulse-notice-danger" style="margin-bottom: 20px;"><%= flash[:alert] %></div>
    <% end %>

    <p class="pulse-body-text">
      Each LLM call an attached agent makes is billed to one enrolled member's own
      prepaid balance, chosen at random per call, so cost spreads roughly evenly
      over time across the enrolled members who have balance available. The pool
      never holds money.
    </p>

    <% if @funding_pool.nil? %>
      <p class="pulse-body-text">
        This collective has no funding pool open yet. Opening a pool puts the
        enabled built-in agents on its payroll automatically; they need the
        pool to run.
      </p>
      <% if @is_pool_admin && @funding_pools_enabled %>
        <section class="pulse-settings-section">
          <h2 class="pulse-section-title">Open a Funding Pool</h2>
          <p class="pulse-section-description">
            Every pool has an explicit ceiling on what it may draw from any one
            enrolled member within a window — day, week, or month (UTC) — set it
            to open the pool.
          </p>
          <form action="<%= @current_collective.path %>/pool/create_funding_pool" method="post" class="pulse-inline-form">
            <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
            <label for="new_pool_draw_cap" class="pulse-label">Ceiling per member (USD)</label>
            <input type="number" id="new_pool_draw_cap" name="member_daily_draw_cap" min="0.01" step="0.01" required
                   class="pulse-form-input">
            <select name="member_draw_cap_period" class="pulse-form-select">
              <% FundingPool::DRAW_CAP_PERIODS.each do |period| %>
                <option value="<%= period %>" <%= "selected" if period == "day" %>>per <%= period %></option>
              <% end %>
            </select>
            <button type="submit" class="pulse-action-btn">Create Funding Pool</button>
          </form>
        </section>
      <% else %>
        <p class="pulse-body-text">A collective admin can open one here.</p>
      <% end %>
    <% else %>

    <% if @funding_pool.archived? %>
      <div class="pulse-notice pulse-notice-warning" style="margin-bottom: 20px;">
        This pool is closed. Its agents stop running and no balances are being drawn on;
        everything resumes automatically if it reopens. Enrollments are kept in case it
        does; you can still withdraw below.
      </div>
      <% if @is_pool_admin && @funding_pools_enabled %>
        <section class="pulse-settings-section">
          <h2 class="pulse-section-title">Reopen the Pool</h2>
          <form action="<%= @current_collective.path %>/pool/create_funding_pool" method="post" class="pulse-inline-form">
            <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
            <label for="new_pool_draw_cap" class="pulse-label">Ceiling per member (USD)</label>
            <input type="number" id="new_pool_draw_cap" name="member_daily_draw_cap" min="0.01" step="0.01" required
                   value="<%= @funding_pool.member_draw_cap_cents / 100.0 %>"
                   class="pulse-form-input">
            <select name="member_draw_cap_period" class="pulse-form-select">
              <% FundingPool::DRAW_CAP_PERIODS.each do |period| %>
                <option value="<%= period %>" <%= "selected" if @funding_pool.member_draw_cap_period == period %>>per <%= period %></option>
              <% end %>
            </select>
            <button type="submit" class="pulse-action-btn">Reopen Funding Pool</button>
          </form>
        </section>
      <% end %>
    <% elsif !@funding_pools_enabled %>
      <div class="pulse-notice pulse-notice-warning" style="margin-bottom: 20px;">
        Funding pools are currently not available for this collective. No balances are
        being drawn on; enrollment is paused. You can still withdraw below<% if @is_pool_admin %>,
        agents can be detached, and the pool can be closed<% end %>.
      </div>
    <% end %>

    <p class="pulse-body-text">
      Pool draw ceiling: this pool stops drawing from a member once its draws from
      them reach <strong><%= number_to_currency(@funding_pool.member_draw_cap_cents / 100.0) %></strong>
      for the <%= @funding_pool.member_draw_cap_period %> (UTC). Each member also sets their own ceiling when enrolling —
      the lower of the two applies. Ceilings are per pool: draws by other pools
      you may be enrolled in count against those pools' ceilings, not this one's.
    </p>

    <p class="pulse-body-text">
      <strong>Usage (last 30 days):</strong>
      <%= number_to_currency(@usage_report[:total_cents].to_f / 100) %>
      <% if @usage_report[:pending_count] > 0 %>
        — <%= pluralize(@usage_report[:pending_count], "call") %> in flight<%= ", #{@usage_report[:stale_pending_count]} stale" if @usage_report[:stale_pending_count] > 0 %>.
      <% end %>
    </p>

    <% agent_spend_by_id = @usage_report[:agent_rows].to_h { |r| [r[:agent]&.id, r[:spend_cents]] } %>
    <% enrolled_user_ids = @pool_enrollments.map(&:user_id) %>

    <% member_count = @pool_enrollments.size %>
    <% if member_count > 0 %>
      <section class="pulse-settings-section">
        <h2 class="pulse-section-title">Maximum Possible Draw</h2>
        <p class="pulse-body-text">
          This pool draws at most its per-member ceiling from each enrolled
          member per period. So the most it can draw in total is that ceiling
          times the number of enrolled members:
        </p>
        <p class="pulse-body-text">
          <strong><%= number_to_currency(@funding_pool.member_draw_cap_cents / 100.0) %></strong> / <%= @funding_pool.member_draw_cap_period %> / member
          × <%= pluralize(member_count, "member") %>
          = <strong><%= number_to_currency(@funding_pool.member_draw_cap_cents * member_count / 100.0) %> / <%= @funding_pool.member_draw_cap_period %></strong>
        </p>
      </section>
    <% end %>

    <section class="pulse-settings-section">
      <h2 class="pulse-section-title">Enrolled Members</h2>
      <% if @usage_report[:member_rows].any? %>
        <table class="pulse-table">
          <thead>
            <tr>
              <th>Member</th>
              <th>Enrolled</th>
              <th>Ceiling</th>
              <th style="text-align: right;">Max possible per 30 days</th>
              <th style="text-align: right;">Last 30 days (actual)</th>
            </tr>
          </thead>
          <tbody>
            <% @usage_report[:member_rows].each do |row| %>
              <% enrollment = row[:enrollment] %>
              <tr class="<%= 'pulse-row-you' if @current_user && row[:user].id == @current_user.id %>">
                <td>
                  <%= link_to row[:user].display_name, row[:user].path %>
                  <% if enrollment.nil? %>
                    <span class="pulse-muted">(withdrawn)</span>
                  <% end %>
                </td>
                <td>
                  <% if enrollment %>
                    <%= enrollment.created_at.strftime("%b %-d, %Y") %>
                  <% else %>
                    <span class="pulse-muted">—</span>
                  <% end %>
                </td>
                <td>
                  <% if enrollment %>
                    <%= number_to_currency(enrollment.draw_cap_cents / 100.0) %> / <%= enrollment.draw_cap_period %>
                  <% else %>
                    <span class="pulse-muted">—</span>
                  <% end %>
                </td>
                <td style="text-align: right;">
                  <% if enrollment %>
                    <% mult = FundingPoolEnrollment::WINDOWS_PER_30_DAYS.fetch(enrollment.draw_cap_period) %>
                    <% windows = case enrollment.draw_cap_period
                                 when "week" then "#{mult} weeks (ceil(30 / 7))"
                                 when "month" then "#{mult} months (a 30-day span can cross a month boundary)"
                                 else "#{mult} days"
                                 end %>
                    <% max_str = number_to_currency(enrollment.draw_cap_per_30_days_cents / 100.0) %>
                    <span title="<%= number_to_currency(enrollment.draw_cap_cents / 100.0) %>/<%= enrollment.draw_cap_period %> × <%= windows %> = <%= max_str %>"><%= max_str %></span>
                  <% else %>
                    <span class="pulse-muted">—</span>
                  <% end %>
                </td>
                <td style="text-align: right;"><%= number_to_currency(row[:spend_cents].to_f / 100) %></td>
              </tr>
            <% end %>
          </tbody>
          <tfoot>
            <tr class="pulse-table-total">
              <td><strong>Total</strong></td>
              <td></td>
              <td></td>
              <td></td>
              <td style="text-align: right;"><strong><%= number_to_currency(@usage_report[:member_rows].sum { |r| r[:spend_cents] }.to_f / 100) %></strong></td>
            </tr>
          </tfoot>
        </table>
      <% else %>
        <p class="pulse-empty-message"><em>No members are enrolled yet.</em></p>
      <% end %>
    </section>

    <section class="pulse-settings-section">
      <h2 class="pulse-section-title">Funded Agents</h2>
      <% if @funded_agents.any? %>
        <table class="pulse-table">
          <thead>
            <tr>
              <th>Agent</th>
              <th>Principal</th>
              <th style="text-align: right;">Last 30 days</th>
              <% if @is_pool_admin %><th></th><% end %>
            </tr>
          </thead>
          <tbody>
            <% @funded_agents.each do |agent| %>
              <% is_you = @current_user && (agent.id == @current_user.id || agent.parent_id == @current_user.id) %>
              <tr class="<%= 'pulse-row-you' if is_you %>">
                <td>
                  <%= link_to agent.display_name, agent.path %>
                  <% unless agent.collective_pool_agent?(@funding_pool) || (agent.parent_id && enrolled_user_ids.include?(agent.parent_id)) %>
                    <br><span class="pulse-muted" style="font-size: 12px;">Not running: principal not enrolled. Runs again when the principal re-enrolls, or when it is detached and given its own billing.</span>
                  <% end %>
                </td>
                <td>
                  <% if agent.parent %>
                    <%= link_to agent.parent.display_name, agent.parent.path %>
                  <% else %>
                    <span class="pulse-muted">—</span>
                  <% end %>
                </td>
                <td style="text-align: right;">
                  <% if agent_spend_by_id[agent.id] %>
                    <%= number_to_currency(agent_spend_by_id[agent.id].to_f / 100) %>
                  <% else %>
                    <span class="pulse-muted">—</span>
                  <% end %>
                </td>
                <% if @is_pool_admin %>
                  <td>
                    <% if agent.collective_pool_agent?(@funding_pool) %>
                      <span class="pulse-muted">Automatic</span>
                    <% else %>
                      <%= button_to "Detach", "#{@current_collective.path}/pool/remove_funded_agent",
                                    method: :delete, params: { ai_agent_id: agent.id }, class: 'pulse-action-btn-danger' %>
                    <% end %>
                  </td>
                <% end %>
              </tr>
            <% end %>
          </tbody>
          <tfoot>
            <tr class="pulse-table-total">
              <td><strong>Total</strong></td>
              <td></td>
              <td style="text-align: right;"><strong><%= number_to_currency(@funded_agents.sum { |a| agent_spend_by_id[a.id] || 0 }.to_f / 100) %></strong></td>
              <% if @is_pool_admin %><td></td><% end %>
            </tr>
          </tfoot>
        </table>
      <% else %>
        <p class="pulse-empty-message"><em>No agents are funded by this pool yet.</em></p>
      <% end %>
    </section>

    <section class="pulse-settings-section">
      <h2 class="pulse-section-title">Your Enrollment</h2>
      <% if @current_user_enrolled %>
        <p class="pulse-body-text">
          You are enrolled: this pool's agents can draw from your prepaid balance,
          up to your own ceiling of
          <strong><%= number_to_currency(@current_user_enrollment.draw_cap_cents / 100.0) %></strong>
          per <%= @current_user_enrollment.draw_cap_period %> (or the pool's ceiling, whichever is lower).
          Withdrawing drops you out of draws immediately.
        </p>
        <% if @funding_pools_enabled %>
          <% matches_pool = @current_user_enrollment.draw_cap_cents == @funding_pool.member_draw_cap_cents &&
                            @current_user_enrollment.draw_cap_period == @funding_pool.member_draw_cap_period %>
          <form action="<%= @current_collective.path %>/pool/enroll_in_funding_pool" method="post" class="pulse-form">
            <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
            <fieldset class="pulse-radio-group">
              <legend class="pulse-fieldset-legend">Your ceiling</legend>
              <label class="pulse-radio-label">
                <input type="radio" name="ceiling_choice" value="pool" <%= "checked" if matches_pool %> class="pulse-radio-input">
                <span>Match the pool ceiling — <%= number_to_currency(@funding_pool.member_draw_cap_cents / 100.0) %> per <%= @funding_pool.member_draw_cap_period %></span>
              </label>
              <label class="pulse-radio-label">
                <input type="radio" name="ceiling_choice" value="custom" <%= "checked" unless matches_pool %> class="pulse-radio-input">
                <span>Set your own ceiling (USD):</span>
                <input type="number" name="daily_draw_cap" min="0.01" step="0.01"
                       value="<%= @current_user_enrollment.draw_cap_cents / 100.0 unless matches_pool %>"
                       class="pulse-form-input" style="width: auto;">
                <select name="draw_cap_period" class="pulse-form-select" style="width: auto;">
                  <% FundingPool::DRAW_CAP_PERIODS.each do |period| %>
                    <option value="<%= period %>" <%= "selected" if !matches_pool && @current_user_enrollment.draw_cap_period == period %>>per <%= period %></option>
                  <% end %>
                </select>
              </label>
            </fieldset>
            <button type="submit" class="pulse-action-btn">Update Ceiling</button>
          </form>
        <% end %>
        <%= button_to "Withdraw from Pool", "#{@current_collective.path}/pool/withdraw_from_funding_pool",
                      method: :delete, class: "pulse-action-btn-danger",
                      data: { turbo_confirm: "Withdraw from the funding pool? You drop out of draws immediately. Your agents funded by this pool stay attached (still listed as funded agents) but their calls are refused until you re-enroll or they are detached." } %>
      <% elsif @funding_pools_enabled && !@funding_pool.archived? %>
        <p class="pulse-body-text">
          Enrolling is consenting to fund this collective's agents from your own
          prepaid balance — each call is billed to one enrolled member, drawn at
          random, and this pool stops drawing from you once its draws reach your
          ceiling. The pool's ceiling is the default; you can set your own, and
          you can change it or withdraw at any time.
          Enrollment requires prepaid credits.
        </p>
        <% unless @current_user.funded_billing? %>
          <p class="pulse-body-text">
            You don't have prepaid credits yet —
            <a href="/billing?return_to=<%= CGI.escape("#{@current_collective.path}/pool") %>" class="pulse-link">top up on the billing page</a>
            and you'll land back here to enroll.
          </p>
        <% end %>
        <form action="<%= @current_collective.path %>/pool/enroll_in_funding_pool" method="post" class="pulse-form">
          <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
          <fieldset class="pulse-radio-group">
            <legend class="pulse-fieldset-legend">Your ceiling</legend>
            <label class="pulse-radio-label">
              <input type="radio" name="ceiling_choice" value="pool" checked class="pulse-radio-input">
              <span>Match the pool ceiling — <%= number_to_currency(@funding_pool.member_draw_cap_cents / 100.0) %> per <%= @funding_pool.member_draw_cap_period %></span>
            </label>
            <label class="pulse-radio-label">
              <input type="radio" name="ceiling_choice" value="custom" class="pulse-radio-input">
              <span>Set your own ceiling (USD):</span>
              <input type="number" name="daily_draw_cap" min="0.01" step="0.01"
                     class="pulse-form-input" style="width: auto;">
              <select name="draw_cap_period" class="pulse-form-select" style="width: auto;">
                <% FundingPool::DRAW_CAP_PERIODS.each do |period| %>
                  <option value="<%= period %>" <%= "selected" if period == "day" %>>per <%= period %></option>
                <% end %>
              </select>
            </label>
          </fieldset>
          <button type="submit" class="pulse-action-btn">Enroll in Pool</button>
        </form>
      <% else %>
        <p class="pulse-body-text">You are not enrolled.</p>
      <% end %>
    </section>

    <% if @is_pool_admin %>
      <% if @funding_pools_enabled && !@funding_pool.archived? %>
        <section class="pulse-settings-section">
          <h2 class="pulse-section-title">Pool Draw Ceiling</h2>
          <p class="pulse-section-description">
            The most this pool may bill any one enrolled member within its window (UTC);
            a member at the ceiling rejoins the draw when the window rolls over. Members
            may also set themselves a personal ceiling when they enroll — the lower of
            the two applies. Every pool must have a ceiling; lowering it binds everyone
            immediately, and raising it never takes any member past the ceiling they
            stated for themselves.
          </p>
          <form action="<%= @current_collective.path %>/pool/update_ceiling" method="post" class="pulse-inline-form">
            <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
            <label for="member_daily_draw_cap" class="pulse-label">Ceiling per member (USD)</label>
            <input type="number" id="member_daily_draw_cap" name="member_daily_draw_cap" min="0.01" step="0.01" required
                   value="<%= @funding_pool.member_draw_cap_cents / 100.0 %>"
                   class="pulse-form-input">
            <select name="member_draw_cap_period" class="pulse-form-select">
              <% FundingPool::DRAW_CAP_PERIODS.each do |period| %>
                <option value="<%= period %>" <%= "selected" if @funding_pool.member_draw_cap_period == period %>>per <%= period %></option>
              <% end %>
            </select>
            <button type="submit" class="pulse-action-btn">Save Ceiling</button>
          </form>
        </section>
      <% end %>

      <%# Operator flag, not self-serve availability: a self-serve pool funds
          only the collective's own built-in agents, never arbitrary agents. %>
      <% if @attachable_agents&.any? %>
        <section class="pulse-settings-section">
          <h2 class="pulse-section-title">Attach an Enrolled Member's Agent</h2>
          <p class="pulse-section-description">
            Funding is separate from membership: attaching an agent here does not
            add it to the collective. The agent's principal must be enrolled.
          </p>
          <form action="<%= @current_collective.path %>/pool/add_funded_agent" method="post" class="pulse-inline-form">
            <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
            <select name="ai_agent_id" class="pulse-form-select">
              <option value="">Select an agent...</option>
              <% @attachable_agents.each do |agent| %>
                <option value="<%= agent.id %>"><%= agent.display_name %></option>
              <% end %>
            </select>
            <button type="submit" class="pulse-action-btn">Attach</button>
          </form>
        </section>
      <% end %>

      <% unless @funding_pool.archived? %>
        <section class="pulse-settings-section">
          <h2 class="pulse-section-title">Close the Pool</h2>
          <p class="pulse-section-description">
            Closing the pool stops all of its spending: attached agents stop running from
            their next call, and resume automatically if the pool reopens (or once they are
            detached and funded individually). Enrollments are kept as the consent record
            for past draws.
          </p>
          <%= button_to "Close Funding Pool", "#{@current_collective.path}/pool/close_funding_pool",
                        method: :post, class: "pulse-action-btn-danger",
                        data: { turbo_confirm: "Close the funding pool? Attached agents stop running until it reopens or they are detached and funded individually." } %>
        </section>
      <% end %>
    <% end %>
    <% end %>
  </div>
</article>
