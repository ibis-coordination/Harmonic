<div style="display: flex; flex-direction: column; height: calc(100vh - 60px);">
  <header class="trio-header">
    <div data-controller="trio-logo"
         data-trio-logo-size-value="80"
         data-trio-logo-rotation-speed-value="0.4"
         class="trio-header-logo">
    </div>
    <h1 class="trio-header-title">Trio</h1>
    <p class="trio-header-subtitle">Your in-app assistant.</p>
  </header>

  <%= render 'chats/chat_window' %>
</div>

<style>
  .trio-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 16px 16px 12px;
    border-bottom: 1px solid var(--color-border-default);
    gap: 4px;
  }

  .trio-header-logo {
    width: 80px;
    height: 80px;
  }

  .trio-header-title {
    font-size: 1.25rem;
    font-weight: 500;
    margin: 0;
    letter-spacing: 0.04em;
  }

  .trio-header-subtitle {
    font-size: 0.85rem;
    color: var(--color-fg-muted);
    margin: 0;
  }
</style>
