<%# Kill switch: served in place of the real service worker when the
    service_worker feature flag is off. Existing installs pick this up on
    their next update check, drop their caches, and uninstall themselves. %>
self.addEventListener("install", () => self.skipWaiting());
self.addEventListener("activate", (event) => {
  event.waitUntil((async () => {
    const names = await caches.keys();
    await Promise.all(names.filter((n) => n.startsWith("harmonic-")).map((n) => caches.delete(n)));
    await self.registration.unregister();
  })());
});
