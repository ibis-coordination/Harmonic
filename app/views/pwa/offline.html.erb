<%# Offline fallback page. Pre-cached by the service worker on install and
    served when an HTML navigation fails. Fully self-contained — when this
    renders, nothing else is reachable. %>
<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Offline — Harmonic</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
      /* Values mirror root_variables.css (light/dark) — this page must be
         self-contained, so the palette is inlined rather than linked. */
      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        margin: 0;
        background: #ffffff;
        color: #24292f;
      }
      @media (prefers-color-scheme: dark) {
        body { background: #0d1117; color: #c9d1d9; }
        button { background: #0d1117; border-color: #30363d; }
        button:hover { background: #161b22; }
      }
      main { text-align: center; padding: 2rem; max-width: 24rem; }
      h1 { font-size: 1.25rem; margin-bottom: 0.5rem; }
      p { margin: 0 0 1.5rem; opacity: 0.8; }
      /* Mirrors .pulse-action-btn-secondary */
      button {
        font: inherit;
        font-size: 14px;
        font-weight: 500;
        line-height: 1.5;
        padding: 8px 16px;
        min-height: 39px;
        border: 1px solid #d0d7de;
        background: #ffffff;
        color: inherit;
        cursor: pointer;
      }
      button:hover { background: #f6f8fa; }
    </style>
  </head>
  <body>
    <main>
      <h1>You're offline</h1>
      <p>Harmonic needs a connection. Your content will be here when you're back online.</p>
      <button onclick="location.reload()">Try again</button>
    </main>
  </body>
</html>
