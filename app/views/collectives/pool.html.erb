<%= render 'shared/pulse_breadcrumb', items: [
  [@current_tenant.subdomain, @current_tenant.path],
  [@current_collective.name, @current_collective.path],
  'Funding Pool'
] %>

<article class="pulse-resource-detail">
  <header class="pulse-resource-header">
    <div class="pulse-resource-header-top">
      <span class="pulse-resource-type-label">
        <%= octicon 'credit-card', height: 14, class: 'pulse-resource-icon' %>
        Funding Pool
      </span>
    </div>
    <h1 class="pulse-resource-title"><%= @current_collective.name %>'s Funding Pool</h1>
  </header>

  <div class="pulse-resource-body">
    <% if flash[:notice] %>
      <div class="pulse-notice pulse-notice-success" style="margin-bottom: 20px;"><%= flash[:notice] %></div>
    <% end %>
    <% if flash[:alert] %>
      <div class="pulse-notice pulse-notice-danger" style="margin-bottom: 20px;"><%= flash[:alert] %></div>
    <% end %>

    <p class="pulse-body-text">
      Each LLM call an attached agent makes is billed to one enrolled member's own
      prepaid balance, chosen at random per call, so cost spreads roughly evenly
      over time across the enrolled members who have balance available. The pool
      never holds money.
    </p>

    <% if @funding_pool.archived? %>
      <div class="pulse-notice pulse-notice-warning" style="margin-bottom: 20px;">
        This pool is closed. Its agents stop running and no balances are being drawn on;
        everything resumes automatically if it reopens. Enrollments are kept in case it
        does; you can still withdraw below.
      </div>
    <% elsif !@funding_pools_enabled %>
      <div class="pulse-notice pulse-notice-warning" style="margin-bottom: 20px;">
        Funding pools are currently disabled for this collective. No balances are being
        drawn on; enrollment is paused. You can still withdraw below.
      </div>
    <% end %>

    <p class="pulse-body-text">
      Pool draw ceiling: this pool stops drawing from a member once its draws from
      them reach <strong><%= number_to_currency(@funding_pool.member_draw_cap_cents / 100.0) %></strong>
      for the day (UTC). Each member also sets their own ceiling when enrolling —
      the lower of the two applies. Ceilings are per pool: draws by other pools
      you may be enrolled in count against those pools' ceilings, not this one's.
    </p>

    <p class="pulse-body-text">
      <strong>Usage (last 30 days):</strong>
      <%= number_to_currency(@usage_report[:total_cents].to_f / 100) %>
      <% if @usage_report[:pending_count] > 0 %>
        — <%= pluralize(@usage_report[:pending_count], "call") %> in flight<%= ", #{@usage_report[:stale_pending_count]} stale" if @usage_report[:stale_pending_count] > 0 %>.
      <% end %>
    </p>

    <% agent_spend_by_id = @usage_report[:agent_rows].to_h { |r| [r[:agent]&.id, r[:spend_cents]] } %>
    <% enrolled_user_ids = @pool_enrollments.map(&:user_id) %>

    <section class="pulse-settings-section">
      <h2 class="pulse-section-title">Enrolled Members</h2>
      <% if @usage_report[:member_rows].any? %>
        <ul class="pulse-list">
          <% @usage_report[:member_rows].each do |row| %>
            <li>
              <%= link_to row[:user].display_name, row[:user].path %>
              <% unless enrolled_user_ids.include?(row[:user].id) %>
                <span class="pulse-muted">(withdrawn)</span>
              <% end %>
              <span class="pulse-muted">— <%= number_to_currency(row[:spend_cents].to_f / 100) %> (last 30 days)</span>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="pulse-empty-message"><em>No members are enrolled yet.</em></p>
      <% end %>
    </section>

    <section class="pulse-settings-section">
      <h2 class="pulse-section-title">Funded Agents</h2>
      <% if @funded_agents.any? %>
        <ul class="pulse-list">
          <% @funded_agents.each do |agent| %>
            <li>
              <%= link_to agent.display_name, agent.path %>
              <% if agent.parent %>
                <span class="pulse-muted">— principal <%= link_to agent.parent.display_name, agent.parent.path %></span>
              <% end %>
              <% if agent_spend_by_id[agent.id] %>
                <span class="pulse-muted">— <%= number_to_currency(agent_spend_by_id[agent.id].to_f / 100) %> (last 30 days)</span>
              <% end %>
              <% unless agent.parent_id && enrolled_user_ids.include?(agent.parent_id) %>
                <span class="pulse-muted">— not running: principal not enrolled. Runs again when the principal re-enrolls, or when it is detached and given its own billing.</span>
              <% end %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="pulse-empty-message"><em>No agents are funded by this pool yet.</em></p>
      <% end %>
    </section>

    <section class="pulse-settings-section">
      <h2 class="pulse-section-title">Your Enrollment</h2>
      <% if @current_user_enrolled %>
        <p class="pulse-body-text">
          You are enrolled: this pool's agents can draw from your prepaid balance,
          up to your own ceiling of
          <strong><%= number_to_currency(@current_user_enrollment.draw_cap_cents / 100.0) %></strong>
          per day (or the pool's ceiling, whichever is lower).
          Withdrawing drops you out of draws immediately.
        </p>
        <% if @funding_pools_enabled %>
          <% matches_pool = @current_user_enrollment.draw_cap_cents == @funding_pool.member_draw_cap_cents %>
          <form action="<%= @current_collective.path %>/settings/enroll_in_funding_pool" method="post" class="pulse-form">
            <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
            <fieldset class="pulse-radio-group">
              <legend class="pulse-fieldset-legend">Your daily ceiling</legend>
              <label class="pulse-radio-label">
                <input type="radio" name="ceiling_choice" value="pool" <%= "checked" if matches_pool %> class="pulse-radio-input">
                <span>Match the pool ceiling — <%= number_to_currency(@funding_pool.member_draw_cap_cents / 100.0) %> per day</span>
              </label>
              <label class="pulse-radio-label">
                <input type="radio" name="ceiling_choice" value="custom" <%= "checked" unless matches_pool %> class="pulse-radio-input">
                <span>Set your own lower ceiling (USD per day):</span>
                <input type="number" name="daily_draw_cap" min="0.01" step="0.01"
                       max="<%= @funding_pool.member_draw_cap_cents / 100.0 %>"
                       value="<%= @current_user_enrollment.draw_cap_cents / 100.0 unless matches_pool %>"
                       class="pulse-form-input" style="width: auto;">
              </label>
            </fieldset>
            <button type="submit" class="pulse-action-btn">Update Ceiling</button>
          </form>
        <% end %>
        <%= button_to "Withdraw from Pool", "#{@current_collective.path}/settings/withdraw_from_funding_pool",
                      method: :delete, class: "pulse-action-btn-danger",
                      data: { turbo_confirm: "Withdraw from the funding pool? You drop out of draws immediately. Your agents funded by this pool stay attached (still listed as funded agents) but their calls are refused until you re-enroll or they are detached." } %>
      <% elsif @funding_pools_enabled && !@funding_pool.archived? %>
        <p class="pulse-body-text">
          Enrolling is consenting to fund this collective's agents from your own
          prepaid balance — each call is billed to one enrolled member, drawn at
          random, and this pool stops drawing from you once its draws reach your
          daily ceiling. The pool's ceiling is the default; you can set a lower
          one for yourself, and you can change it or withdraw at any time.
          Enrollment requires prepaid credits.
        </p>
        <form action="<%= @current_collective.path %>/settings/enroll_in_funding_pool" method="post" class="pulse-form">
          <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
          <fieldset class="pulse-radio-group">
            <legend class="pulse-fieldset-legend">Your daily ceiling</legend>
            <label class="pulse-radio-label">
              <input type="radio" name="ceiling_choice" value="pool" checked class="pulse-radio-input">
              <span>Match the pool ceiling — <%= number_to_currency(@funding_pool.member_draw_cap_cents / 100.0) %> per day</span>
            </label>
            <label class="pulse-radio-label">
              <input type="radio" name="ceiling_choice" value="custom" class="pulse-radio-input">
              <span>Set your own lower ceiling (USD per day):</span>
              <input type="number" name="daily_draw_cap" min="0.01" step="0.01"
                     max="<%= @funding_pool.member_draw_cap_cents / 100.0 %>"
                     class="pulse-form-input" style="width: auto;">
            </label>
          </fieldset>
          <button type="submit" class="pulse-action-btn">Enroll in Pool</button>
        </form>
      <% else %>
        <p class="pulse-body-text">You are not enrolled.</p>
      <% end %>
    </section>
  </div>
</article>
