<%= render 'shared/pulse_breadcrumb', items: [
  [@current_tenant.subdomain, @current_tenant.path],
  [@current_collective.name, @current_collective.path],
  'Settings'
] %>

<article class="pulse-resource-detail">
  <header class="pulse-resource-header">
    <div class="pulse-resource-header-top">
      <span class="pulse-resource-type-label">
        <%= octicon 'gear', height: 14, class: 'pulse-resource-icon' %>
        Settings
      </span>
      <%= render 'shared/collective_tier_badge', collective: @current_collective %>
    </div>
    <h1 class="pulse-resource-title"><%= @current_collective.private_workspace? ? "Workspace" : "Collective" %> Settings</h1>
  </header>

  <div class="pulse-settings-form">
    <% if flash[:notice] %>
      <div class="pulse-notice pulse-notice-success" style="margin-bottom: 20px;">
        <%= flash[:notice] %>
      </div>
    <% end %>

    <% if flash[:error] %>
      <div class="pulse-notice pulse-notice-danger" style="margin-bottom: 20px;">
        <%= flash[:error] %>
      </div>
    <% end %>

    <% if @current_collective.pending_billing_setup? && @current_tenant.feature_enabled?("stripe_billing") %>
      <div class="pulse-notice pulse-notice-warning" style="margin-bottom: 20px;">
        <span>
          <%= octicon 'clock', height: 14 %>
          <strong>Pending</strong> — This collective will activate once billing is set up.
          <%= link_to "Set up billing", "/billing", class: "pulse-link" %>
        </span>
      </div>

    <% elsif @current_collective.archived? %>
      <div class="pulse-notice pulse-notice-warning" style="margin-bottom: 20px;">
        <span>
          <%= octicon 'archive', height: 14 %>
          <strong>Inactive</strong> — This <%= @current_collective.private_workspace? ? "workspace" : "collective" %> is archived and not being billed.
          <% if @current_collective.created_by_id && @current_user.id == @current_collective.created_by_id %>
            <%= button_to "Reactivate",
                          "#{@current_collective.path}/unarchive",
                          method: :post,
                          class: "pulse-action-btn-small",
                          form: { style: "display: inline; margin-left: 8px;" },
                          data: { turbo_confirm: "Reactivate #{@current_collective.name}? It will return on the free plan. You'll be asked to reverify with your 2FA code on the next step." } %>
          <% else %>
            Only the creator can reactivate it.
          <% end %>
        </span>
      </div>

    <% else %>

    <section class="pulse-settings-section">
      <h2 class="pulse-section-title"><%= @current_collective.private_workspace? ? "Workspace" : "Collective" %> Image</h2>
      <%= render 'shared/profile_image_upload', resource: @current_collective, size: 83 %>
    </section>

    <%= form_with(url: "#{@current_collective.path}/settings", id: "collective-settings-form", class: "pulse-form", data: { controller: "form-tracker", action: "change->form-tracker#trackChange input->form-tracker#trackChange" }) do |form| %>
      <section class="pulse-settings-section">
        <h2 class="pulse-section-title"><%= @current_collective.private_workspace? ? "Workspace" : "Collective" %> Name</h2>
        <div class="pulse-form-group">
          <%= form.text_field :name, placeholder: @current_collective.private_workspace? ? 'Workspace Name' : 'Collective Name', value: @current_collective.name, class: 'pulse-form-input' %>
        </div>
      </section>

      <section class="pulse-settings-section">
        <h2 class="pulse-section-title"><%= @current_collective.private_workspace? ? "Workspace" : "Collective" %> Description</h2>
        <div class="pulse-form-group">
          <%= form.text_area :description, placeholder: 'Description (markdown supported)', value: @current_collective.description, class: 'pulse-form-textarea', rows: 4 %>
        </div>
      </section>

      <section class="pulse-settings-section">
        <h2 class="pulse-section-title">Time Zone</h2>
        <p class="pulse-section-description">
          The collective time zone determines when cycles begin and end.
        </p>
        <div class="pulse-form-group">
          <%= form.time_zone_select :timezone, ActiveSupport::TimeZone.all, { default: @current_collective.timezone.name }, class: 'pulse-form-select' %>
        </div>
      </section>

      <section class="pulse-settings-section">
        <h2 class="pulse-section-title">Tempo</h2>
        <p class="pulse-section-description">
          How frequently should collective members check in (approximately)?
          This determines the primary cycle duration.
        </p>
        <div class="pulse-form-group">
          <%= form.select :tempo, [['Daily', 'daily'], ['Weekly', 'weekly'], ['Monthly', 'monthly']], { selected: @current_collective.tempo }, class: 'pulse-form-select' %>
        </div>
      </section>

      <section class="pulse-settings-section">
        <h2 class="pulse-section-title">Synchronization Mode</h2>
        <p class="pulse-section-description">
          Which metaphor best describes how this collective is organized?
        </p>
        <fieldset class="pulse-radio-group">
          <label class="pulse-radio-label">
            <%= form.radio_button :synchronization_mode, 'improv', checked: @current_collective.improv?, class: 'pulse-radio-input' %>
            <span><strong>Improv</strong> (no formal leadership roles)</span>
          </label>
          <label class="pulse-radio-label">
            <%= form.radio_button :synchronization_mode, 'orchestra', checked: @current_collective.orchestra?, class: 'pulse-radio-input' %>
            <span><strong>Orchestra</strong> (has formal leadership roles)</span>
          </label>
        </fieldset>
      </section>

      <% unless @current_collective.private_workspace? %>
      <section class="pulse-settings-section">
        <h2 class="pulse-section-title">Invitations</h2>
        <fieldset class="pulse-radio-group">
          <legend class="pulse-fieldset-legend">Who can invite new members?</legend>
          <label class="pulse-radio-label">
            <%= form.radio_button :invitations, 'all_members', checked: @current_collective.all_members_can_invite?, class: 'pulse-radio-input' %>
            <span>All members can invite</span>
          </label>
          <label class="pulse-radio-label">
            <%= form.radio_button :invitations, 'only_admins', checked: !@current_collective.all_members_can_invite?, class: 'pulse-radio-input' %>
            <span>Only admins can invite</span>
          </label>
        </fieldset>
      </section>

      <section class="pulse-settings-section">
        <h2 class="pulse-section-title">Representation</h2>
        <fieldset class="pulse-radio-group">
          <legend class="pulse-fieldset-legend">Who can act as a representative of <%= @current_collective.name %> within other collectives?</legend>
          <label class="pulse-radio-label">
            <%= form.radio_button :representation, 'any_member', checked: @current_collective.any_member_can_represent?, class: 'pulse-radio-input' %>
            <span>Any member can represent the collective</span>
          </label>
          <label class="pulse-radio-label">
            <%= form.radio_button :representation, 'only_representatives', checked: !@current_collective.any_member_can_represent?, class: 'pulse-radio-input' %>
            <span>Only designated representatives can represent the collective</span>
          </label>
        </fieldset>
      </section>

      <section class="pulse-settings-section">
        <h2 class="pulse-section-title">Summarization</h2>
        <fieldset class="pulse-radio-group">
          <legend class="pulse-fieldset-legend">Who can write summaries of items in <%= @current_collective.name %>?</legend>
          <label class="pulse-radio-label">
            <%= form.radio_button :summarization, 'any_member', checked: @current_collective.any_member_can_summarize?, class: 'pulse-radio-input' %>
            <span>Any member can write summaries</span>
          </label>
          <label class="pulse-radio-label">
            <%= form.radio_button :summarization, 'only_summarizers', checked: !@current_collective.any_member_can_summarize?, class: 'pulse-radio-input' %>
            <span>Only designated summarizers can write summaries</span>
          </label>
        </fieldset>
      </section>
      <% end %>

      <%
        available_flags = FeatureFlagService.all_flags.select { |f|
          FeatureFlagService.tenant_enabled?(@current_tenant, f) &&
            FeatureFlagService.flag_metadata(f).fetch("collective_level", false) &&
            !FeatureFlagService.operator_managed?(f)
        }
        # Trio is managed on the Agents page, not by a checkbox here — settings
        # only points there. (The update endpoint still accepts the flag, so
        # saving this form never silently disables Trio.)
        trio_available = available_flags.include?("trio")
        available_flags -= ["trio"]
        tier_in_effect = @current_tenant.feature_enabled?("stripe_billing")
        if tier_in_effect
          paid_flags, free_flags = available_flags.partition { |f| Collective::PAID_FEATURE_FLAGS.include?(f) }
        else
          paid_flags, free_flags = [], available_flags
        end
      %>

      <% render_flag_item = ->(flag_name) {
        metadata = FeatureFlagService.flag_metadata(flag_name)
        collective_enabled_locally = @current_collective.feature_flag_enabled_locally?(flag_name) %>
        <div class="pulse-feature-flag-item">
          <strong><%= metadata['name'] %></strong>
          <label class="pulse-checkbox-label">
            <%= form.check_box "feature_#{flag_name}", checked: collective_enabled_locally, id: "feature_#{flag_name}", class: 'pulse-checkbox-input' %>
            <span><%= metadata['description'] %></span>
          </label>
          <% if flag_name == 'file_attachments' && collective_enabled_locally %>
            <p class="pulse-feature-usage">
              Current usage:
              <%= @current_collective.file_storage_usage_in_human_size %> of <%= @current_collective.file_storage_limit_in_human_size %>
              <% if ENV['SAAS_MODE'] == 'true' %>
                <%= link_to 'Purchase more space', '/billing', class: 'pulse-action-btn-small' %>
              <% else %>
                <br/>
                Increase limit: <%= form.number_field :file_storage_limit, value: @current_collective.file_storage_limit / 1.megabyte, class: 'pulse-form-input pulse-form-input-small' %> MB
              <% end %>
            </p>
          <% end %>
        </div>
      <% } %>

      <% render_trio_pointer = -> {
        %>
        <div class="pulse-feature-flag-item">
          <strong>Trio</strong>
          <p class="pulse-muted" style="margin: 4px 0 6px 0; font-size: 13px;">
            <%= @current_collective.feature_flag_enabled_locally?("trio") ? "Enabled" : "Not enabled" %> —
            the built-in agents are managed on the Agents page.
          </p>
          <a href="<%= @current_collective.path %>/agents" class="pulse-action-btn pulse-action-btn-sm">
            <%= octicon 'command-palette', height: 12 %> Manage agents
          </a>
        </div>
      <% } %>

      <% render_automations_item = -> {
        %>
        <div class="pulse-feature-flag-item">
          <strong>Automations</strong>
          <p class="pulse-muted" style="margin: 4px 0 6px 0; font-size: 13px;">
            Event-triggered actions, webhooks, and schedules.
            <%= @enabled_automations_count.to_i %> enabled.
          </p>
          <a href="<%= @current_collective.path %>/settings/automations" class="pulse-action-btn pulse-action-btn-sm">
            <%= octicon 'zap', height: 12 %> Manage automations
          </a>
        </div>
      <% } %>

      <% show_paid_section = tier_in_effect && !@current_collective.is_main_collective? %>
      <% automations_available = @current_tenant.automations_enabled? %>
      <%# Automations group with the paid features. Where there is no paid
          section (non-billing tenants, main collectives), they group with the
          plain features instead — never a standalone section of their own. %>
      <% automations_with_free = automations_available && !show_paid_section %>
      <% trio_with_free = trio_available && !show_paid_section %>
      <% if free_flags.any? || show_paid_section || automations_with_free || trio_with_free %>
        <%# Suppress border-bottom; the sticky Save Settings form-actions below %>
        <%# has its own border-top, so keeping both produces two visible lines. %>
        <section class="pulse-settings-section" style="border-bottom: none;">
          <% if free_flags.any? || automations_with_free || trio_with_free %>
            <h2 class="pulse-section-title"><%= tier_in_effect ? "Features" : "Features Enabled" %></h2>
            <% free_flags.each { |f| render_flag_item.call(f) } %>
            <% render_automations_item.call if automations_with_free %>
            <% render_trio_pointer.call if trio_with_free %>
          <% end %>

          <% if show_paid_section %>
            <h3 class="pulse-section-title" style="<%= free_flags.any? ? 'margin-top: 24px;' : '' %> font-size: 16px;">
              Paid Plan Features
            </h3>

            <% if @current_collective.paid_tier? %>
              <p class="pulse-muted" style="margin-bottom: 12px; font-size: 13px;">
                <%= octicon 'credit-card', height: 12 %>
                This collective is on the paid plan ($3/month).
              </p>

              <% render_automations_item.call if automations_available %>
              <% paid_flags.each { |f| render_flag_item.call(f) } %>
              <% render_trio_pointer.call if trio_available %>
            <% elsif @current_collective.requires_stripe_billing? %>
              <p class="pulse-muted" style="margin-bottom: 12px; font-size: 13px;">
                <%= octicon 'alert', height: 12 %>
                Billing lapsed — paid features are paused. Restore your subscription to resume.
              </p>
              <%= button_to "Resume billing", "/billing", method: :get,
                            class: "pulse-action-btn",
                            form: { style: "display: inline;" } %>
            <% else %>
              <p class="pulse-muted" style="margin-bottom: 12px; font-size: 13px;">
                <%= octicon 'credit-card', height: 12 %>
                Upgrade to the paid plan ($3/month) to unlock <%= paid_feature_labels(@current_tenant).to_sentence %> on this collective.
              </p>
              <% if @current_user.id == @current_collective.created_by_id %>
                <%# Links go to the GET upgrade preview, which shows the %>
                <%# prorated charge (for owners with billing) or the Stripe %>
                <%# Checkout next step (without) before any charge happens. %>
                <% if @pending_collective_upgrade_in_session %>
                  <p class="pulse-muted" style="margin-bottom: 8px; font-size: 13px;">
                    <em>You started checkout for this collective. Resume to finish.</em>
                  </p>
                  <a href="<%= @current_collective.path %>/upgrade" class="pulse-action-btn">Resume checkout</a>
                <% else %>
                  <a href="<%= @current_collective.path %>/upgrade" class="pulse-action-btn">Upgrade to Paid ($3/month)</a>
                <% end %>
              <% else %>
                <p class="pulse-muted" style="font-size: 13px;">
                  <em>Only the collective owner can upgrade.</em>
                </p>
              <% end %>
            <% end %>
          <% end %>
        </section>
      <% end %>

      <div class="pulse-form-actions pulse-form-actions-sticky">
        <button type="submit" class="pulse-action-btn pulse-action-btn-disabled" disabled data-form-tracker-target="submit">Save Settings</button>
      </div>
    <% end %>

    <% if @current_tenant.feature_enabled?("stripe_billing") && !@current_collective.is_main_collective? && @current_collective.paid_tier? && @current_user.id == @current_collective.created_by_id %>
      <%
        downgrade_disables = paid_features_to_disable_on_downgrade(@current_collective)
        n_auto = @enabled_automations_count.to_i
        # Build two parallel sentences for the section copy and the confirm dialog.
        # Phrases are conditional so we don't promise to turn off features the
        # tenant doesn't support.
        section_phrases = []
        section_phrases << "disable #{pluralize(n_auto, 'enabled automation')}" if n_auto > 0
        section_phrases << "turn off #{downgrade_disables.to_sentence}" if downgrade_disables.any?

        confirm_phrases = []
        confirm_phrases << "#{pluralize(n_auto, 'enabled automation')} will be disabled" if n_auto > 0
        confirm_phrases << "#{downgrade_disables.to_sentence} will be turned off" if downgrade_disables.any?

        confirm_text = "Downgrade #{@current_collective.name} to the free plan?"
        confirm_text += " #{sentence_case(confirm_phrases.to_sentence)}." if confirm_phrases.any?
      %>
      <section class="pulse-settings-section">
        <h2 class="pulse-section-title">Downgrade to Free</h2>
        <p class="pulse-section-description">
          Move this collective back to the free plan.
          <% if section_phrases.any? %>
            This will <%= section_phrases.to_sentence %>.
          <% end %>
        </p>
        <%= button_to "Downgrade to Free",
                      "#{@current_collective.path}/downgrade",
                      method: :post,
                      class: "pulse-action-btn-danger",
                      form: { style: "display: inline;" },
                      data: { turbo_confirm: confirm_text } %>
      </section>
    <% end %>

    <% if @current_collective.standard? && @current_tenant.feature_enabled?("stripe_billing") && (@funding_pools_enabled || @funding_pool) %>
      <section class="pulse-settings-section">
        <h2 class="pulse-section-title">Agent Funding Pool</h2>
        <p class="pulse-section-description">
          A funding pool lets members fund this collective's agents together: each
          LLM call an attached agent makes is billed to one enrolled member's own
          prepaid balance. The pool is managed on the
          <a href="<%= @current_collective.path %>/pool" class="pulse-link">pool page</a><%= @funding_pool ? "." : ", where an admin can open one." %>
        </p>
      </section>
    <% end %>

    <% unless @current_collective.private_workspace? %>
      <section class="pulse-settings-section">
        <h2 class="pulse-section-title">Agent Members</h2>
        <p class="pulse-section-description">
          Agents are members. See who runs here on the
          <a href="<%= @current_collective.path %>/agents" class="pulse-link">Agents page</a>;
          add or remove agents on the
          <a href="<%= @current_collective.path %>/members" class="pulse-link">Members page</a>.
        </p>
      </section>
    <% end %>


      <% if @current_tenant.feature_enabled?("collective_export") %>
        <section class="pulse-settings-section">
          <h2 class="pulse-section-title"><%= octicon 'download', height: 16 %> Data Export</h2>
          <p class="pulse-section-description">
            Export this collective's data as a ZIP file.
          </p>
          <a href="<%= @current_collective.path %>/exports" class="pulse-action-btn">
            <%= octicon 'download', height: 14 %> Export Data
          </a>
        </section>
      <% end %>

      <% if @current_tenant.feature_enabled?("stripe_billing") && !@current_collective.is_main_collective? && @current_collective.paid_tier? %>
        <section class="pulse-settings-section">
          <p class="pulse-muted">
            <%= octicon 'credit-card', height: 14 %>
            <% if @current_collective.billing_exempt? %>
              Billing-exempt by an admin. <%= link_to "View billing", "/billing", class: "pulse-link" %>
            <% else %>
              <%= link_to "Manage billing", "/billing", class: "pulse-link" %>
            <% end %>
          </p>
        </section>
      <% end %>

      <% if !@current_collective.is_main_collective? && @current_user.id == @current_collective.created_by_id %>
        <section class="pulse-settings-section pulse-danger-zone">
          <h2 class="pulse-section-title"><%= octicon 'alert', height: 16 %> Danger Zone</h2>
          <p class="pulse-section-description">
            Archiving makes this <%= @current_collective.private_workspace? ? "workspace" : "collective" %> inaccessible to all members and drops it back to the free plan (paid features turn off, billing stops). You can reactivate it from this page on the free plan; re-upgrade explicitly if you want paid features back.
          </p>
          <%= button_to "Archive #{@current_collective.private_workspace? ? 'Workspace' : 'Collective'}",
                        "#{@current_collective.path}/archive",
                        method: :post,
                        class: "pulse-action-btn pulse-action-btn-danger",
                        form: { style: "display: inline;" },
                        data: { turbo_confirm: "Archive #{@current_collective.name}? Members will lose access immediately and the collective will return to the free plan. You'll be asked to reverify with your 2FA code on the next step." } %>
        </section>
      <% end %>

    <% end %>

  </div>
</article>
