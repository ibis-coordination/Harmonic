<%= render 'shared/pulse_breadcrumb', items: [
  [@current_collective.name, @current_collective.path],
  'Members'
] %>

<article class="pulse-resource-detail">
  <header class="pulse-resource-header">
    <div class="pulse-resource-header-top">
      <span class="pulse-resource-type-label">
        <%= octicon 'people', height: 14, class: 'pulse-resource-icon' %>
        Members
      </span>
    </div>
    <h1 class="pulse-resource-title">Members</h1>
  </header>

  <div class="pulse-resource-body">
    <% if @team.empty? %>
      <p class="pulse-empty-content"><em>No members yet.</em></p>
    <% else %>
      <div class="pulse-participants-list">
        <% @team.each do |u| %>
          <div class="pulse-participant" data-member-id="<%= u.id %>">
            <%= render "shared/avatar", user: u %>
            <a href="<%= u.path %>" class="pulse-participant-name"><%= u.display_name %></a>
            <% if u.ai_agent? %>
              <span class="pulse-badge pulse-badge-muted">ai_agent</span>
            <% end %>
            <%# Pills showing the roles this member currently holds, so admins can
                see who has which roles at a glance. Server-rendered in the
                canonical @manageable_roles order; the page reloads after a role
                change (the action redirects back here) so the pills stay current. %>
            <div class="pulse-member-roles" data-role-pills-for="<%= u.id %>">
              <% @manageable_roles.each do |role| %>
                <% if u.collective_member.has_role?(role) %>
                  <span class="pulse-badge pulse-badge-muted" data-role-pill="<%= role %>"><%= role %></span>
                <% end %>
              <% end %>
            </div>
            <% if @can_manage_members %>
              <% is_owner = u.id == @current_collective.created_by_id %>
              <div class="pulse-member-controls">
                <details class="pulse-member-menu" data-controller="kebab-menu">
                  <summary class="pulse-action-btn-secondary pulse-member-menu-toggle" title="Manage member">
                    <%= octicon 'kebab-horizontal', height: 14 %>
                  </summary>
                  <div class="top-menu pulse-member-menu-list">
                    <ul>
                      <% @manageable_roles.each do |role| %>
                        <%# Owner's admin is permanent (the action rejects revoking it), so don't offer a toggle that can only fail — it shows as a pill above instead. The model also forbids the representative role for collective-identity users. %>
                        <% next if role == 'admin' && is_owner %>
                        <% next if role == 'representative' && u.collective_identity? %>
                        <% active = u.collective_member.has_role?(role) %>
                        <% role_label = active ? "Remove role #{role}" : "Add role #{role}" %>
                        <%# Each item is a real action POST — capability-checked and
                            authorized server-side. On success the action redirects
                            back to this page, so the pills and menu refresh. %>
                        <li>
                          <%= button_to role_label,
                                "#{@current_collective.path}/members/actions/update_member_roles",
                                method: :post,
                                params: { user_handle: u.handle, role: role, grant: (active ? "false" : "true") },
                                class: "pulse-member-menu-item",
                                form: { class: "pulse-member-menu-form", data: { member_id: u.id, role: role } } %>
                        </li>
                      <% end %>
                      <% unless is_owner || u.id == @current_user&.id %>
                        <li class="pulse-member-menu-divider"><hr></li>
                        <li>
                          <%= button_to "Remove from collective",
                                "#{@current_collective.path}/members/actions/remove_member",
                                method: :post,
                                params: { user_handle: u.handle },
                                class: "pulse-member-menu-item pulse-member-menu-item-danger",
                                form: { class: "pulse-member-menu-form" },
                                data: { turbo_confirm: "Remove #{u.display_name} from this collective?" } %>
                        </li>
                      <% end %>
                    </ul>
                  </div>
                </details>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>

    <% if @current_user&.collective_member&.can_invite? %>
      <div class="pulse-invite-section">
        <a href="<%= @current_collective.path %>/invite" class="pulse-invite-btn">
          <%= octicon 'person-add', height: 16 %>
          Invite Members
        </a>
      </div>
    <% end %>
  </div>
</article>
