<div data-controller="agent-chat"
     data-agent-chat-url-value="<%= chat_message_path(@partner.handle) %>"
     data-agent-chat-agent-name-value="<%= @partner.name %>"
     data-agent-chat-session-id-value="<%= @chat_session.id %>"
     data-agent-chat-poll-url-value="<%= chat_poll_path(@partner.handle) %>"
     data-agent-chat-turn-running-value="<%= @turn_running %>"
     data-agent-chat-partner-is-agent-value="<%= @partner.internal_ai_agent? %>"
     data-agent-chat-current-user-id-value="<%= @current_user&.id %>"
     data-agent-chat-has-older-messages-value="<%= @has_older_messages %>"
     data-agent-chat-oldest-timestamp-value="<%= @oldest_message_timestamp %>"
     style="display: flex; flex-direction: column; height: calc(100vh - 60px);">

  <% if @chat_blocked %>
    <div class="pulse-flash pulse-flash-warning" style="margin: 8px 16px 0; padding: 8px 12px; font-size: 13px;">
      <%= octicon 'no-entry', height: 14 %>
      <% if @blocked_by_self && @blocked_by_partner %>
        You and <%= @partner.display_name %> have blocked each other. Chat is disabled.
      <% elsif @blocked_by_self %>
        You have blocked <%= @partner.display_name %>. Chat is disabled. <a href="/user-blocks" class="pulse-link">Manage blocks</a>
      <% else %>
        <%= @partner.display_name %> has blocked you. Chat is disabled.
      <% end %>
    </div>
  <% end %>

  <% if @agent_busy_run %>
    <div class="pulse-flash pulse-flash-warning" style="margin: 8px 16px 0; padding: 8px 12px; font-size: 13px;">
      <%= octicon 'clock', height: 14 %>
      This agent is currently working on another task.
      <a href="<%= ai_agent_run_path(@partner.handle, @agent_busy_run.id) %>" class="pulse-link">View task</a>
    </div>
  <% end %>

  <%# Message list %>
  <div data-agent-chat-target="messages" id="chat-messages" style="flex: 1; overflow-y: auto; padding: 16px;">
    <% if @has_older_messages %>
      <div data-agent-chat-target="loadOlderButton" style="text-align: center; margin-bottom: 12px;">
        <button type="button"
                data-action="agent-chat#loadOlder"
                class="pulse-action-btn"
                style="font-size: 12px; padding: 4px 12px;">
          Load earlier messages
        </button>
      </div>
    <% end %>

    <% @messages.each do |message| %>
      <%= render 'chats/message', message: message %>
    <% end %>

    <% if @messages.empty? %>
      <p data-agent-chat-target="emptyState" style="text-align: center; margin-top: 40px; color: var(--color-fg-muted);">
        Send a message to start the conversation.
      </p>
    <% end %>
  </div>

  <%# Input bar %>
  <% unless @chat_blocked %>
    <div style="border-top: 1px solid var(--color-border-default); padding: 12px 16px;">
      <form data-action="submit->agent-chat#submit" style="display: flex; gap: 8px;">
        <textarea
          data-agent-chat-target="input"
          data-action="keydown->agent-chat#keydown"
          rows="1"
          class="pulse-form-textarea"
          placeholder="Type a message..."
          style="flex: 1; resize: none;"
        ></textarea>
        <button type="submit" data-agent-chat-target="submitButton" class="pulse-action-btn" style="align-self: flex-end;">
          <%= octicon 'paper-airplane', height: 14 %> Send
        </button>
      </form>
    </div>
  <% end %>
</div>
