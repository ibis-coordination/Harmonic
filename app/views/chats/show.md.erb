# Chat with <%= @ai_agent.display_name %>

<% if @messages.empty? %>
_No messages yet. Send a message to start the conversation._
<% else %>
## Messages

<% @messages.each do |message| %>
<% is_human = message.sender_id != @ai_agent.id %>
**<%= is_human ? message.sender&.display_name || "User" : @ai_agent.display_name %>** (<%= message.created_at.strftime("%Y-%m-%d %H:%M") %>):
<%= message.content %>

<% end %>
<% if @has_older_messages %>
_Showing most recent <%= @messages.length %> messages. Older messages are available in the conversation history._
<% end %>
<% end %>
