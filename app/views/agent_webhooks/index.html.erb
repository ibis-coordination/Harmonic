<%= render 'shared/pulse_breadcrumb', items: [
  ['AI Agents', '/ai-agents'],
  [@ai_agent.display_name, "/ai-agents/#{@agent_handle}"],
  'Webhooks'
] %>

<article class="pulse-resource-detail">
  <header class="pulse-resource-header">
    <div class="pulse-resource-header-top">
      <span class="pulse-resource-type-label">
        <%= octicon 'broadcast', height: 14, class: 'pulse-resource-icon' %>
        Webhooks
      </span>
    </div>
    <h1 class="pulse-resource-title">Webhooks for <%= @ai_agent.display_name %></h1>
  </header>

  <div class="pulse-resource-body">
    <p>Pings a URL on your server when this agent is @-mentioned or someone comments on its content.</p>

    <p class="pulse-action-row">
      <a href="/ai-agents/<%= @agent_handle %>/webhooks/new" class="pulse-action-btn pulse-action-btn-primary">
        <%= octicon "plus" %> New Webhook
      </a>
    </p>

    <% if @webhook_rules.empty? %>
      <p class="pulse-empty-content"><em>No webhooks configured yet.</em></p>
    <% else %>
      <table class="pulse-table">
        <thead>
          <tr>
            <th>Name</th>
            <th>Trigger</th>
            <th>URL</th>
            <th>Status</th>
            <th>Deliveries</th>
            <th>Last delivery</th>
          </tr>
        </thead>
        <tbody>
          <% @webhook_rules.each do |rule| %>
            <tr>
              <td>
                <a href="/ai-agents/<%= @agent_handle %>/webhooks/<%= rule.truncated_id %>/edit" class="pulse-link">
                  <%= rule.name %>
                </a>
              </td>
              <td>
                <small class="pulse-hint"><%= rule.event_type %> (<%= rule.mention_filter %>)</small>
              </td>
              <td><small class="pulse-hint"><%= truncate(rule.actions&.dig("webhook_url").to_s, length: 40) %></small></td>
              <td>
                <% if rule.enabled? %>
                  <span class="pulse-tag pulse-tag-success">Enabled</span>
                <% else %>
                  <span class="pulse-tag">Disabled</span>
                <% end %>
              </td>
              <td><%= rule.execution_count %></td>
              <td>
                <% if rule.last_executed_at %>
                  <%= time_ago_in_words(rule.last_executed_at) %> ago
                <% else %>
                  <em>Never</em>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% end %>
  </div>
</article>
