<%= render 'shared/pulse_breadcrumb', items: [
  ['AI Agents', '/ai-agents'],
  [@ai_agent.display_name, "/ai-agents/#{@agent_handle}"],
  ['Webhooks', "/ai-agents/#{@agent_handle}/webhooks"],
  @webhook_rule.name
] %>

<article class="pulse-resource-detail">
  <header class="pulse-resource-header">
    <h1 class="pulse-resource-title">Signing secret</h1>
  </header>

  <div class="pulse-resource-body">
    <% if flash.now[:notice].present? %>
      <div class="pulse-notice"><%= flash.now[:notice] %></div>
    <% end %>

    <div class="pulse-notice pulse-notice-warning">
      <strong>Save this secret now. You won't be able to see it again.</strong>
    </div>

    <section class="pulse-settings-section">
      <label class="pulse-label">Signing secret</label>
      <input type="text" class="pulse-form-input" readonly value="<%= @reveal_secret %>"
             onclick="this.select()">
      <p class="pulse-hint">Use this secret to verify the <code>X-Harmonic-Signature</code> header on incoming requests. Signature scheme: HMAC-SHA256 over <code>"&lt;timestamp&gt;.&lt;body&gt;"</code>.</p>
    </section>

    <p class="pulse-action-row">
      <a href="/ai-agents/<%= @agent_handle %>/webhooks/<%= @webhook_rule.truncated_id %>/edit" class="pulse-action-btn pulse-action-btn-primary">
        Done — go to webhook
      </a>
      <a href="/ai-agents/<%= @agent_handle %>/webhooks" class="pulse-action-btn">All webhooks</a>
    </p>
  </div>
</article>
