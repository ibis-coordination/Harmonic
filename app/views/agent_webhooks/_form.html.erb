<%# Local: form_url, form_method, submit_label, webhook_rule (nil for new) %>
<%= form_with(url: form_url, method: form_method, class: "pulse-form", data: { turbo: false }) do %>
  <section class="pulse-settings-section">
    <label for="webhook_name" class="pulse-label">Name (optional)</label>
    <input type="text" name="name" id="webhook_name" class="pulse-form-input"
           placeholder="<%= @form[:webhook_url].presence || 'my-server.example.com' %>"
           value="<%= @form[:name] %>">
    <p class="pulse-hint">Defaults to the URL's hostname.</p>
  </section>

  <section class="pulse-settings-section">
    <label class="pulse-label">Trigger</label>
    <div class="pulse-radio-group">
      <% AgentWebhooksController::TRIGGERS.each_key do |key| %>
        <label class="pulse-radio-label">
          <input type="radio" name="trigger" value="<%= key %>" <%= "checked" if @form[:trigger] == key %>>
          <%= AgentWebhooksController::TRIGGER_LABELS[key] %>
        </label>
      <% end %>
    </div>
    <p class="pulse-hint">Each rule has exactly one trigger. To listen on multiple triggers, create multiple webhooks.</p>
  </section>

  <section class="pulse-settings-section">
    <label for="webhook_url" class="pulse-label">Webhook URL</label>
    <input type="url" name="webhook_url" id="webhook_url" class="pulse-form-input" placeholder="https://your-server.example.com/harmonic-webhook"
           value="<%= @form[:webhook_url] %>" required>
    <p class="pulse-hint">Must be HTTPS. Harmonic will POST a signed JSON payload to this URL.</p>
  </section>

  <section class="pulse-settings-section pulse-action-row">
    <button type="submit" class="pulse-action-btn pulse-action-btn-primary"><%= submit_label %></button>
    <a href="/ai-agents/<%= @agent_handle %>/webhooks" class="pulse-action-btn">Cancel</a>
  </section>
<% end %>
