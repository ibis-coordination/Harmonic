<%= render 'shared/pulse_breadcrumb', items: [
  ['AI Agents', '/ai-agents'],
  [@ai_agent.display_name, "/ai-agents/#{@agent_handle}"],
  ['Webhooks', "/ai-agents/#{@agent_handle}/webhooks"],
  @webhook_rule.name
] %>

<article class="pulse-resource-detail">
  <header class="pulse-resource-header">
    <h1 class="pulse-resource-title">Edit webhook</h1>
  </header>

  <div class="pulse-resource-body">
    <% if flash[:alert].present? %>
      <div class="pulse-notice pulse-notice-warning"><%= flash[:alert] %></div>
    <% end %>
    <% if flash[:notice].present? %>
      <div class="pulse-notice"><%= flash[:notice] %></div>
    <% end %>

    <%= render "form",
               form_url: "/ai-agents/#{@agent_handle}/webhooks/#{@webhook_rule.truncated_id}",
               form_method: :patch,
               submit_label: "Save changes" %>

    <hr>

    <section class="pulse-settings-section">
      <h2 class="pulse-section-title">Test delivery</h2>
      <p class="pulse-hint">Sends a fixed test payload to the URL right now. Blocks until the server responds (up to <%= AgentWebhooksController::TEST_TIMEOUT_SECONDS %>s).</p>
      <%= form_with(url: "/ai-agents/#{@agent_handle}/webhooks/#{@webhook_rule.truncated_id}/test",
                    method: :post, class: "pulse-form-inline", data: { turbo: false }) do %>
        <button type="submit" class="pulse-action-btn">Send test payload</button>
      <% end %>

      <% if @test_result %>
        <div class="pulse-card" style="margin-top:12px;">
          <% if @test_result[:error] %>
            <p><strong>Error:</strong> <%= @test_result[:error] %></p>
          <% else %>
            <p><strong>Response status:</strong> <%= @test_result[:status] %></p>
            <% if @test_result[:body].present? %>
              <p><strong>Response body:</strong></p>
              <pre style="white-space:pre-wrap;background:var(--bg-tertiary);padding:8px;border-radius:4px;font-size:12px;"><%= @test_result[:body] %></pre>
            <% end %>
          <% end %>
          <details>
            <summary>What Harmonic sent</summary>
            <pre style="white-space:pre-wrap;background:var(--bg-tertiary);padding:8px;border-radius:4px;font-size:12px;"><%= @test_result[:request_body] %></pre>
          </details>
        </div>
      <% end %>
    </section>

    <hr>

    <section class="pulse-settings-section">
      <h2 class="pulse-section-title">Signing secret</h2>
      <p class="pulse-hint">Rotating reveals a new secret once. The current secret stays in use until you rotate.</p>
      <%= form_with(url: "/ai-agents/#{@agent_handle}/webhooks/#{@webhook_rule.truncated_id}/rotate_secret",
                    method: :post, class: "pulse-form-inline", data: { turbo: false }) do %>
        <button type="submit" class="pulse-action-btn">Rotate signing secret</button>
      <% end %>
    </section>

    <hr>

    <section class="pulse-settings-section">
      <h2 class="pulse-section-title">Recent deliveries</h2>
      <% if @recent_deliveries.present? && @recent_deliveries.any? %>
        <table class="pulse-table">
          <thead>
            <tr>
              <th>When</th>
              <th>Status</th>
              <th>Code</th>
              <th>Attempts</th>
            </tr>
          </thead>
          <tbody>
            <% @recent_deliveries.each do |d| %>
              <tr>
                <td><%= time_ago_in_words(d.created_at) %> ago</td>
                <td><%= d.status %></td>
                <td><%= d.response_code %></td>
                <td><%= d.attempt_count %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <p class="pulse-hint"><em>No deliveries yet.</em></p>
      <% end %>
    </section>

    <hr>

    <section class="pulse-settings-section pulse-action-row">
      <%= form_with(url: "/ai-agents/#{@agent_handle}/webhooks/#{@webhook_rule.truncated_id}/toggle",
                    method: :post, class: "pulse-form-inline", data: { turbo: false }) do %>
        <button type="submit" class="pulse-action-btn">
          <%= @webhook_rule.enabled? ? "Disable" : "Enable" %>
        </button>
      <% end %>
      <%= form_with(url: "/ai-agents/#{@agent_handle}/webhooks/#{@webhook_rule.truncated_id}",
                    method: :delete, class: "pulse-form-inline", data: { turbo: false, confirm: "Delete this webhook? This cannot be undone." }) do %>
        <button type="submit" class="pulse-action-btn pulse-action-btn-danger">Delete</button>
      <% end %>
    </section>
  </div>
</article>
