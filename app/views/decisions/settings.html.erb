<%= render 'shared/pulse_breadcrumb', items: [
  [@current_collective.name, @current_collective.path],
  ['Decision', @decision.path],
  'Settings'
] %>

<article class="pulse-resource-detail">
  <header class="pulse-resource-header">
    <div class="pulse-resource-header-top">
      <span class="pulse-resource-type-label">
        <i class="decision-icon icon-sm"></i>
        Decision Settings
      </span>
    </div>
    <h1 class="pulse-resource-title">Edit Decision</h1>
  </header>

  <div class="pulse-resource-body">
    <%= form_with url: "#{@decision.path}/settings", class: "pulse-form" do |form| %>
      <section class="pulse-settings-section">
        <label for="question" class="pulse-label">Question</label>
        <%= form.text_field :question, placeholder: 'Question that this decision will answer', value: @decision.question, class: "pulse-form-input" %>
      </section>

      <section class="pulse-settings-section">
        <label for="description" class="pulse-label">Description</label>
        <div class="mention-autocomplete-container" data-controller="mention-autocomplete" data-mention-autocomplete-collective-path-value="<%= @current_collective.path %>">
          <%= form.text_area :description, placeholder: @current_collective.private_workspace? ? 'Description (optional)' : 'Description (optional, use @ to mention users)', value: @decision.description, class: "pulse-form-input", data: { mention_autocomplete_target: "input" } %>
          <div data-mention-autocomplete-target="dropdown" class="mention-dropdown"></div>
        </div>
      </section>

      <% unless @decision.closed? %>
        <section class="pulse-settings-section">
          <h2 class="pulse-section-title">Options</h2>
          <p class="pulse-form-row">
            <%= form.select :options_open, options_for_select([['Everyone', true], ['Just you', false]], selected: @decision.options_open), {}, class: "pulse-form-input" %>
            can add options.
          </p>
        </section>
      <% end %>

      <% unless @decision.closed? %>
        <section class="pulse-settings-section">
          <h2 class="pulse-section-title">Deadline</h2>
          <%= render 'shared/deadline_input_fields', form: form, resource: @decision, close_now_option: true %>
        </section>
      <% end %>

      <section class="pulse-settings-section pulse-action-row">
        <%= form.submit 'Save', class: "pulse-action-btn pulse-action-btn-primary" %>
        <a href="<%= @decision.path %>" class="pulse-action-btn">Cancel</a>
      </section>
    <% end %>

    <% if @current_user.id == @decision.created_by_id || @current_user.collective_member&.is_admin? || @current_user.app_admin? %>
      <section class="pulse-settings-section">
        <details>
          <summary class="pulse-section-title" style="cursor: pointer; color: var(--color-danger-fg);">
            <%= octicon 'trash', height: 14 %> Delete this decision
          </summary>
          <div style="margin-top: 12px;">
            <p class="pulse-body-text-muted" style="margin-bottom: 12px;">
              This will delete your decision. Votes and comments from others will be preserved.
            </p>
            <%= button_to "#{@decision.path}/settings/actions/delete_decision", method: :post,
                data: { turbo_confirm: "Delete this decision?" },
                class: "pulse-action-btn pulse-action-btn-danger" do %>
              <%= octicon 'trash', height: 14 %> Delete Decision
            <% end %>
          </div>
        </details>
      </section>
    <% end %>
  </div>
</article>
