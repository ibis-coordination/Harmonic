<%= render 'shared/pulse_breadcrumb', items: [
  [@current_collective.name, @current_collective.path],
  [@decision.is_lottery? ? 'Lottery' : 'Decision', @decision.path],
  'Verify'
] %>

<article class="pulse-resource-detail">
  <h1 style="font-size: 1.5em; margin-bottom: 8px;">Verify Results</h1>
  <p class="pulse-body-text-muted" style="margin-bottom: 20px;">
    <%= link_to @decision.question, @decision.path %>
  </p>

  <div class="pulse-resource-body" style="padding: 16px;">

    <p style="line-height: 1.6; margin-bottom: 16px;">
      Every action on this <%= @decision.is_lottery? ? 'lottery' : 'decision' %> is recorded in a tamper-evident audit chain.
      <% if @decision.beacon_drawn? %>
        <%= @decision.is_lottery? ? 'The draw order' : 'Tiebreakers' %> are determined by a public randomness beacon that was not known when the <%= @decision.is_lottery? ? 'lottery' : 'decision' %> closed.
      <% end %>
      Anyone can independently verify that the recorded data has not been altered
      <% if @decision.beacon_drawn? %>
        and that the results are correct.
      <% else %>
        &mdash; randomness data will appear here after the <%= @decision.is_lottery? ? 'lottery' : 'decision' %> closes.
      <% end %>
    </p>

    <% if @audit_entries.any? %>
      <%# === Audit Chain === %>
      <h2 style="font-size: 1.15em; margin: 0 0 12px 0;">Audit Chain</h2>

      <p style="line-height: 1.6; margin-bottom: 8px; font-size: 14px;">
        <strong><%= @audit_entries.size %> entries</strong>
        <% if @decision.audit_chain_hash.present? %>
          &middot; Chain hash: <code style="font-size: 0.85em;"><%= @decision.audit_chain_hash[0..7] %>...</code>
        <% end %>
      </p>

      <table style="width: 100%; border-collapse: collapse; font-size: 13px; margin-bottom: 12px;">
        <thead>
          <tr>
            <th style="padding: 6px 8px; text-align: left; border-bottom: 1px solid var(--color-border-default); color: var(--color-fg-muted);">#</th>
            <th style="padding: 6px 8px; text-align: left; border-bottom: 1px solid var(--color-border-default); color: var(--color-fg-muted);">Action</th>
            <th style="padding: 6px 8px; text-align: left; border-bottom: 1px solid var(--color-border-default); color: var(--color-fg-muted);">By</th>
            <th style="padding: 6px 8px; text-align: left; border-bottom: 1px solid var(--color-border-default); color: var(--color-fg-muted);">Detail</th>
            <th style="padding: 6px 8px; text-align: left; border-bottom: 1px solid var(--color-border-default); color: var(--color-fg-muted);">Entry Hash</th>
          </tr>
        </thead>
        <tbody>
          <% @audit_entries.each do |entry| %>
            <% action_label = {
              "option_added" => @decision.is_lottery? ? "Entry added" : "Option added",
              "option_removed" => @decision.is_lottery? ? "Entry removed" : "Option removed",
              "vote_cast" => "Vote cast",
              "vote_updated" => "Vote updated",
              "executive_selection" => "Selection made",
              "decision_closed" => @decision.is_lottery? ? "Lottery closed" : "Decision closed",
              "beacon_drawn" => "Beacon drawn",
            }[entry.action] || entry.action %>
            <tr>
              <td style="padding: 6px 8px; border-bottom: 1px solid var(--color-border-default);"><%= entry.sequence_number %></td>
              <td style="padding: 6px 8px; border-bottom: 1px solid var(--color-border-default);"><%= action_label %></td>
              <td style="padding: 6px 8px; border-bottom: 1px solid var(--color-border-default);"><%= entry.actor_handle ? "@#{entry.actor_handle}" : "" %></td>
              <td style="padding: 6px 8px; border-bottom: 1px solid var(--color-border-default);">
                <% if entry.option_title.present? %>
                  <%= entry.option_title %>
                  <% if entry.accepted.present? %>
                    <span style="color: var(--color-fg-muted);">&middot; accepted: <%= entry.accepted == 1 ? 'yes' : 'no' %>, preferred: <%= entry.preferred == 1 ? 'yes' : 'no' %></span>
                  <% end %>
                <% elsif entry.action == "beacon_drawn" && entry.metadata.present? %>
                  round <%= entry.metadata["round"] %>
                <% elsif entry.action == "executive_selection" && entry.metadata.present? %>
                  <%= entry.metadata["selected_option_titles"]&.join(", ") %>
                <% end %>
              </td>
              <td style="padding: 6px 8px; border-bottom: 1px solid var(--color-border-default);">
                <code style="font-size: 0.85em;" title="<%= entry.entry_hash %>"><%= entry.entry_hash[0..7] %>...</code>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>

      <p style="font-size: 13px; color: var(--color-fg-muted); line-height: 1.5; margin-bottom: 16px;">
        Each entry's hash includes the previous entry's hash, forming a chain. If any record were altered, inserted, or removed, all subsequent hashes would break.
        <% unless @decision.is_lottery? %>
          Individual votes are also visible on the <%= link_to "voters page", "#{@decision.path}/voters" %>.
        <% end %>
      </p>
    <% end %>

    <% if @decision.beacon_drawn? %>
      <%# === Results === %>
      <h2 style="font-size: 1.15em; margin: 0 0 12px 0;">Results</h2>

      <table style="width: 100%; border-collapse: collapse; font-size: 14px; margin-bottom: 12px;">
        <thead>
          <tr>
            <th style="padding: 8px 12px; text-align: left; border-bottom: 1px solid var(--color-border-default); color: var(--color-fg-muted); width: 40px;">#</th>
            <th style="padding: 8px 12px; text-align: left; border-bottom: 1px solid var(--color-border-default); color: var(--color-fg-muted);"><%= @decision.is_lottery? ? 'Entry' : 'Option' %></th>
            <% unless @decision.is_lottery? %>
              <th style="padding: 8px 12px; text-align: left; border-bottom: 1px solid var(--color-border-default); color: var(--color-fg-muted);">✅</th>
              <th style="padding: 8px 12px; text-align: left; border-bottom: 1px solid var(--color-border-default); color: var(--color-fg-muted);">⭐</th>
            <% end %>
            <th style="padding: 8px 12px; text-align: left; border-bottom: 1px solid var(--color-border-default); color: var(--color-fg-muted);">Sort Key</th>
          </tr>
        </thead>
        <tbody>
          <% ([nil] + @decision.results + [nil]).each_cons(3).with_index do |(prev_result, result, next_result), index| %>
            <% is_tiebreaker = @decision.is_lottery? || result.is_sorting_factor?(prev_result, 'lottery_sort_key') || result.is_sorting_factor?(next_result, 'lottery_sort_key') %>
            <tr style="<%= index == 0 ? 'background: var(--color-attention-subtle); font-weight: 600;' : '' %><%= is_tiebreaker ? '' : ' opacity: 0.4;' %>">
              <td style="padding: 8px 12px; border-bottom: 1px solid var(--color-border-default); width: 40px;"><%= index + 1 %></td>
              <td style="padding: 8px 12px; border-bottom: 1px solid var(--color-border-default);"><%= markdown_inline(result.option_title) %></td>
              <% unless @decision.is_lottery? %>
                <td style="padding: 8px 12px; border-bottom: 1px solid var(--color-border-default);"><%= result.accepted_yes || 0 %></td>
                <td style="padding: 8px 12px; border-bottom: 1px solid var(--color-border-default);"><%= result.preferred || 0 %></td>
              <% end %>
              <td style="padding: 8px 12px; border-bottom: 1px solid var(--color-border-default);"><code style="font-size: 0.85em;"><%= result.lottery_sort_key %></code></td>
            </tr>
          <% end %>
        </tbody>
      </table>

      <p style="font-size: 13px; color: var(--color-fg-muted); line-height: 1.5; margin-bottom: 16px;">
        <% unless @decision.is_lottery? %>
          Sorted by acceptance ✅, then preference ⭐, then sort key (random tiebreaker).
        <% end %>
        Sort keys are computed as <code>SHA256(beacon_randomness + option_title)</code>.
        Beacon randomness: <code style="word-break: break-all;"><%= @decision.lottery_beacon_randomness[0..15] %>...</code>
        (<%= link_to "verify on drand", @verification_url, target: "_blank", rel: "noopener" %><% if @verification_url %>)<% end %>
      </p>
    <% end %>

    <%# === How to Verify === %>
    <h2 style="font-size: 1.15em; margin: 0 0 12px 0;">How to Verify</h2>

    <p style="line-height: 1.6; margin-bottom: 12px;">
      Download the verification data as JSON, then run the Python script to independently check every hash, every vote total, and every sort key.
    </p>
    <ol style="line-height: 1.8; margin-bottom: 16px; padding-left: 20px;">
      <li>Download <%= link_to "verify.json", "#{request.path}.json" %> (save the page while logged in, or <code>curl&nbsp;-H&nbsp;"Authorization:&nbsp;Bearer&nbsp;TOKEN"&nbsp;<%= @decision.shareable_link %>/verify.json</code>)</li>
      <li>Save the script below as <code>verify.py</code></li>
      <li>Run <code>python3 verify.py verify.json</code></li>
    </ol>

    <details>
      <summary style="cursor: pointer; font-size: 14px; margin-bottom: 8px;"><code>verify.py</code></summary>
      <div data-controller="code-block" data-code-block-language-value="python">
        <pre style="background: var(--color-canvas-subtle); padding: 12px; border-radius: 6px; overflow-x: auto; margin: 8px 0;"><code><%= File.read(Rails.root.join("scripts", "verify-audit-chain.py")) %></code></pre>
      </div>
    </details>

    <%# === Technical Details === %>
    <details style="margin-top: 16px;">
      <summary style="cursor: pointer; font-size: 14px; margin-bottom: 8px;">Technical details</summary>
      <div style="padding: 8px 0; font-size: 14px; line-height: 1.6;">

        <% if @audit_entries.any? %>
          <h4 style="font-size: 0.95em; margin: 0 0 8px 0;">Audit chain hash formula</h4>
          <p style="margin-bottom: 8px;">
            Each entry's hash is computed by concatenating its fields with <code>|</code> delimiters:
          </p>
          <pre style="background: var(--color-canvas-subtle); padding: 12px; border-radius: 6px; overflow-x: auto; margin-bottom: 8px;"><code>"v1" | previous_hash | sequence_number | action | actor_id | actor_handle | NFC(option_title) | accepted | preferred | metadata | created_at</code></pre>
          <p style="margin-bottom: 16px;">
            All values are strings in the JSON, ready to concatenate directly. <code>option_title</code> must be <a href="https://unicode.org/reports/tr15/" target="_blank" rel="noopener">NFC-normalized</a> before hashing (this matters for accented characters or emoji).
          </p>
        <% end %>

        <% if @decision.beacon_drawn? %>
          <h4 style="font-size: 0.95em; margin: 0 0 8px 0;">Beacon data</h4>
          <table class="pulse-results-table" style="margin-bottom: 16px;">
            <tbody>
              <tr>
                <td><strong>Beacon Round</strong></td>
                <td><code><%= @decision.lottery_beacon_round %></code></td>
              </tr>
              <tr>
                <td><strong>Randomness</strong></td>
                <td><code style="word-break: break-all;"><%= @decision.lottery_beacon_randomness %></code></td>
              </tr>
              <% if @verification_url %>
                <tr>
                  <td><strong>Verify on drand</strong></td>
                  <td><%= link_to "Look up round #{@decision.lottery_beacon_round}", @verification_url, target: "_blank", rel: "noopener" %></td>
                </tr>
              <% end %>
              <tr>
                <td><strong>Decision Deadline</strong></td>
                <td><code><%= @decision.deadline.iso8601 %></code> (unix: <code><%= @decision.deadline.to_i %></code>)</td>
              </tr>
            </tbody>
          </table>

          <details style="margin-bottom: 16px;">
            <summary style="cursor: pointer; color: var(--color-fg-muted);">How the beacon round is derived from the deadline</summary>
            <div style="padding: 8px 0;">
              <p style="margin-bottom: 12px;">
                <%= @round_derivation[:description] %>
              </p>
              <% if @round_derivation[:formula] %>
                <pre style="background: var(--color-canvas-subtle); padding: 12px; border-radius: 6px; overflow-x: auto; margin-bottom: 12px;"><code><%= @round_derivation[:formula] %>

<%= @round_derivation[:steps].join("\n") %></code></pre>
              <% end %>
              <% if @round_derivation[:chain_info_url] %>
                <p>
                  <%= @round_derivation[:chain_info_note] %>
                  <%= link_to "View chain info", @round_derivation[:chain_info_url], target: "_blank", rel: "noopener" %>
                </p>
              <% end %>
            </div>
          </details>
        <% end %>

        <p style="color: var(--color-fg-muted);">
          <strong>What this does not prove:</strong> The audit chain verifies the integrity of data that was recorded, but cannot prove that the server accepted every submission. If a <%= @decision.is_lottery? ? 'entry' : 'vote' %> was never recorded (e.g., due to a server error), it would not appear in the chain.
        </p>
      </div>
    </details>

  </div>
</article>
