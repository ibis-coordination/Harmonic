<%= render 'shared/pulse_breadcrumb', items: [
  [@current_tenant.subdomain, @current_tenant.path],
  ['Settings', @settings_user.path + '/settings'],
  'Download My Data'
] %>

<% data_export_path = "/u/#{@settings_user.tenant_users.find_by(tenant_id: @current_tenant.id).handle}/settings/data-export" %>

<article class="pulse-resource-detail">
  <header class="pulse-resource-header">
    <div class="pulse-resource-header-top">
      <span class="pulse-resource-type-label">
        <%= octicon 'download', height: 14, class: 'pulse-resource-icon' %>
        Personal Data Export
      </span>
    </div>
    <h1 class="pulse-resource-title">Download My Data</h1>
  </header>

  <% if flash[:notice] %>
    <div class="pulse-notice pulse-notice-success" style="margin-bottom: 20px;"><%= flash[:notice] %></div>
  <% end %>
  <% if flash[:alert] %>
    <div class="pulse-notice pulse-notice-danger" style="margin-bottom: 20px;"><%= flash[:alert] %></div>
  <% end %>

  <div class="pulse-section">
    <p>
      Download a ZIP of the data you've shared publicly and the actions you've taken in public spaces:
      notes, comments, decisions you created, options you proposed, commitments, votes, participations,
      read confirmations, audit-chain receipts, trustee authorizations, and your account details. Data from
      any AI agents you've created is included.
    </p>
    <p class="pulse-form-hint">
      Content created by other users is not included.
      Data shared in private collectives is not included.
    </p>

    <%= form_tag(data_export_path, method: :post) do %>
      <button type="submit" class="pulse-btn pulse-btn-primary">
        <%= octicon 'download', height: 14 %> Start Export
      </button>
    <% end %>
  </div>

  <% if @exports.any? %>
    <div class="pulse-section" style="margin-top: 24px;">
      <h2 class="pulse-section-title">Previous Exports</h2>
      <table class="pulse-table">
        <thead>
          <tr>
            <th>Status</th>
            <th>Created</th>
            <th>Records</th>
            <th>Download</th>
          </tr>
        </thead>
        <tbody>
          <% @exports.each do |export| %>
            <tr>
              <td>
                <% case export.status %>
                <% when "pending", "processing" %>
                  <span class="pulse-badge pulse-badge-info"><%= export.status.capitalize %></span>
                <% when "completed" %>
                  <span class="pulse-badge pulse-badge-success">Completed</span>
                <% when "failed" %>
                  <span class="pulse-badge pulse-badge-danger">Failed</span>
                <% end %>
              </td>
              <td><%= export.created_at.strftime("%Y-%m-%d %H:%M") %></td>
              <td>
                <% if export.record_counts.present? %>
                  <%= export.record_counts.map { |k, v| "#{v} #{k}" }.join(", ") %>
                <% else %>
                  &mdash;
                <% end %>
              </td>
              <td>
                <% if export.downloadable? %>
                  <a href="<%= data_export_path %>/<%= export.id %>" class="pulse-btn pulse-btn-small" data-turbo="false">
                    <%= octicon 'download', height: 12 %> Download
                  </a>
                <% elsif export.expired? %>
                  <span class="pulse-text-muted">Expired</span>
                <% else %>
                  &mdash;
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</article>
