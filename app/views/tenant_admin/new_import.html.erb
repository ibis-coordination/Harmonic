<%= render 'shared/pulse_breadcrumb', items: [
  ['Tenant Admin', '/tenant-admin'],
  ['Imports', '/tenant-admin/imports'],
  'New Import'
] %>

<article class="pulse-resource-detail">
  <header class="pulse-resource-header">
    <div class="pulse-resource-header-top">
      <span class="pulse-resource-type-label">
        <%= octicon 'upload', height: 14, class: 'pulse-resource-icon' %>
        Import Data
      </span>
    </div>
    <h1 class="pulse-resource-title">Import Collective Data</h1>
  </header>

  <% if flash[:alert] %>
    <div class="pulse-notice pulse-notice-danger" style="margin-bottom: 20px;">
      <%= flash[:alert] %>
    </div>
  <% end %>

  <div class="pulse-section">
    <p>Import a collective export ZIP file. This will create a new collective with all the exported data, including notes, decisions, commitments, and attachments.</p>
    <p>Users will be matched by email address. Unmatched users will appear as placeholder accounts.</p>

    <%= form_tag("/tenant-admin/imports", method: :post, multipart: true) do %>
      <div style="margin-bottom: 16px;">
        <label for="file" class="pulse-label">Export ZIP file</label>
        <input type="file" name="file" id="file" accept=".zip" class="pulse-input" required>
      </div>
      <button type="submit" class="pulse-btn pulse-btn-primary">
        <%= octicon 'upload', height: 14 %> Start Import
      </button>
    <% end %>
  </div>
</article>
