<%= render 'shared/pulse_breadcrumb', items: [
  [@current_tenant.subdomain, '/'],
  ['Tenant Admin', '/tenant-admin'],
  'Settings'
] %>

<h1 class="pulse-page-title">
  <%= octicon 'gear', height: 24 %> Tenant Settings
</h1>

<%= form_with(url: "/tenant-admin/settings", class: "pulse-form", style: "max-width:600px;") do |form| %>
  <%= render 'shared/pulse_accordion', title: 'General', icon: 'info', open: true do %>
    <div class="pulse-form-section" style="border-top:none;margin-top:0;padding-top:0;">
      <label class="pulse-form-label" for="name">Tenant Name</label>
      <%= form.text_field :name, placeholder: 'Tenant Name', value: @current_tenant.name, class: 'pulse-form-input' %>
    </div>

    <div class="pulse-form-section">
      <label class="pulse-form-label" for="timezone">Default Time Zone</label>
      <%= form.time_zone_select :timezone, ActiveSupport::TimeZone.all, { default: @current_tenant.timezone.name }, { class: 'pulse-form-select' } %>
    </div>
  <% end %>

  <%= render 'shared/pulse_accordion', title: 'Access Control', icon: 'lock', open: true do %>
    <div class="pulse-form-section" style="border-top:none;margin-top:0;padding-top:0;">
      <label class="pulse-checkbox-label">
        <%= form.check_box :require_login, { checked: @current_tenant.require_login?, class: 'pulse-checkbox-input' } %>
        <span>Require login for all users</span>
      </label>
      <p class="pulse-form-hint">When enabled, users must be logged in to view any content on this tenant.</p>
    </div>
  <% end %>

  <%= render 'shared/pulse_accordion', title: 'Attachments', icon: 'paperclip', open: true do %>
    <p class="pulse-form-hint" style="margin-bottom:16px;">
      Which categories of file attachments may be uploaded by users in this tenant. Existing attachments are not affected when these settings change.
    </p>

    <%# Hidden empty value ensures the param key is present even when no boxes are checked. %>
    <%= hidden_field_tag "allowed_attachment_categories[]", "" %>

    <% [["images", "Images (PNG, JPEG, GIF, WebP, BMP, SVG, etc.)"],
        ["pdfs",   "PDFs"],
        ["text",   "Text files (plain text, Markdown, CSV, HTML, etc.)"]].each do |category, label| %>
      <div class="pulse-form-section" style="border-top:none;margin-top:0;padding-top:0;">
        <label class="pulse-checkbox-label">
          <%= check_box_tag "allowed_attachment_categories[]", category,
                @current_tenant.allowed_attachment_categories.include?(category),
                id: "allowed_attachment_category_#{category}", class: 'pulse-checkbox-input' %>
          <span><%= label %></span>
        </label>
      </div>
    <% end %>
  <% end %>

  <% available_flags = FeatureFlagService.all_flags.select { |f| FeatureFlagService.app_enabled?(f) } %>
  <% if available_flags.any? %>
    <%= render 'shared/pulse_accordion', title: 'Feature Flags', icon: 'beaker', count: available_flags.count, open: true do %>
      <p class="pulse-form-hint" style="margin-bottom:16px;">
        Features must be enabled here for collectives to use them. When disabled, the feature is unavailable for all collectives in this tenant.
      </p>

      <% available_flags.each do |flag_name| %>
        <% metadata = FeatureFlagService.flag_metadata(flag_name) %>
        <% tenant_enabled_locally = @current_tenant.feature_flag_enabled_locally?(flag_name) %>

        <div class="pulse-feature-flag-item">
          <label class="pulse-checkbox-label">
            <%= form.check_box "feature_#{flag_name}", { checked: tenant_enabled_locally, id: "feature_#{flag_name}", class: 'pulse-checkbox-input' } %>
            <div>
              <strong><%= metadata['name'] %></strong>
              <p class="pulse-form-hint" style="margin:4px 0 0 0;"><%= metadata['description'] %></p>
            </div>
          </label>
        </div>
      <% end %>
    <% end %>
  <% end %>

  <% if @current_tenant.feature_enabled?("stripe_billing") %>
    <% gateway_catalog = GatewayModelCatalog.prices %>
    <% if gateway_catalog.any? %>
      <% enabled_models = @current_tenant.enabled_gateway_models %>
      <%= render 'shared/pulse_accordion', title: 'AI Agent Models', icon: 'cpu', count: gateway_catalog.size, open: false do %>
        <p class="pulse-form-hint" style="margin-bottom:16px;">
          Which models users can choose for internal AI agents. Prices are per 1M tokens (input / output), billed to your credit balance as agents run. Unchecked models are hidden from users; if none are enabled, a default set is offered.
        </p>

        <%# Hidden empty value ensures the param key is present even when no boxes are checked. %>
        <%= hidden_field_tag "gateway_models[]", "" %>

        <% gateway_catalog.keys.group_by { |model| model.split("/").first }.sort.each do |vendor, models| %>
          <% any_enabled = models.any? { |model| enabled_models.include?(model) } %>
          <details class="pulse-form-section" style="border-top:none;margin-top:0;padding-top:0;" data-controller="checkbox-group" <%= "open" if any_enabled %>>
            <summary style="cursor:pointer;font-weight:600;">
              <%= gateway_vendor_label(vendor) %> <span class="pulse-form-hint">(<%= models.count { |model| enabled_models.include?(model) } %>/<%= models.size %>)</span>
            </summary>
            <label class="pulse-checkbox-label" style="margin-top:8px;">
              <%# Unnamed: a UI-only "select all", not submitted with the form. %>
              <input type="checkbox" data-checkbox-group-target="toggle" data-action="change->checkbox-group#toggleAll">
              <span class="pulse-form-hint">Select all <%= gateway_vendor_label(vendor) %></span>
            </label>
            <% models.sort.each do |model| %>
              <label class="pulse-checkbox-label" style="margin-top:8px;">
                <%= check_box_tag "gateway_models[]", model, enabled_models.include?(model),
                      id: "gateway_model_#{model.parameterize}", class: 'pulse-checkbox-input',
                      data: { "checkbox-group-target": "checkbox", action: "change->checkbox-group#syncToggle" } %>
                <span>
                  <%= model %>
                  <span class="pulse-form-hint">$<%= gateway_catalog[model][:input_per_million] %> / $<%= gateway_catalog[model][:output_per_million] %></span>
                </span>
              </label>
            <% end %>
          </details>
        <% end %>
      <% end %>
    <% end %>
  <% end %>

  <div class="pulse-form-actions">
    <%= form.submit 'Save Settings', class: 'pulse-action-btn' %>
    <a href="/tenant-admin" class="pulse-action-btn-secondary">Cancel</a>
  </div>
<% end %>
