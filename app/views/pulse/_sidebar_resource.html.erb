<%# Resource sidebar variant - for Note, Decision, Commitment detail pages %>
<%# Shows only collective info and back link, like the settings sidebar %>
<aside class="pulse-sidebar" data-mode="resource">
  <%= render 'pulse/sidebar_collective_info' %>

  <nav class="pulse-nav">
    <a href="<%= @current_collective.path %>" class="pulse-nav-item">
      <%= octicon 'arrow-left', height: 16 %>
      <span>Back to Collective</span>
    </a>
  </nav>
</aside>
