<div class="pulse-collective-info">
  <div class="pulse-breadcrumb">
    <a href="/"><%= @current_tenant.subdomain %></a>
    <span class="pulse-breadcrumb-sep">/</span>
    <span><%= @current_collective.private_workspace? ? "Workspace" : "Collective" %></span>
  </div>
  <div class="pulse-collective-info-row">
    <a href="<%= @current_collective.path %>">
      <%= inline_avatar(@current_collective, css_class: "pulse-collective-image", variant: :thumbnail) %>
    </a>
    <div class="pulse-collective-info-text">
      <a href="<%= @current_collective.path %>" class="pulse-sidebar-collective-name">
        <%= @current_collective.name %>
      </a>
      <% if @current_collective.private_workspace? -%>
      <div class="pulse-collective-meta">
        <span title="All content in this workspace is private. Only you can access this workspace." style="cursor: default;"><%= octicon 'lock', height: 12 %> Private</span>
      </div>
      <% else -%>
      <% count = @current_collective.member_count -%>
      <div class="pulse-collective-meta">
        <a href="<%= @current_collective.path %>/members" class="pulse-member-link"><%= count %> <%= 'member'.pluralize(count) %></a>
      </div>
      <% end -%>
    </div>
    <%# Explore/navigation links live in a kebab menu here on the collective
        home + dashboard (passed show_collective_menu: true). Uses the
        <details>-based kebab-menu controller (CSP-safe, outside-click close). %>
    <% if local_assigns[:show_collective_menu] %>
      <details class="pulse-sidebar-menu" data-controller="kebab-menu">
        <summary class="pulse-sidebar-menu-toggle" title="More">
          <%= octicon 'kebab-horizontal', height: 16 %>
        </summary>
        <div class="pulse-sidebar-menu-list">
          <ul>
            <li>
              <a href="<%= @current_collective.path %>/dashboard">
                <%= octicon 'meter', height: 14 %> Dashboard
              </a>
            </li>
            <li>
              <a href="<%= @current_collective.path %>/cycles">
                <%= octicon 'iterations', height: 14 %> Cycles
              </a>
            </li>
            <li>
              <a href="<%= @current_collective.path %>/backlinks">
                <%= octicon 'link', height: 14 %> Backlinks
              </a>
            </li>
            <% unless @current_collective.private_workspace? %>
            <li>
              <a href="<%= @current_collective.path %>/representation">
                <%= octicon 'people', height: 14 %> Representation
              </a>
            </li>
            <% end %>
            <% if !@current_collective.private_workspace? && @current_collective.pool_page_available? %>
            <li>
              <a href="<%= @current_collective.path %>/pool">
                <%= octicon 'credit-card', height: 14 %> Funding Pool
              </a>
            </li>
            <% end %>
            <% if !@current_collective.private_workspace? && @current_user&.collective_member&.can_edit_settings? %>
            <li>
              <a href="<%= @current_collective.path %>/settings">
                <%= octicon 'gear', height: 14 %> Settings
              </a>
            </li>
            <% end %>
          </ul>
        </div>
      </details>
    <% end %>
  </div>
</div>
