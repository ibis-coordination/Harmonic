<div class="pulse-collective-info">
  <div class="pulse-breadcrumb">
    <a href="/"><%= @current_tenant.subdomain %></a>
    <span class="pulse-breadcrumb-sep">/</span>
    <span>Collective</span>
  </div>
  <div class="pulse-collective-info-row">
    <a href="<%= @current_collective.path %>">
      <img src="<%= @current_collective.image_path %>" alt="<%= @current_collective.name %>" class="pulse-collective-image">
    </a>
    <div class="pulse-collective-info-text">
      <a href="<%= @current_collective.path %>" class="pulse-sidebar-collective-name">
        <%= @current_collective.name %>
      </a>
      <% if @team -%>
      <div class="pulse-collective-meta">
        <a href="<%= @current_collective.path %>/members" class="pulse-member-link"><%= @team.count %> <%= 'member'.pluralize(@team.count) %></a>
      </div>
      <% end -%>
    </div>
  </div>
</div>
