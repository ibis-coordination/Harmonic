<div class="pulse-collective-info">
  <div class="pulse-breadcrumb">
    <a href="/"><%= @current_tenant.subdomain %></a>
    <span class="pulse-breadcrumb-sep">/</span>
    <span><%= @current_collective.private_workspace? ? "Workspace" : "Collective" %></span>
  </div>
  <div class="pulse-collective-info-row">
    <a href="<%= @current_collective.path %>">
      <%= inline_avatar(@current_collective, css_class: "pulse-collective-image", variant: :thumbnail) %>
    </a>
    <div class="pulse-collective-info-text">
      <a href="<%= @current_collective.path %>" class="pulse-sidebar-collective-name">
        <%= @current_collective.name %>
      </a>
      <% if @current_collective.private_workspace? -%>
      <div class="pulse-collective-meta">
        <span title="All content in this workspace is private. Only you can access this workspace." style="cursor: default;"><%= octicon 'lock', height: 12 %> Private</span>
      </div>
      <% else -%>
      <% count = @current_collective.member_count -%>
      <div class="pulse-collective-meta">
        <a href="<%= @current_collective.path %>/members" class="pulse-member-link"><%= count %> <%= 'member'.pluralize(count) %></a>
      </div>
      <% end -%>
    </div>
  </div>
</div>
