<aside class="pulse-sidebar" data-mode="chat">
  <div class="pulse-sidebar-section">
    <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 12px;">
      <%= octicon 'comment-discussion', height: 16 %>
      <span style="font-weight: 600;"><%= @ai_agent.name %></span>
    </div>
    <%= button_to ai_agent_chat_create_path(@ai_agent.handle),
          method: :post,
          class: "pulse-action-btn pulse-action-btn-primary",
          style: "width: 100%;" do %>
      <%= octicon 'plus', height: 14 %> New Chat
    <% end %>
  </div>

  <div class="pulse-sidebar-section" style="flex: 1; overflow-y: auto;">
    <div style="font-size: 11px; font-weight: 600; text-transform: uppercase; color: var(--color-fg-muted); margin-bottom: 8px;">
      Chat Sessions
    </div>
    <% @chat_sessions.each do |session| %>
      <% first_message = @first_messages[session.id] %>
      <% is_active = @chat_session&.id == session.id %>
      <a href="<%= ai_agent_chat_path(@ai_agent.handle, session.id) %>"
         class="pulse-nav-item<%= ' active' if is_active %>"
         style="display: block; padding: 8px 10px; font-size: 13px; text-decoration: none; border-radius: 6px; margin-bottom: 2px;">
        <div style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
          <%= first_message ? first_message.detail&.dig("content").to_s.truncate(50) : "Empty session" %>
        </div>
        <div style="font-size: 11px; color: var(--color-fg-muted); margin-top: 2px;">
          <%= timeago(session.created_at) %>
        </div>
      </a>
    <% end %>
    <% if @chat_sessions.empty? %>
      <p style="font-size: 13px; color: var(--color-fg-muted); text-align: center; margin-top: 16px;">
        No chat sessions yet.
      </p>
    <% end %>
  </div>

  <div class="pulse-sidebar-section" style="border-top: 1px solid var(--color-border-default); border-bottom: none;">
    <a href="<%= ai_agent_path(@ai_agent.handle) %>" class="pulse-nav-item" style="font-size: 13px;">
      <%= octicon 'arrow-left', height: 14 %> Back to <%= @ai_agent.name %>
    </a>
  </div>
</aside>
