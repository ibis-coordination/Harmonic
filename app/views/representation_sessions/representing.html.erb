<% is_user_representation = @representation_session.user_representation? %>
<% represented_user = @representation_session.represented_user %>

<% if is_user_representation %>
  <%= render 'shared/pulse_breadcrumb', items: [
    ['Home', '/'],
    ['Trustee Grants', "/u/#{@current_human_user.handle}/settings/trustee-grants"],
    'Active Session'
  ] %>
<% else %>
  <%= render 'shared/pulse_breadcrumb', items: [
    [@collective.name, @collective.path],
    ['Representation', @collective.path + '/representation'],
    'Active Session'
  ] %>
<% end %>

<article class="pulse-resource-detail">
  <header class="pulse-resource-header">
    <div class="pulse-resource-header-top">
      <span class="pulse-resource-type-label">
        <%= octicon 'play', height: 14, class: 'pulse-resource-icon' %>
        Active Session
      </span>
      <% if is_user_representation %>
        <span class="pulse-tag">User Representation</span>
      <% else %>
        <span class="pulse-tag">Collective Representation</span>
      <% end %>
    </div>
    <% if is_user_representation %>
      <h1 class="pulse-resource-title">Acting on behalf of <%= represented_user&.display_name %></h1>
    <% else %>
      <h1 class="pulse-resource-title">Representing <%= @collective.name %></h1>
    <% end %>
  </header>

  <div class="pulse-resource-body">
    <div class="pulse-notice pulse-notice-info">
      <% if is_user_representation %>
        <p>
          You are acting on behalf of <strong><%= represented_user&.display_name %></strong>.
          Actions you take will be attributed to a trustee user representing <%= represented_user&.display_name %>.
          All actions are being recorded.
        </p>
        <p class="pulse-muted">
          The message box above will remain visible until you end the session.
        </p>
      <% else %>
        <p>
          You are now representing <%= @collective.name %>. Your actions during this session are being recorded and will be visible to all members of <%= @collective.name %>.
        </p>
        <p class="pulse-muted">
          The message box above will remain visible until you end the session.
        </p>
      <% end %>
    </div>

    <% if is_user_representation %>
      <section class="pulse-settings-section">
        <h2 class="pulse-section-title">Granted Capabilities</h2>
        <% grant = @representation_session.trustee_grant %>
        <% if grant&.permissions.present? %>
          <div style="display: flex; flex-wrap: wrap; gap: 8px;">
            <% grant.permissions.each do |capability, enabled| %>
              <% next unless enabled %>
              <span class="pulse-tag"><%= capability %></span>
            <% end %>
          </div>
        <% else %>
          <p class="pulse-muted">No specific capabilities granted.</p>
        <% end %>
      </section>

      <section class="pulse-settings-section">
        <h2 class="pulse-section-title">Available Collectives</h2>
        <% scoped_collectives = @other_collectives.select { |s| grant.allows_collective?(s) } %>
        <% if scoped_collectives.empty? %>
          <p class="pulse-muted">
            No collectives are currently available within the scope of this trustee grant.
          </p>
        <% else %>
          <p>
            You can act on behalf of <%= represented_user&.display_name %> in the following collectives:
          </p>
          <ul class="pulse-list">
            <% scoped_collectives.each do |s| %>
              <li class="pulse-list-item">
                <a href="<%= s.path %>" class="pulse-list-link">
                  <%= octicon 'organization', height: 16 %>
                  <%= s.name %>
                </a>
              </li>
            <% end %>
          </ul>
        <% end %>
      </section>
    <% else %>
      <section class="pulse-settings-section">
        <h2 class="pulse-section-title">Other Collectives</h2>

        <% if @other_collectives.empty? %>
          <p>
            <%= @collective.name %> is not a member of any other collectives yet.
            Once <%= @collective.name %> is invited to join other collectives, they will appear here.
          </p>
          <p class="pulse-muted">
            Since there are no other collectives to participate in, there is nothing for you to do as a representative at this time.
            You can end the session by clicking the "End Session" button above.
          </p>
        <% else %>
          <p>
            <%= @collective.name %> is a member of the following collectives:
          </p>

          <ul class="pulse-list">
            <% @other_collectives.each do |s| %>
              <li class="pulse-list-item">
                <a href="<%= s.path %>" class="pulse-list-link">
                  <%= octicon 'organization', height: 16 %>
                  <%= s.name %>
                </a>
              </li>
            <% end %>
          </ul>
        <% end %>
      </section>
    <% end %>
  </div>
</article>
