<%= render 'shared/pulse_breadcrumb', items: ['Billing'] %>

<article class="pulse-resource-detail">
  <header class="pulse-resource-header">
    <div class="pulse-resource-header-top">
      <span class="pulse-resource-type-label">
        <%= octicon 'credit-card', height: 14, class: 'pulse-resource-icon' %>
        Billing
      </span>
    </div>
  </header>

  <div class="pulse-resource-body">
    <% if flash[:notice] %>
      <div class="pulse-notice pulse-notice-success" style="margin-bottom: 20px;">
        <%= flash[:notice] %>
      </div>
    <% end %>

    <% if flash[:error] %>
      <div class="pulse-notice pulse-notice-error" style="margin-bottom: 20px;">
        <%= flash[:error] %>
      </div>
    <% end %>

    <% if @stripe_customer&.active? %>
      <section class="pulse-section" style="margin-bottom: 24px;">
        <div class="pulse-notice pulse-notice-success"><span><%= octicon 'check-circle', height: 16 %> <strong>Active</strong> — <%= link_to "Manage payment", billing_portal_path %></span></div>
      </section>

      <section class="pulse-section" style="margin-bottom: 24px;">
        <h2 class="pulse-section-title">Subscription Details</h2>
        <table class="pulse-table" style="max-width: 400px;">
          <tbody>
            <tr>
              <td>Your account</td>
              <td style="text-align: right;">$3/mo</td>
            </tr>
            <% if @active_agent_count && @active_agent_count > 0 %>
              <tr>
                <td>AI Agents (<%= @active_agent_count %>)</td>
                <td style="text-align: right;">$<%= @active_agent_count * 3 %>/mo</td>
              </tr>
            <% end %>
            <% if @active_collective_count && @active_collective_count > 0 %>
              <tr>
                <td>Collectives (<%= @active_collective_count %>)</td>
                <td style="text-align: right;">$<%= @active_collective_count * 3 %>/mo</td>
              </tr>
            <% end %>
            <tr style="font-weight: bold; border-top: 2px solid var(--border-color, #ddd);">
              <td>Total</td>
              <td style="text-align: right;">$<%= (1 + (@active_agent_count || 0) + (@active_collective_count || 0)) * 3 %>/mo</td>
            </tr>
          </tbody>
        </table>
      </section>

    <% else %>
      <section class="pulse-section" style="margin-bottom: 24px;">
        <h2 class="pulse-section-title">Account Subscription</h2>
        <p style="margin-bottom: 16px;">
          Harmonic accounts on this server require an active subscription. The base fee is <strong>$3/month</strong>.
        </p>
        <p class="pulse-muted" style="margin-bottom: 24px;">
          You'll see the exact pricing on the next page before confirming. You can cancel at any time.
        </p>

        <%= form_tag billing_setup_path, method: :post do %>
          <button type="submit" class="pulse-action-btn pulse-action-btn-primary">
            <%= octicon 'credit-card', height: 14 %>
            Set Up Billing
          </button>
        <% end %>
      </section>
    <% end %>
  </div>
</article>
