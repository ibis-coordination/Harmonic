<% show_actions = local_assigns.fetch(:show_actions, false) %>
<% multi_tenant = @current_user.tenant_users.count > 1 %>
<table class="pulse-table" style="max-width: 650px;">
  <tbody>
    <tr>
      <td><%= octicon 'person', height: 14 %> <%= @current_user.display_name %> <span class="pulse-muted">(you)</span></td>
      <% if show_prices %>
        <td style="text-align: right;">
          <% if @current_user.counts_self_for_api_access? %>
            $3/mo <span class="pulse-muted">(API access)</span>
          <% else %>
            <span style="color: var(--color-fg-muted);">free</span>
          <% end %>
        </td>
      <% end %>
      <% if show_actions %><td></td><% end %>
    </tr>
    <% @active_agents&.each do |agent| %>
      <% tu = agent.tenant_users.first %>
      <% agent_handle = tu&.handle %>
      <% agent_tenant = tu&.tenant %>
      <tr data-billing-item="agent-<%= agent.id %>">
        <td>
          <%= octicon 'dependabot', height: 14 %>
          <%= link_to agent.display_name, "/ai-agents/#{agent_handle}" %>
          <span class="pulse-muted">(agent<%= " on #{agent_tenant&.subdomain}" if multi_tenant && agent_tenant %>)</span>
        </td>
        <% if show_prices %>
          <td style="text-align: right;">
            <% if agent.billing_exempt? %>
              <span style="color: var(--color-fg-muted);">$0/mo <span class="pulse-muted">(exempt)</span></span>
            <% else %>
              $3/mo
            <% end %>
          </td>
        <% end %>
        <% if show_actions && agent_tenant == @current_tenant %>
          <td style="text-align: right;">
            <%= form_tag billing_deactivate_agent_path(agent_handle), method: :post, style: "display:inline",
                         data: { turbo_confirm: "Deactivate #{agent.display_name}? This will revoke API tokens and stop task execution." } do %>
              <%= hidden_field_tag :confirm_deactivate, "1" %>
              <button type="submit" class="pulse-action-btn-small pulse-action-btn-danger">
                Deactivate
              </button>
            <% end %>
          </td>
        <% elsif show_actions %>
          <td></td>
        <% end %>
      </tr>
    <% end %>
    <% @active_collectives&.each do |collective| %>
      <tr data-billing-item="collective-<%= collective.id %>">
        <td>
          <%= octicon 'people', height: 14 %>
          <%= link_to collective.name, collective.path %>
          <span class="pulse-muted">(collective<%= " on #{collective.tenant&.subdomain}" if multi_tenant %>)</span>
        </td>
        <% if show_prices %>
          <td style="text-align: right;">
            <% if collective.billing_exempt? %>
              <span style="color: var(--color-fg-muted);">$0/mo <span class="pulse-muted">(exempt)</span></span>
            <% else %>
              $3/mo
            <% end %>
          </td>
        <% end %>
        <% if show_actions && collective.tenant_id == @current_tenant.id %>
          <%
            row_disables = paid_features_to_disable_on_downgrade(collective)
            row_off_clauses = ["enabled automations will be disabled"]
            row_off_clauses << "#{row_disables.to_sentence} will be turned off" if row_disables.any?
            row_confirm = "Downgrade #{collective.name} to the free plan? #{sentence_case(row_off_clauses.to_sentence)}. To archive or delete the collective, use its settings page."
          %>
          <td style="text-align: right;">
            <%= button_to "Downgrade",
                          "#{collective.path}/downgrade",
                          method: :post,
                          params: { return_to: billing_show_path },
                          class: "pulse-action-btn-small pulse-action-btn-danger",
                          form: { style: "display: inline;" },
                          data: { turbo_confirm: row_confirm } %>
          </td>
        <% elsif show_actions %>
          <td></td>
        <% end %>
      </tr>
    <% end %>
    <% @pending_agents&.each do |agent| %>
      <tr data-billing-item="agent-<%= agent.id %>">
        <td>
          <%= octicon 'dependabot', height: 14 %> <%= agent.display_name %>
          <span class="pulse-muted">(pending agent<%= " on #{agent.tenant_users.first&.tenant&.subdomain}" if multi_tenant %>)</span>
        </td>
        <% if show_prices %>
          <td style="text-align: right; color: var(--color-fg-muted);">$3/mo when active</td>
        <% end %>
        <% if show_actions %><td></td><% end %>
      </tr>
    <% end %>
    <% @pending_collectives&.each do |collective| %>
      <tr data-billing-item="collective-<%= collective.id %>">
        <td>
          <%= octicon 'people', height: 14 %> <%= collective.name %>
          <span class="pulse-muted">(pending collective<%= " on #{collective.tenant&.subdomain}" if multi_tenant %>)</span>
        </td>
        <% if show_prices %>
          <td style="text-align: right; color: var(--color-fg-muted);">$3/mo when active</td>
        <% end %>
        <% if show_actions %><td></td><% end %>
      </tr>
    <% end %>
    <% if show_prices %>
      <tr style="font-weight: bold; border-top: 2px solid var(--border-color, #ddd);">
        <td>Total</td>
        <td style="text-align: right;">$<%= (@billable_quantity || 0) * 3 %>/mo</td>
        <% if show_actions %><td></td><% end %>
      </tr>
    <% end %>
  </tbody>
</table>
