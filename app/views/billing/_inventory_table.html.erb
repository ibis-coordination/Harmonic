<% show_actions = local_assigns.fetch(:show_actions, false) %>
<table class="pulse-table" style="max-width: 600px;">
  <tbody>
    <tr>
      <td><%= octicon 'person', height: 14 %> <%= @current_user.display_name %> <span class="pulse-muted">(you)</span></td>
      <% if show_prices %>
        <td style="text-align: right;">
          <% if @current_user.billing_exempt? %>
            <span style="color: var(--color-fg-muted);">$0/mo <span class="pulse-muted">(exempt)</span></span>
          <% else %>
            $3/mo
          <% end %>
        </td>
      <% end %>
      <% if show_actions %><td></td><% end %>
    </tr>
    <% @active_agents&.each do |agent| %>
      <% agent_handle = agent.tenant_users.find_by(tenant_id: @current_tenant.id)&.handle %>
      <tr data-billing-item="agent-<%= agent.id %>">
        <td><%= octicon 'dependabot', height: 14 %> <%= link_to agent.display_name, "/ai-agents/#{agent_handle}" %> <span class="pulse-muted">(agent)</span></td>
        <% if show_prices %>
          <td style="text-align: right;">
            <% if agent.billing_exempt? %>
              <span style="color: var(--color-fg-muted);">$0/mo <span class="pulse-muted">(exempt)</span></span>
            <% else %>
              $3/mo
            <% end %>
          </td>
        <% end %>
        <% if show_actions %>
          <td style="text-align: right;">
            <%= form_tag billing_deactivate_agent_path(agent_handle), method: :post, style: "display:inline" do %>
              <%= hidden_field_tag :confirm_deactivate, "1" %>
              <button type="submit" class="pulse-action-btn-small pulse-action-btn-danger" onclick="return confirm('Deactivate <%= j agent.display_name %>? This will revoke API tokens and stop task execution.')">
                Deactivate
              </button>
            <% end %>
          </td>
        <% end %>
      </tr>
    <% end %>
    <% @active_collectives&.each do |collective| %>
      <tr data-billing-item="collective-<%= collective.id %>">
        <td><%= octicon 'people', height: 14 %> <%= link_to collective.name, collective.path %> <span class="pulse-muted">(collective)</span></td>
        <% if show_prices %>
          <td style="text-align: right;">
            <% if collective.billing_exempt? %>
              <span style="color: var(--color-fg-muted);">$0/mo <span class="pulse-muted">(exempt)</span></span>
            <% else %>
              $3/mo
            <% end %>
          </td>
        <% end %>
        <% if show_actions %>
          <td style="text-align: right;">
            <%= form_tag billing_deactivate_collective_path(collective.handle), method: :post, style: "display:inline" do %>
              <%= hidden_field_tag :confirm_deactivate, "1" %>
              <button type="submit" class="pulse-action-btn-small pulse-action-btn-danger" onclick="return confirm('Deactivate <%= j collective.name %>? It will become inaccessible to all members.')">
                Deactivate
              </button>
            <% end %>
          </td>
        <% end %>
      </tr>
    <% end %>
    <% if show_prices %>
      <tr style="font-weight: bold; border-top: 2px solid var(--border-color, #ddd);">
        <td>Total</td>
        <td style="text-align: right;">$<%= (@billable_quantity || 0) * 3 %>/mo</td>
        <% if show_actions %><td></td><% end %>
      </tr>
    <% end %>
  </tbody>
</table>
