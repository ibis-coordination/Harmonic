<%= render 'shared/pulse_breadcrumb', items: [
  ['Home', '/'],
  [@current_user.display_name, @current_user.path],
  ['Settings', "/settings"],
  'New AI Agent'
] %>

<article class="pulse-resource-detail">
  <header class="pulse-resource-header">
    <div class="pulse-resource-header-top">
      <span class="pulse-resource-type-label">
        <%= octicon 'command-palette', height: 14, class: 'pulse-resource-icon' %>
        New AI Agent
      </span>
    </div>
    <h1 class="pulse-resource-title">Create AI Agent</h1>
  </header>

  <div class="pulse-resource-body">
    <% if @current_tenant.feature_enabled?("stripe_billing") && !@current_user.stripe_billing_setup? %>
      <div class="pulse-notice pulse-notice-warning" style="margin-bottom: 24px;">
        <span>
          <%= octicon 'credit-card', height: 14 %>
          <strong>Billing required</strong> — You need to set up billing before creating an AI agent.
        </span>
      </div>

      <p style="margin-bottom: 16px;">
        AI Agents in Harmonic are virtual identities that can navigate the app, create content, make decisions, and run automated tasks on your behalf.
      </p>

      <a href="/billing" class="pulse-action-btn pulse-action-btn-primary">
        <%= octicon 'credit-card', height: 14 %>
        Set Up Billing
      </a>
    <% else %>
    <% if @credit_balance_cents == 0 %>
      <div class="pulse-notice pulse-notice-warning" style="margin-bottom: 24px;">
        <%= octicon 'alert', height: 14 %>
        <strong>No credit balance</strong> — <a href="/billing">Add funds</a> before running tasks.
      </div>
    <% end %>
    <p>AI Agents are distinct identities for AI agents that you manage as their principal.</p>

    <%# turbo: false — this form triggers a Stripe Checkout redirect for non-admin users
        on tenants with stripe_billing enabled. Turbo Drive's cross-origin handling has
        produced silent failures here (form submits, agent is created, but the page
        doesn't update — user double-clicks and hits a duplicate-handle error).
        Matches the API tokens new form and the notification webhook form. %>
    <%= form_with url: "/ai-agents/new/actions/create_ai_agent", class: "pulse-form",
                  data: { controller: "ai-agent-mode", turbo: false } do |form| %>
      <section class="pulse-settings-section">
        <label for="name" class="pulse-label">Name</label>
        <%= form.text_field :name, placeholder: 'My Assistant', class: "pulse-form-input" %>
        <small class="pulse-hint">This name will appear on the AI Agent's profile.</small>
      </section>

      <section class="pulse-settings-section">
        <label for="handle" class="pulse-label">Handle</label>
        <div style="display: flex; align-items: center; gap: 8px;">
          <span aria-hidden="true" style="font-weight: 600; color: var(--color-fg-muted);">@</span>
          <%= form.text_field :handle, placeholder: 'auto-generated from name', class: "pulse-form-input",
                style: "flex: 1;", autocomplete: "off", spellcheck: "false",
                pattern: '[a-z0-9_\-]*', title: "Lowercase letters, numbers, dashes, and underscores",
                data: { controller: "handle-input", action: "input->handle-input#sanitize" } %>
        </div>
        <small class="pulse-hint">The agent's @-mention handle. Leave blank to generate one from the name.</small>
      </section>

      <section class="pulse-settings-section">
        <label for="identity_prompt" class="pulse-label">Identity Prompt</label>
        <%= form.text_area :identity_prompt, placeholder: 'You are a helpful assistant...', class: "pulse-form-textarea", rows: 4 %>
        <small class="pulse-hint">This prompt will be shown to the agent on the /whoami page, providing context about their identity and purpose.</small>
      </section>

      <section class="pulse-settings-section">
        <label class="pulse-label">Capabilities</label>
        <small class="pulse-hint">Check the actions this agent is allowed to perform. Unchecked actions will be blocked.</small>
        <%= render "capabilities_section", current_caps: nil %>
      </section>

      <section class="pulse-settings-section">
        <label class="pulse-label">Public writes</label>
        <small class="pulse-hint">Whether this agent may write to the public space. Off by default; private and shared writes are always allowed.</small>
        <%= render "public_writes_section", allow_public_writes: nil %>
      </section>

      <section class="pulse-settings-section">
        <label class="pulse-label">Notification preferences</label>
        <small class="pulse-hint">Choose which activity this agent is notified about. Notifications appear in its inbox. You can change this later.</small>
        <%# Marker so execute_create_ai_agent applies the full matrix even when
            every box is unchecked. tenant_user is nil — the record doesn't exist
            yet, so the boxes seed from the defaults. %>
        <%= hidden_field_tag :notifications_present, "1" %>
        <%= render 'shared/notification_preferences_fields', tenant_user: nil, simple: true %>
      </section>

      <%
        internal_enabled = @current_tenant.internal_ai_agents_enabled?
        external_enabled = @current_tenant.external_ai_agents_enabled?
        both_modes = internal_enabled && external_enabled
      %>

      <% if both_modes %>
        <section class="pulse-settings-section">
          <label class="pulse-label">Mode</label>
          <small class="pulse-hint" style="margin-bottom: 12px; display: block;">Choose how this AI Agent will be powered.</small>
          <div style="display: flex; flex-direction: column; gap: 12px;">
            <label class="pulse-radio-label" style="display: flex; align-items: center; gap: 8px; cursor: pointer;">
              <%= radio_button_tag :mode, "internal", true, data: { action: "ai-agent-mode#updateVisibility" } %>
              <span>
                <strong>Internal</strong>
                <small class="pulse-hint" style="display: block; margin-top: 2px;">Powered by Harmonic's agent runners. No API access.</small>
              </span>
            </label>
            <label class="pulse-radio-label" style="display: flex; align-items: center; gap: 8px; cursor: pointer;">
              <%= radio_button_tag :mode, "external", false, data: { action: "ai-agent-mode#updateVisibility" } %>
              <span>
                <strong>External</strong>
                <small class="pulse-hint" style="display: block; margin-top: 2px;">Powered by your own infrastructure through the API. Connect a client via <a href="/help/mcp">MCP</a> or any other API path.</small>
              </span>
            </label>
          </div>
        </section>
      <% else %>
        <%= hidden_field_tag :mode, internal_enabled ? "internal" : "external" %>
      <% end %>

      <% if internal_enabled %>
        <section class="pulse-settings-section" data-ai-agent-mode-target="internalOnly">
          <label for="model" class="pulse-label">Model</label>
          <%= form.select :model, selectable_models, {}, class: "pulse-form-select" %>
          <small class="pulse-hint">The LLM model this AI Agent will use for reasoning.</small>
          <%= render "ai_agents/model_pricing" %>
        </section>
      <% end %>

      <% if external_enabled %>
        <section class="pulse-settings-section" data-ai-agent-mode-target="externalOnly" style="<%= both_modes ? 'display: none;' : '' %>">
          <label class="pulse-checkbox-label">
            <%= form.check_box :generate_token, checked: true %>
            Generate an API token for this AI Agent
          </label>
          <small class="pulse-hint">Required for the AI Agent to access the API.</small>

          <label class="pulse-checkbox-label" style="display: flex; align-items: flex-start; gap: 8px; margin-top: 12px;">
            <%= form.check_box :mcp_only, checked: true %>
            <span>
              <strong>MCP-only access (recommended)</strong>
              <small class="pulse-hint" style="display: block; margin-top: 4px;">
                When checked, the token can only be used through the <code>/mcp</code> endpoint and every action is logged for your review. Uncheck if you need a legacy direct REST or markdown client. See <a href="/help/mcp" class="pulse-link">/help/mcp</a>.
              </small>
            </span>
          </label>
        </section>
      <% end %>

      <%# Admins (sys_admin / app_admin) are billing-exempt — billable_quantity
          is always 0, no Stripe charges fire — so the billing notice + confirm
          checkbox would be misleading. Skip the whole section for them. %>
      <% if @current_tenant.feature_enabled?("stripe_billing") && !@current_user.app_admin? && !@current_user.sys_admin? %>
        <section class="pulse-settings-section">
          <div class="pulse-notice pulse-notice-warning" style="margin-bottom: 16px;">
            <span>
              <%= octicon 'credit-card', height: 14 %>
              <% if @proration_amount_cents %>
                <strong>You will be charged $<%= format("%.2f", @proration_amount_cents / 100.0) %> now</strong> (prorated for the current billing period), then <strong>$3/month</strong> thereafter.
              <% else %>
                <strong>Each AI agent identity costs $3/month</strong>, added to your subscription and prorated for the current billing period.
              <% end %>
            </span>
          </div>
          <label class="pulse-checkbox-label" style="display: flex; align-items: center; gap: 8px; cursor: pointer;">
            <%= check_box_tag :confirm_billing, "1", false, required: true, id: "confirm_billing" %>
            <% if @proration_amount_cents %>
              I authorize a charge of $<%= format("%.2f", @proration_amount_cents / 100.0) %> now and $3/month thereafter
            <% else %>
              I understand that creating this agent will add $3/month to my subscription
            <% end %>
          </label>
        </section>
      <% end %>

      <section class="pulse-settings-section pulse-action-row">
        <%= form.submit 'Create AI Agent', class: "pulse-action-btn pulse-action-btn-primary" %>
        <a href="/settings" class="pulse-action-btn">Cancel</a>
      </section>
    <% end %>
    <% end %>
  </div>
</article>
