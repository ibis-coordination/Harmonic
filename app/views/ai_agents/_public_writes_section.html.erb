<%# Renders the public-write toggle used by both the new-agent form and the
    agent settings form. Sibling to _capabilities_section.

    Required local: allow_public_writes — the agent's current setting (true /
    false), or nil for a brand-new agent with no configuration yet. nil and
    false both render unchecked (public writes are off by default). %>

<%# Hidden sentinel so an unchecked box still posts allow_public_writes=0 —
    the controller casts it to false, preserving "uncheck = disable" semantics. %>
<%= hidden_field_tag "allow_public_writes", "0" %>

<div style="margin-top: 8px;">
  <label class="pulse-checkbox-label" style="display: flex; align-items: center; gap: 8px; cursor: pointer;">
    <%= check_box_tag "allow_public_writes", "1", allow_public_writes == true, id: "allow_public_writes" %>
    <span style="font-size: 13px;">Allow writes to the public space</span>
  </label>
  <small class="pulse-hint" style="display: block; margin-top: 8px;">
    Read access to the public space is always enabled.
  </small>
</div>
