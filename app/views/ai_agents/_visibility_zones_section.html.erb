<%# Renders the visibility-zone picker used by both the new-agent form and the
    agent settings form. Sibling to _capabilities_section.

    Required local: current_zones — array of currently-granted grantable zone
    strings, or nil for a brand-new agent with no configuration yet. nil
    triggers the default grant (shared on, public off). %>

<%# Sentinel so an all-unchecked submission still includes a visibility_zones
    param — the controller writes [] when present-but-empty, preserving
    "uncheck all" semantics (private only). %>
<%= hidden_field_tag "visibility_zones[]", "" %>

<% zones_not_configured = current_zones.nil? %>

<div style="margin-top: 16px;">
  <div style="font-weight: 500; font-size: 13px; margin-bottom: 4px; color: var(--text-muted); display: flex; align-items: center; gap: 12px;">
    <span>Always allowed</span>
    <span style="font-weight: normal; font-size: 12px;">(cannot be disabled)</span>
  </div>
  <small class="pulse-hint" style="display: block; margin-bottom: 8px;">An agent can always act in its own private workspace.</small>
  <div class="pulse-checkbox-group" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 8px;">
    <% CapabilityCheck::ALWAYS_ALLOWED_ZONES.each do |zone| %>
      <label class="pulse-checkbox-label" style="display: flex; align-items: center; gap: 8px; cursor: not-allowed; opacity: 0.6;">
        <%= check_box_tag nil, zone, true, disabled: true, id: "zone_#{zone}" %>
        <code style="font-size: 12px;"><%= zone %></code>
      </label>
    <% end %>
  </div>
</div>

<div style="margin-top: 16px;">
  <div style="font-weight: 500; font-size: 13px; margin-bottom: 4px; color: var(--text-primary);">
    <span>Visibility zones</span>
  </div>
  <small class="pulse-hint" style="display: block; margin-bottom: 8px;">
    Which audiences this agent may write to. <code>shared</code> covers collective spaces; <code>public</code> covers the tenant-wide main collective.
  </small>
  <div class="pulse-checkbox-group" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 8px;">
    <% CapabilityCheck::GRANTABLE_ZONES.each do |zone| %>
      <% checked = zones_not_configured ? CapabilityCheck::DEFAULT_GRANTED_ZONES.include?(zone) : current_zones.include?(zone) %>
      <label class="pulse-checkbox-label" style="display: flex; align-items: center; gap: 8px; cursor: pointer;">
        <%= check_box_tag "visibility_zones[]", zone, checked, id: "zone_#{zone}" %>
        <code style="font-size: 12px;"><%= zone %></code>
      </label>
    <% end %>
  </div>
</div>
