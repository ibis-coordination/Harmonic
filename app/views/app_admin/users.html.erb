<%= render layout: 'shared/admin_user_list', locals: {
  breadcrumb_items: [
    [@current_tenant.subdomain, '/'],
    ['App Admin', '/app-admin'],
    'Users',
  ],
  page_title: 'All Users',
  intro_html: 'All users across all tenants',
  base_path: '/app-admin/users',
  search_query: @search_query,
  page: @page,
  total_pages: @total_pages,
  total_users: @total_users,
  users_by_type: @users_by_type,
  counts_by_type: @counts_by_type,
  user_type_labels: { 'human' => 'Human Users', 'ai_agent' => 'AI Agents' },
  user_path: ->(user) { "/app-admin/users/#{user.id}" },
} do |user| %>
  <% if user.app_admin? %>
    <span class="pulse-badge pulse-badge-primary">app_admin</span>
  <% end %>
  <% if user.sys_admin? %>
    <span class="pulse-badge pulse-badge-primary">sys_admin</span>
  <% end %>
<% end %>
