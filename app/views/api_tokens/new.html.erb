<%= render 'shared/pulse_breadcrumb', items: [
  ['Home', '/'],
  [@showing_user.display_name, @showing_user.path],
  ['Settings', "#{@showing_user.path}/settings"],
  'New API Token'
] %>

<article class="pulse-resource-detail">
  <header class="pulse-resource-header">
    <div class="pulse-resource-header-top">
      <span class="pulse-resource-type-label">
        <%= octicon 'key', height: 14, class: 'pulse-resource-icon' %>
        New Token
      </span>
    </div>
    <h1 class="pulse-resource-title">API Token</h1>
  </header>

  <div class="pulse-resource-body">
    <%# Opt out of Turbo: when billing isn't set up, the controller redirects
        to Stripe Checkout (cross-origin), which Turbo cannot follow. %>
    <%= form_with(model: [@showing_user, @token], class: "pulse-form", data: { turbo: false }) do |form| %>
      <section class="pulse-settings-section">
        <label class="pulse-label">Identity</label>
        <div style="padding: 8px 12px; background-color: var(--bg-tertiary); border: 1px solid var(--border-color); border-radius: 6px; color: var(--text-secondary); font-style: italic;">
          <% if @showing_user == @current_user %>
            you
          <% elsif @showing_user.ai_agent? %>
            <%= @showing_user.display_name %> (AI agent)
          <% else %>
            <%= @showing_user.display_name %>
          <% end %>
        </div>
        <p class="pulse-hint" style="margin-top: 8px;">
          <% if @showing_user == @current_user %>
            This token will be associated with your account. To create a token for an AI agent, go to
            <a href="/ai-agents" class="pulse-link">AI Agents</a> and select the agent's settings page.
          <% else %>
            This token will be associated with <%= @showing_user.display_name %>. Actions taken through the API using this token will be attributed to <%= @showing_user.display_name %>.
          <% end %>
        </p>
      </section>

      <section class="pulse-settings-section">
        <label for="api_token_name" class="pulse-label">Name</label>
        <input type="text" name="api_token[name]" id="api_token_name" class="pulse-form-input" placeholder="My API Token" value="<%= @token.name %>">
      </section>

      <section class="pulse-settings-section">
        <h2 class="pulse-section-title">Scopes</h2>
        <div class="pulse-radio-group">
          <label class="pulse-radio-label">
            <%= form.radio_button :read_write, 'read', checked: true %>
            Read only
          </label>
          <label class="pulse-radio-label">
            <%= form.radio_button :read_write, 'write' %>
            Read + write
          </label>
        </div>
      </section>

      <% if @showing_user.ai_agent? %>
        <section class="pulse-settings-section">
          <h2 class="pulse-section-title">Access mode</h2>
          <label class="pulse-checkbox-label" style="display: flex; align-items: flex-start; gap: 8px;">
            <%= form.check_box :mcp_only %>
            <span>
              <strong>MCP-only access (recommended)</strong>
              <p class="pulse-hint" style="margin-top: 4px;">
                When checked, this token can only be used through the <code>/mcp</code> endpoint. Every action — reads and writes — is logged for your review. See <a href="/help/mcp" class="pulse-link">/help/mcp</a> for connection details. Uncheck only if you have a legacy client that needs direct REST or markdown access; doing so removes the audit guarantee for this token.
              </p>
            </span>
          </label>
        </section>
      <% end %>

      <section class="pulse-settings-section">
        <h2 class="pulse-section-title">Expiration</h2>
        <p class="pulse-form-row">
          This will expire in
          <%= form.number_field :duration, value: 12, class: "pulse-form-input", style: 'width:64px;' %>
          <%= form.select :duration_unit, options_for_select(['hour(s)', 'day(s)', 'week(s)', 'month(s)'], selected: 'month(s)'), {}, class: "pulse-form-input" %>
          <span class="pulse-muted">(max 12 months)</span>
        </p>
      </section>

      <% if @showing_user.human? && @current_tenant.feature_enabled?("stripe_billing") &&
            !@showing_user.app_admin? && !@showing_user.sys_admin? %>
        <% if @showing_user.billing_exempt? %>
          <section class="pulse-settings-section">
            <div class="pulse-notice" style="background:var(--color-canvas-subtle);padding:12px;border-radius:6px;font-size:13px;">
              <%= octicon 'credit-card', height: 14 %>
              Your account has a billing exemption — API tokens are free for you.
            </div>
          </section>
        <% elsif @showing_user.counts_self_for_api_access? %>
          <section class="pulse-settings-section">
            <div class="pulse-notice" style="background:var(--color-canvas-subtle);padding:12px;border-radius:6px;font-size:13px;">
              <%= octicon 'credit-card', height: 14 %>
              API access is already on your subscription ($3/mo). Adding more tokens does not increase the cost.
            </div>
          </section>
        <% elsif @showing_user.stripe_customer&.active? %>
          <section class="pulse-settings-section">
            <div class="pulse-notice" style="background:var(--color-attention-subtle);border:1px solid var(--color-attention-muted);padding:12px;border-radius:6px;font-size:13px;">
              <%= octicon 'credit-card', height: 14 %>
              <strong>Creating an API token will add $3/month to your subscription</strong>, prorated for the current billing period.
            </div>
          </section>
        <% else %>
          <section class="pulse-settings-section">
            <div class="pulse-notice" style="background:var(--color-attention-subtle);border:1px solid var(--color-attention-muted);padding:12px;border-radius:6px;font-size:13px;">
              <%= octicon 'credit-card', height: 14 %>
              <strong>Creating an API token costs $3/month.</strong> When you click <em>Create Token</em>, you'll be sent to Stripe to set up billing. The token is created once payment succeeds.
            </div>
          </section>
        <% end %>
      <% end %>

      <section class="pulse-settings-section pulse-action-row">
        <%= form.submit 'Create Token', class: "pulse-action-btn pulse-action-btn-primary" %>
        <a href="<%= @showing_user.path %>/settings" class="pulse-action-btn">Cancel</a>
      </section>
    <% end %>
  </div>
</article>
