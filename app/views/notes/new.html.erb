<%= render 'shared/pulse_breadcrumb', items: [
  [@current_collective.name, @current_collective.path],
  'New'
] %>

<%= render 'shared/pulse_create_tabs', current: :note %>

<article class="pulse-resource-detail">

  <%= form_with(url: "#{@current_collective.path}/note", class: "pulse-form", data: { controller: "note-subtype" }) do |form| %>
    <input type="hidden" name="subtype" value="<%= @subtype %>" data-note-subtype-target="subtypeInput">

    <div style="display: flex; gap: 8px; margin-bottom: 16px;">
      <button type="button" class="<%= @subtype == 'table' ? 'pulse-action-btn-secondary' : 'pulse-action-btn' %>" data-action="note-subtype#selectText" data-note-subtype-target="textBtn">Text</button>
      <button type="button" class="<%= @subtype == 'table' ? 'pulse-action-btn' : 'pulse-action-btn-secondary' %>" data-action="note-subtype#selectTable" data-note-subtype-target="tableBtn">Table</button>
    </div>

    <div data-note-subtype-target="textFields"<%= ' style="display: none;"'.html_safe if @subtype == 'table' %>>
      <div class="pulse-form-group">
        <div class="mention-autocomplete-container" data-controller="mention-autocomplete" data-mention-autocomplete-collective-path-value="<%= @current_collective.path %>">
          <%= form.text_area :text,
              placeholder: @current_collective.private_workspace? ? "Write your note here..." : "Write your note here... (use @ to mention users)",
              autofocus: true,
              value: @note.text,
              class: "pulse-form-textarea",
              rows: 8,
              data: { mention_autocomplete_target: "input" } %>
          <div data-mention-autocomplete-target="dropdown" class="mention-dropdown"></div>
        </div>
      </div>
    </div>

    <div data-note-subtype-target="tableFields"<%= ' style="display: none;"'.html_safe unless @subtype == 'table' %>>
      <div class="pulse-form-group">
        <label class="pulse-form-label">Title</label>
        <input type="text" name="title" placeholder="Table title" class="pulse-form-input">
      </div>
      <div class="pulse-form-group">
        <label class="pulse-form-label">Description <span style="font-weight: normal; color: var(--color-fg-muted);">(optional)</span></label>
        <textarea name="table_description" placeholder="What is this table for?" class="pulse-form-textarea" rows="2"></textarea>
      </div>
      <div style="display: flex; gap: 8px; margin-bottom: 12px;">
        <button type="button" class="pulse-action-btn" data-action="note-subtype#selectManualColumns" data-note-subtype-target="manualColumnsBtn">Define columns</button>
        <button type="button" class="pulse-action-btn-secondary" data-action="note-subtype#selectCsvImport" data-note-subtype-target="csvImportBtn">Import from CSV</button>
      </div>

      <div data-note-subtype-target="manualColumnsSection">
        <div class="pulse-form-group">
          <div data-columns>
            <div style="display: flex; gap: 8px; margin-bottom: 8px;">
              <input type="text" name="columns[0][name]" placeholder="Column name" class="pulse-form-input" style="flex: 2;">
              <select name="columns[0][type]" class="pulse-form-input" style="flex: 1;">
                <option value="text">Text</option>
                <option value="number">Number</option>
                <option value="boolean">Boolean</option>
                <option value="date">Date</option>
              </select>
              <button type="button" class="pulse-action-btn-secondary" style="padding: 4px 8px;" data-action="note-subtype#removeColumn">✕</button>
            </div>
            <div style="display: flex; gap: 8px; margin-bottom: 8px;">
              <input type="text" name="columns[1][name]" placeholder="Column name" class="pulse-form-input" style="flex: 2;">
              <select name="columns[1][type]" class="pulse-form-input" style="flex: 1;">
                <option value="text">Text</option>
                <option value="number">Number</option>
                <option value="boolean">Boolean</option>
                <option value="date">Date</option>
              </select>
              <button type="button" class="pulse-action-btn-secondary" style="padding: 4px 8px;" data-action="note-subtype#removeColumn">✕</button>
            </div>
          </div>
          <button type="button" class="pulse-action-btn-secondary" data-action="note-subtype#addColumn" style="margin-top: 4px;">
            + Add Column
          </button>
        </div>
      </div>

      <div data-note-subtype-target="csvImportSection" style="display: none;">
        <div class="pulse-form-group">
          <label style="font-size: 12px; color: var(--color-fg-muted); display: block; margin-bottom: 4px;">Paste CSV or upload a file (first row becomes column names)</label>
          <textarea data-note-subtype-target="csvInput"
                    class="pulse-form-textarea"
                    rows="5"
                    placeholder="Name,Status,Due&#10;Task A,done,2026-05-01&#10;Task B,pending,2026-05-15"
                    data-action="input->note-subtype#parseCsvFromTextarea"></textarea>
        </div>
        <div style="margin-bottom: 8px;">
          <input type="file" accept=".csv,text/csv" data-note-subtype-target="fileInput" data-action="change->note-subtype#parseCsvFromFile" style="font-size: 13px;">
        </div>
        <div data-note-subtype-target="csvErrors"></div>
        <div data-note-subtype-target="csvPreview"></div>
      </div>

      <input type="hidden" name="initial_rows" value="" data-note-subtype-target="initialRowsInput">
      <input type="hidden" name="table_creation_mode" value="manual" data-note-subtype-target="tableCreationModeInput">
    </div>

    <%= render 'shared/multi_file_select', form: form %>

    <div class="pulse-form-actions">
      <%= form.submit 'Post Note', class: 'pulse-action-btn' %>
      <span class="pulse-visibility-hint">
        <% if @current_collective.id == @current_tenant.main_collective_id %>
          <%= octicon 'eye', height: 14 %>
          This note will be publicly visible.
        <% elsif @current_collective.private_workspace? %>
          <%= octicon 'lock', height: 14 %>
          Only you will see this note.
        <% else %>
          <%= octicon 'lock', height: 14 %>
          Only members of this collective will see this note.
        <% end %>
      </span>
    </div>
  <% end %>
</article>
