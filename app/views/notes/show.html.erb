<span data-controller="note" data-note-id="<%= @note.id %>">
<%= render 'shared/pulse_breadcrumb', items: [
  [@current_collective.name, @current_collective.path],
  (@note.is_comment? ? 'Comment' : 'Note')
] %>

<% if @note.deleted? %>
<article class="pulse-resource-detail">
  <div class="pulse-resource-body" style="padding: 24px;">
    <p><%= octicon 'trash', height: 16 %> This <%= @note.is_comment? ? "comment" : "note" %> has been deleted<%= " by the author" if @note.deleted_by_id == @note.created_by_id %>.</p>
    <% if @note.is_comment? && @note.commentable %>
      <p style="margin-top: 16px;">
        <a href="<%= @note.commentable.path %>" class="pulse-link"><%= octicon 'arrow-left', height: 12 %> Back to parent</a>
      </p>
    <% end %>
  </div>
</article>
<% else %>

<article class="pulse-resource-detail">
  <% note_type_label = @note.is_comment? ? "Comment" : (@note.is_table? ? "Table" : (@note.is_reminder? ? "Reminder" : "Note")) %>
  <%= render ResourceHeaderComponent.new(
    type_label: note_type_label,
    title: @note.persisted_title,
    icon_name: @note.is_comment? ? "comment" : nil,
    icon_class: @note.is_comment? ? nil : "note-icon",
  ) do |header|
    header.with_actions do %>
      <%= render 'shared/copy_to_clipboard', text: request.original_url %>
      <% if @note.user_can_edit?(@current_user) %>
        <% if @note.is_table? %>
          <%= link_to "#{@note.path}/settings", class: 'pulse-action-btn' do %>
            <%= octicon 'gear', height: 14 %>
            Settings
          <% end %>
        <% else %>
          <%= link_to "#{@note.path}/edit", class: 'pulse-action-btn' do %>
            <%= octicon 'pencil', height: 14 %>
            Edit
          <% end %>
        <% end %>
      <% end %>
      <% show_pin = @current_user && !@current_collective.is_main_collective? %>
      <% show_report = @current_user && @note.created_by_id != @current_user.id && !@already_reported %>
      <% if show_pin || show_report %>
        <details data-controller="kebab-menu" style="position: relative; display: inline-block;">
          <summary class="pulse-action-btn-secondary" style="cursor: pointer; list-style: none;" title="More actions">
            <%= octicon 'kebab-horizontal', height: 14 %>
          </summary>
          <div class="top-menu" style="position: absolute; top: 100%; right: 0; z-index: 100;">
            <ul>
              <% if show_pin %>
                <li><%= render 'shared/pulse_pin_button', resource: @note, is_pinned: @is_pinned %></li>
              <% end %>
              <% if show_report %>
                <li>
                  <%= link_to "#{@note.path}/report" do %>
                    <%= octicon 'report', height: 14 %> Report
                  <% end %>
                </li>
              <% end %>
            </ul>
          </div>
        </details>
      <% end %>
    <% end
  end %>

  <% if @note.is_comment? && @note.commentable %>
    <div class="pulse-reply-context" onclick="location.href='<%= @note.commentable.path %>'" style="cursor:pointer;">
      <%= octicon 'reply', height: 14 %>
      Replying to
      <%= render 'shared/pulse_resource_link', resource: @note.commentable %>
    </div>
  <% elsif @note.is_comment? %>
    <div class="pulse-reply-context">
      <%= octicon 'reply', height: 14 %>
      Replying to a deleted <%= @note.commentable_type&.downcase || "item" %>
    </div>
  <% end %>

  <div class="pulse-resource-meta">
    <%= render 'shared/pulse_author', resource: @note %>
  </div>

  <%= render 'shared/automation_attribution', resource: @note %>

  <%= render 'shared/pulse_attachments', resource: @note %>

  <% if @note.reminder_pending? %>
    <div class="pulse-resource-meta" style="margin-top: 12px;" data-action="countdown:completed->note#countdownCompleted">
      <span style="color: var(--color-fg-muted);">
        <%= octicon 'clock', height: 14 %>
        <%= render CountdownComponent.new(datetime: @note.reminder_scheduled_for) %>
      </span>
    </div>
  <% elsif @note.reminder_delivered? %>
    <div class="pulse-resource-meta" style="margin-top: 12px;">
      <% delivered_event = @note.note_history_events.find_by(event_type: "reminder") %>
      <span style="color: var(--color-fg-muted);">
        <%= octicon 'check-circle', height: 14 %>
        Reminder delivered <% if delivered_event %><%= time_ago_in_words(delivered_event.happened_at) %> ago<% end %>
      </span>
    </div>
  <% elsif @note.reminder_cancelled? %>
    <div class="pulse-resource-meta" style="margin-top: 12px;">
      <span style="color: var(--color-fg-muted);">
        <%= octicon 'x-circle', height: 14 %>
        Reminder cancelled by <%= link_to @note.updated_by.display_name, @note.updated_by.path %> <%= time_ago_in_words(@note.updated_at) %> ago
      </span>
    </div>
  <% end %>

  <% if @note.is_table? %>
    <%= render 'table' %>
  <% else %>
    <div class="pulse-resource-body">
      <div class="pulse-markdown-content">
        <% if @note.text.present? %>
          <%= markdown(@note.text) %>
        <% else %>
          <p class="pulse-empty-content"><em>empty note</em></p>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# Confirmed Reads Section %>
  <div class="pulse-confirmed-section" data-note-target="confirmSection">
    <%= render 'confirm' %>
  </div>
</article>
<% end %>
</span>
