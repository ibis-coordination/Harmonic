<%= render 'shared/pulse_breadcrumb', items: [
  [@current_tenant.subdomain, '/'],
  ['System Admin', '/system-admin'],
  'Agent Runner'
] %>

<h1 class="pulse-page-title">
  <%= octicon 'cpu', height: 24 %> Agent Runner
</h1>

<% if @error %>
  <div class="pulse-alert pulse-alert-warning">
    <strong>Error reading agent-runner stats:</strong> <%= @error %>
  </div>
<% end %>

<%= render 'shared/pulse_accordion', title: 'Service Status', icon: 'pulse', open: true do %>
  <% if @runner_stats %>
    <div class="pulse-table-wrapper">
      <table class="pulse-table">
        <thead>
          <tr>
            <th>Metric</th>
            <th>Value</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>Active Tasks</td><td><%= @runner_stats["activeTasks"] %></td></tr>
          <tr><td>Total Tasks Processed</td><td><%= @runner_stats["totalTasksProcessed"] %></td></tr>
          <% if @runner_stats["processedSinceStart"] %>
            <% counts = @runner_stats["processedSinceStart"] %>
            <tr><td>Completed</td><td><%= counts["completed"] || 0 %></td></tr>
            <tr><td>Failed</td><td><%= counts["failed"] || 0 %></td></tr>
            <tr><td>Cancelled</td><td><%= counts["cancelled"] || 0 %></td></tr>
          <% end %>
          <tr><td>Started At</td><td><%= @runner_stats["startedAt"] %></td></tr>
          <tr><td>Last Task At</td><td><%= @runner_stats["lastTaskAt"] || "None" %></td></tr>
          <tr><td>Last Completion At</td><td><%= @runner_stats["lastCompletionAt"] || "None" %></td></tr>
          <tr><td>Last Failure At</td><td><%= @runner_stats["lastFailureAt"] || "None" %></td></tr>
          <% if @runner_stats["lastFailureReason"] %>
            <tr><td>Last Failure</td><td><%= @runner_stats["lastFailureReason"] %></td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="pulse-text-secondary">Agent runner is not reporting stats. It may be offline or not yet started.</p>
  <% end %>
<% end %>

<%= render 'shared/pulse_accordion', title: 'Redis Stream', icon: 'database', open: true do %>
  <div class="pulse-table-wrapper">
    <table class="pulse-table">
      <thead>
        <tr>
          <th>Metric</th>
          <th>Value</th>
        </tr>
      </thead>
      <tbody>
        <tr><td>Stream Depth</td><td><%= @runner_stats&.dig("streamDepth") || @stream_length %></td></tr>
        <tr><td>Pending Messages</td><td><%= @runner_stats&.dig("streamPending") || @pending_count %></td></tr>
      </tbody>
    </table>
  </div>
<% end %>

<%= render 'shared/pulse_accordion', title: 'Recent Task Runs', icon: 'history', count: @recent_task_runs&.count || 0, open: true do %>
  <div style="margin-bottom: 12px; display: flex; gap: 8px;">
    <% %w[all completed failed cancelled running queued].each do |status| %>
      <% active = (status == "all" && @status_filter.blank?) || @status_filter == status %>
      <a href="<%= status == "all" ? "/system-admin/agent-runner" : "/system-admin/agent-runner?status=#{status}" %>"
         class="pulse-badge <%= active ? 'pulse-badge-info' : 'pulse-badge-muted' %>"
         style="text-decoration: none;">
        <%= status.titleize %>
      </a>
    <% end %>
  </div>
  <% if @recent_task_runs&.any? %>
    <div class="pulse-table-wrapper">
      <table class="pulse-table">
        <thead>
          <tr>
            <th>ID</th>
            <th>Agent</th>
            <th>Status</th>
            <th>Steps</th>
            <th>Tokens</th>
            <th>Started</th>
            <th>Completed</th>
            <th>Wait</th>
            <th>Duration</th>
          </tr>
        </thead>
        <tbody>
          <% @recent_task_runs.each do |run| %>
            <tr>
              <td><a href="<%= system_admin_task_run_path(run.id) %>"><code><%= run.id[0..7] %></code></a></td>
              <td><%= run.ai_agent&.name %></td>
              <td><span class="pulse-badge <%= run.status_badge_class %>"><%= run.status %></span></td>
              <td><%= run.steps_count %></td>
              <td><%= run.total_tokens %></td>
              <td><%= run.started_at&.strftime("%b %-d %H:%M:%S") %></td>
              <td><%= run.completed_at&.strftime("%b %-d %H:%M:%S") %></td>
              <td><%= run.formatted_queue_wait %></td>
              <td><%= run.formatted_duration %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="pulse-text-secondary">No task runs<%= " with status '#{@status_filter}'" if @status_filter.present? %>.</p>
  <% end %>
<% end %>
