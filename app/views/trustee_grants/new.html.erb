<%
base_path = "/u/#{@target_user.handle}/settings/trustee-authorizations"
%>

<%= render 'shared/pulse_breadcrumb', items: [
  ['Home', '/'],
  [@target_user.display_name, "/u/#{@target_user.handle}"],
  ['Settings', "/u/#{@target_user.handle}/settings"],
  ['Trustee Authorizations', base_path],
  'New'
] %>

<article class="pulse-resource-detail">
  <header class="pulse-resource-header">
    <div class="pulse-resource-header-top">
      <span class="pulse-resource-type-label">
        <%= octicon 'people', height: 14, class: 'pulse-resource-icon' %>
        New Trustee Authorization
      </span>
    </div>
    <h1 class="pulse-resource-title">Create New Trustee Authorization</h1>
  </header>

  <div class="pulse-resource-body">
    <p>Grant another user authority to act on your behalf. They will need to accept the trustee authorization before they can use it.</p>

    <%= form_tag "#{base_path}/new/actions/create_trustee_authorization", method: :post, class: "pulse-form" do %>
      <section class="pulse-settings-section">
        <label for="trustee_user_id" class="pulse-label">Who should receive this trustee authorization? *</label>
        <select name="trustee_user_id" id="trustee_user_id" class="pulse-form-input" required>
          <option value="">Select a user...</option>
          <% @available_users.each do |user| %>
            <option value="<%= user.id %>">
              <%= user.display_name || user.name %> (<%= user.handle %>)
              <% if user.ai_agent? %> - AI Agent<% end %>
            </option>
          <% end %>
        </select>
      </section>

      <section class="pulse-settings-section">
        <label class="pulse-label">What actions should they be able to perform?</label>
        <p class="pulse-text-muted">Select the actions they can perform on your behalf. Nothing is granted by default.</p>

        <fieldset class="pulse-fieldset">
          <%= render "shared/capability_group_checkboxes",
                     groups: @grantable_groups,
                     param_name: "permissions[]",
                     selected: [],
                     id_prefix: "perm" %>
        </fieldset>
      </section>

      <section class="pulse-settings-section"
               data-controller="radio-toggle"
               data-radio-toggle-hide-on-value="all">
        <label class="pulse-label">Which collectives?</label>
        <p class="pulse-text-muted">Choose which collectives this trustee authorization applies to.</p>

        <div class="pulse-radio-group">
          <label class="pulse-radio-label">
            <input type="radio" name="collective_scope_mode" value="all" checked class="pulse-radio"
                   data-action="change->radio-toggle#sync">
            All collectives where you are a member
          </label>
          <label class="pulse-radio-label">
            <input type="radio" name="collective_scope_mode" value="include" class="pulse-radio"
                   data-action="change->radio-toggle#sync">
            Only specific collectives
          </label>
          <label class="pulse-radio-label">
            <input type="radio" name="collective_scope_mode" value="exclude" class="pulse-radio"
                   data-action="change->radio-toggle#sync">
            All collectives except specific ones
          </label>
        </div>

        <div data-radio-toggle-target="section" class="pulse-conditional-section" style="display: none; margin-top: 1rem;">
          <label class="pulse-label">Select collectives:</label>
          <% @available_collectives.each do |collective| %>
            <label class="pulse-checkbox-label">
              <input type="checkbox" name="collective_ids[]" value="<%= collective.id %>" class="pulse-checkbox">
              <%= collective.name %>
            </label>
          <% end %>
        </div>
      </section>

      <section class="pulse-settings-section">
        <label for="expires_at" class="pulse-label">Expiration (optional)</label>
        <input type="datetime-local" name="expires_at" id="expires_at" class="pulse-form-input">
        <p class="pulse-text-muted">Leave blank for no expiration.</p>
      </section>

      <section class="pulse-settings-section pulse-action-row">
        <button type="submit" class="pulse-action-btn pulse-action-btn-primary">Create Trustee Authorization</button>
        <a href="<%= base_path %>" class="pulse-action-btn">Cancel</a>
      </section>
    <% end %>
  </div>
</article>
