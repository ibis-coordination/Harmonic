<% is_owner = @current_user && @current_user.id == @list.owner_id %>
# <%= @list.name %><%= @list.is_primary && is_owner ? " (your list)" : "" %>

<% owner = @list.owner %>
<% owner_handle = @handles_by_user_id[@list.owner_id] %>
Owner: [<%= owner.display_name %>](/u/<%= owner_handle %>)
Visibility: <%= @list.visibility %>
<% if @list.description.present? %>

<%= @list.description %>
<% end %>

## Members (<%= @members.size %>)

<% if @members.empty? %>
_No members yet._
<% else %>
<% @members.each do |member| %>
<% member_handle = @handles_by_user_id[member.id] %>
* [<%= member.display_name %>](/u/<%= member_handle %>) (@<%= member_handle %>)
<% end %>
<% end %>
