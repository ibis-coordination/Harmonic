<% is_owner = @current_user && @current_user.id == @list.owner_id %>
# <%= @list.display_name %>

<% owner = @list.owner %>
<% owner_handle = @handles_by_user_id[@list.owner_id] %>
Owner: [<%= owner.display_name %>](/u/<%= owner_handle %>)
Visibility: <%= @list.visibility %>
<% if @list.description.present? %>

<%= @list.description %>
<% end %>

## Activity

<% if @feed_items.present? %>
<% @feed_items.each do |feed_item| -%>
<% next if feed_item[:created_by] && block_related_user_ids.include?(feed_item[:created_by].id) -%>
* [<%= feed_item[:type] %>] **<%= feed_item[:item].title %>** by <%= feed_item[:created_by]&.display_name || 'Anonymous' %> (<%= time_ago_in_words(feed_item[:created_at]) %> ago) - [View](<%= feed_item[:item].path %>)
<% end -%>
<% else %>
_No recent activity from members of this list._
<% end %>

## Members (<%= @members.size %>)

<% if @members.empty? %>
_No members yet._
<% else %>
<% @members.each do |member| %>
<% member_handle = @handles_by_user_id[member.id] %>
* [<%= member.display_name %>](/u/<%= member_handle %>) (@<%= member_handle %>)
<% end %>
<% end %>
