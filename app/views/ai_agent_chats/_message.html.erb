<% is_human = step.sender_id != @ai_agent.id %>
<% sender_name = is_human ? "You" : @ai_agent.name %>

<div style="display: flex; margin-bottom: 12px; justify-content: <%= is_human ? 'flex-end' : 'flex-start' %>;">
  <div style="max-width: 75%; padding: 10px 14px; border-radius: 12px; background: <%= is_human ? 'var(--color-accent-subtle)' : 'var(--color-canvas-subtle)' %>;">
    <div style="font-size: 11px; font-weight: 600; margin-bottom: 4px; color: var(--color-fg-muted);">
      <%= sender_name %>
    </div>
    <div style="font-size: 14px; white-space: pre-wrap;"><%= step.detail&.dig("content") %></div>
    <div style="font-size: 11px; color: var(--color-fg-muted); margin-top: 4px;">
      <%= step.created_at.strftime("%-I:%M %p") %>
    </div>
  </div>
</div>
