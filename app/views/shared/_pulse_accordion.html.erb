<%# Wrapper partial - delegates to AccordionComponent. %>
<%# Existing callers can continue using: render 'shared/pulse_accordion', title: 'Details' do %>
<%# New code should use: render AccordionComponent.new(title: 'Details') do %>
<%= render AccordionComponent.new(
  title: title,
  open: local_assigns.fetch(:open, false),
  count: local_assigns.fetch(:count, nil),
  icon: local_assigns.fetch(:icon, nil),
  tooltip: local_assigns.fetch(:tooltip, nil),
  title_data: local_assigns.fetch(:title_data, {}),
) do %>
  <%= yield %>
<% end %>
