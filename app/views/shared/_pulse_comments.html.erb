<%# Pulse-styled comments section %>
<%# Usage: render 'shared/pulse_comments', commentable: @note %>
<div class="pulse-comments-section"
     data-controller="comments"
     data-comments-refresh-url-value="<%= commentable.path %>/comments.html"
     data-comments-commentable-type-value="<%= commentable.class.name %>"
     data-comments-commentable-id-value="<%= commentable.id %>">
  <div class="pulse-section-label">
    <%= octicon 'comment', height: 12 %>
    Comments (<span data-comments-target="count"><%= commentable.all_comments_chronological.size %></span>)
  </div>

  <%= render 'shared/pulse_comments_list', commentable: commentable %>

  <% if @current_user && commentable.respond_to?(:created_by_id) && commentable.created_by && UserBlock.between?(@current_user, commentable.created_by) %>
    <p class="pulse-body-text-muted" style="margin-top: 8px;">
      <%= octicon 'blocked', height: 12 %>
      <% if @current_user.blocked?(commentable.created_by) %>
        Commenting is unavailable because you have blocked the author of this <%= commentable.class.name.downcase %>.
      <% else %>
        Commenting is unavailable because you have been blocked by the author of this <%= commentable.class.name.downcase %>.
      <% end %>
    </p>
  <% elsif @current_user %>
    <div class="pulse-comment-form">
      <div class="pulse-reply-context-bar" data-comments-target="replyContext" hidden>
        <%= octicon 'reply', height: 12 %>
        <span>Replying to <strong data-comments-target="replyContextAuthor"></strong></span>
        <button type="button" class="pulse-reply-context-cancel" data-action="click->comments#cancelReply" aria-label="Cancel reply">
          <%= octicon 'x', height: 12 %>
        </button>
      </div>
      <%= form_with url: "#{commentable.path}/comments", method: :post, local: true, class: "pulse-new-comment-form", data: { comments_target: "form", action: "submit->comments#submit", turbo: "false" } do |form| %>
        <%= render 'shared/markdown_editor', form: form, field: :text, inline: true, rows: 3,
              textarea_class: "pulse-form-textarea",
              mention_container_class: "pulse-form-group",
              extra_data: { comments_target: "textarea" },
              placeholder: @current_collective.private_workspace? ? "Add a comment..." : "Add a comment (use @ to mention users)..." %>
        <div class="pulse-form-actions">
          <%= form.submit "Add Comment", class: "pulse-feed-action-btn", data: { comments_target: "submitButton" } %>
        </div>
      <% end %>
    </div>
  <% else %>
    <%= render "shared/login_to_act", verb: "comment", resource_path: commentable.path %>
  <% end %>
</div>
