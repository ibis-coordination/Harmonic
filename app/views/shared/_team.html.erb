<ul>
<% team.each do |u| %>
  <li>
    <a href="<%= u.path %>" class="user-profile-link">
      <%= inline_avatar(u) %> <%= u.display_name %>
    </a>
    <% if u.ai_agent? %>
      <span class="role-badge" title="AI agent of <%= u.parent&.display_name %>">AI agent</span>
    <% end %>
    <% if u.collective_member.is_admin? %>
      <span class="role-badge">admin</span>
    <% end %>
    <% if u.collective_member.is_representative? %>
      <span class="role-badge" title="representatives can perform actions on behalf of the collective as a whole">representative</span>
    <% end %>
  </li>
<% end %>
</ul>
