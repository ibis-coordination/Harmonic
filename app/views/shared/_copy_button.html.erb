<%# Wrapper partial - delegates to CopyButtonComponent. %>
<%# Existing callers can continue using: render "shared/copy_button", text: "..." %>
<%# New code should use: render CopyButtonComponent.new(text: "...") %>
<%= render CopyButtonComponent.new(
  text: text,
  message: local_assigns.fetch(:message, nil),
  success_message: local_assigns.fetch(:success_message, nil),
) %>
