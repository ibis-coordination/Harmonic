<%# Flat chronological comments section for markdown views %>
<%# Usage: render 'shared/comments_section', resource: @note %>
## Comments (<%= resource.all_comments_chronological.size %>)

<% if resource.comments.empty? -%>
No comments yet.
<% else -%>
<%
  comments = resource.all_comments_chronological
  # When the caller arrived via ?comment_id=<id> (e.g. an agent following a
  # mention link), mark the matching comment inline so its position in the
  # list is preserved.
  linked_comment_id = params[:comment_id].presence
-%>
<% comments.each do |comment| -%>
<% marker = comment.truncated_id == linked_comment_id ? "📌 " : "" -%>
<%# A reply points at another comment rather than the root resource. -%>
<% is_reply = comment.commentable_id != resource.id || comment.commentable_type != resource.class.name -%>
<% if comment.deleted? -%>
* <%= marker %>[`<%= comment.truncated_id %>`](<%= comment.display_path %>) - *[deleted]* (<%= time_ago_in_words(comment.created_at) %> ago)
<% elsif comment.created_by && blocked_user_ids.include?(comment.created_by.id) -%>
* <%= marker %>[`<%= comment.truncated_id %>`](<%= comment.display_path %>) - *[Comment from a user you have blocked]*
<% else -%>
* <%= marker %>[`<%= comment.truncated_id %>`](<%= comment.display_path %>) <% if is_reply && comment.commentable.present? && comment.commentable.created_by.present? -%>↳ Replying to `<%= comment.commentable.truncated_id %>` (@<%= comment.commentable.created_by.handle %>) <% end -%>- <%= comment.created_by ? user_link_md(comment.created_by) : 'Unknown' %> (<%= time_ago_in_words(comment.created_at) %> ago): <%= comment.text.to_s.gsub(/\n+/, ' ') %>
<% end -%>
<% end -%>
<% end -%>
