<%# Wrapper partial - delegates to CollapsibleSectionComponent. %>
<%# Existing callers can continue using: render "shared/collapseable_section", title: "..." do %>
<%# New code should use: render CollapsibleSectionComponent.new(title: "...") do %>
<%= render CollapsibleSectionComponent.new(
  title: title,
  header_level: local_assigns.fetch(:header_level, 1),
  hidden: local_assigns.fetch(:hidden, false),
  title_superscript: local_assigns.fetch(:title_superscript, nil),
  icon: local_assigns.fetch(:octicon, nil),
  target: local_assigns.fetch(:target, nil),
  indent: local_assigns.fetch(:indent, false),
  lazy_load: local_assigns.fetch(:lazy_load, nil),
) do %>
  <%= yield %>
<% end %>
