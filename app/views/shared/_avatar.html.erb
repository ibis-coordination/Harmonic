<%# Wrapper partial - delegates to AvatarComponent. %>
<%# Existing callers can continue using: render "shared/avatar", user: user %>
<%# New code should use: render AvatarComponent.new(user: user) %>
<%= render AvatarComponent.new(
  user: user,
  size: local_assigns.fetch(:size, nil),
  show_link: local_assigns.fetch(:show_link, false),
  title: local_assigns.fetch(:title, nil),
  css_class: local_assigns.fetch(:css_class, "pulse-author-avatar"),
) %>
