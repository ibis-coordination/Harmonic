<%
  current_collective_path = @current_collective.path
  active_key = case current
               when :note       then "note"
               when :decision   then "decision"
               when :commitment then "commitment"
               end
%>
<%= render TabsComponent.new(
      active_key: active_key.to_s,
      css_class: "pulse-create-tabs",
      tabs: [
        TabsComponent::Tab.new(key: "note",       label: "Note",   href: "#{current_collective_path}/note"),
        TabsComponent::Tab.new(key: "decision",   label: "Decide", href: "#{current_collective_path}/decide"),
        TabsComponent::Tab.new(key: "commitment", label: "Commit", href: "#{current_collective_path}/commit"),
      ],
    ) %>
