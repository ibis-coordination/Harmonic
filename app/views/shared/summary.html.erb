<%# Summary show page. Rendered by NotesController#summary,
    DecisionsController#summary, and CommitmentsController#summary
    when an agent or user fetches `<parent>/summary`. The controller
    sets @note to the summary note itself, and @summarizable to the
    parent resource. %>
<span data-controller="note summary-toggle" data-note-id="<%= @note.id %>">
<%= render 'shared/pulse_breadcrumb', items: [
  [@current_collective.name, @current_collective.path],
  [@summarizable.class.to_s, @summarizable.path],
  'Summary'
] %>

<%= render 'shared/note_main', note: @note %>
</span>
