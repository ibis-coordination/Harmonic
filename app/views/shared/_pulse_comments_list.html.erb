<%# Wrapper partial - delegates to CommentsListComponent. %>
<%# Existing callers can continue using: render "shared/pulse_comments_list", commentable: commentable %>
<%# New code should use: render CommentsListComponent.new(commentable: commentable, ...) %>
<%= render CommentsListComponent.new(
  commentable: commentable,
  current_user: @current_user,
  collective_path: @current_collective&.path || "",
) %>
