<%# Wrapper partial - delegates to AuthorComponent. %>
<%# Existing callers can continue using: render "shared/pulse_author", resource: @note %>
<%# New code should use: render AuthorComponent.new(resource: @note, current_user: @current_user) %>
<%= render AuthorComponent.new(
  resource: resource,
  verb: local_assigns.fetch(:verb, nil),
  current_user: @current_user,
) %>
