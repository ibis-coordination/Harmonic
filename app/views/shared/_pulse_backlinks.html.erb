<%# Pulse-styled backlinks section %>
<%# Usage: render 'shared/pulse_backlinks', resource: @note %>
<% if resource.backlinks.any? %>
  <%= render 'shared/pulse_accordion', title: 'Backlinks', count: resource.backlinks.count do %>
    <p class="pulse-backlinks-hint">
      Items that link to this <%= resource.class.name.downcase %>.
    </p>
    <ul class="pulse-backlinks-list">
      <% resource.backlinks.each do |r| %>
        <li class="pulse-backlinks-item">
          <% if r.respond_to?(:created_by_id) && blocked_user_ids.include?(r.created_by_id) %>
            <span class="pulse-body-text-muted">
              <%= octicon 'blocked', height: 12 %>
              A link from a user you have blocked
              <a href="<%= r.path %>" class="pulse-link pulse-body-text-muted">Show</a>
            </span>
          <% else %>
            <%= render 'shared/pulse_resource_link', resource: r %>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% end %>
<% end %>
