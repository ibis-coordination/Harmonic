<% topic_name = @page_title.sub('Help — ', '') %>
<%= render 'shared/pulse_breadcrumb', items: [
  ['Home', '/'],
  *(topic_name == 'Help' ? ['Help'] : [['Help', '/help'], topic_name])
] %>

<article class="pulse-resource-detail">
  <header class="pulse-resource-header">
    <div class="pulse-resource-header-top">
      <span class="pulse-resource-type-label">
        <%= octicon 'question', height: 14, class: 'pulse-resource-icon' %>
        Help
      </span>
    </div>
  </header>

  <div class="pulse-resource-body pulse-prose">
    <%= @help_html.html_safe %>
  </div>
</article>
