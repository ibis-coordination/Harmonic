<%= render 'shared/pulse_breadcrumb', items: [
  [@current_tenant.subdomain, '/'],
  'Users',
  @showing_user.display_name
] %>

<article class="pulse-user-profile">
  <header class="pulse-user-header">
    <%= render "shared/avatar_div", record: @showing_user, css_class: "pulse-user-avatar-large", variant: :thumbnail %>
    <div class="pulse-user-info">
      <h1 class="pulse-user-name">
        <%= @showing_user.display_name %>
        <% if @showing_user.archived? %>
          <span class="pulse-badge pulse-badge-muted">Archived</span>
        <% end %>
      </h1>
      <p class="pulse-user-handle">@<%= @showing_user.handle %></p>
      <% if @showing_user.ai_agent? %>
        <span class="pulse-badge" title="This is an AI agent managed by <%= @showing_user.parent&.display_name %>">AI agent</span>
      <% end %>
      <% if @viewer_on_target_list %>
        <span class="pulse-badge pulse-badge-muted pulse-tuning-in-to-you-badge">
          <%= pulse_icon('tuning_in', size: :sm) %> Tuned in to you
        </span>
      <% end %>
    </div>
    <div class="pulse-user-actions">
      <% if @current_user && @current_user.can_edit?(@showing_user) %>
        <a href="<%= @showing_user.path %>/settings" class="pulse-action-btn">
          <%= octicon 'gear', height: 14 %>
          Settings
        </a>
      <% end %>
      <% if @current_user && @showing_user.id != @current_user.id %>
        <% if @viewer_blocks_target %>
          <span class="pulse-body-text-muted">You have blocked <%= @showing_user.display_name %>.</span>
        <% elsif @viewer_blocked_by_target %>
          <span class="pulse-body-text-muted"><%= @showing_user.display_name %> has blocked you.</span>
        <% else %>
          <%= render AjaxToggleButtonComponent.new(
                on:        @target_on_my_list,
                on_url:    "#{@showing_user.path}/actions/tune_out",
                on_html:   pulse_icon('tuning_in', size: :sm) + " Tuned in",
                on_class:  "pulse-action-btn-secondary",
                off_url:   "#{@showing_user.path}/actions/tune_in",
                off_html:  octicon('plus', height: 14) + " Tune in",
                off_class: "pulse-action-btn",
                title:     "Tuning in to this user adds their activity to your timeline view",
              ) %>
        <% end %>
      <% end %>
      <% if @current_user && @showing_user.id != @current_user.id && (!@showing_user.collective_identity? || !@showing_user.ai_agent?) %>
        <details data-controller="kebab-menu" style="position: relative; display: inline-block;">
          <summary class="pulse-action-btn-secondary" style="cursor: pointer; list-style: none;" title="More actions">
            <%= octicon 'kebab-horizontal', height: 14 %>
          </summary>
          <div class="top-menu" style="position: absolute; top: 100%; right: 0; z-index: 100;">
            <ul>
              <% if !@showing_user.collective_identity? && !@viewer_blocks_target && !@viewer_blocked_by_target %>
                <li>
                  <a href="<%= chat_path(@showing_user.handle) %>">
                    <%= octicon 'comment', height: 14 %> Message
                  </a>
                </li>
              <% end %>
              <% if !@showing_user.ai_agent? %>
                <% if @current_user.blocked?(@showing_user) %>
                  <% existing_block = @current_user.user_blocks_given.find_by(blocked: @showing_user) %>
                  <% if existing_block %>
                    <li>
                      <%= button_to user_block_path(existing_block), method: :delete do %>
                        <%= octicon 'blocked', height: 14 %> Unblock
                      <% end %>
                    </li>
                  <% end %>
                <% else %>
                  <li>
                    <%= button_to user_blocks_path(blocked_id: @showing_user.id),
                                  method: :post,
                                  title: "Blocking hides their content from your feed and prevents them from commenting on your content, @mentioning you, voting on your decisions, or joining your commitments. They will not be notified." do %>
                      <%= octicon 'blocked', height: 14 %> Block
                    <% end %>
                  </li>
                <% end %>
              <% end %>
            </ul>
          </div>
        </details>
      <% end %>
    </div>
  </header>

  <% if @showing_user.ai_agent? && @showing_user.parent %>
    <div class="pulse-user-parent-info">
      <span style="color: var(--color-fg-muted);">Managed by</span>
      <a href="<%= @showing_user.parent.path %>" class="pulse-user-parent-link">
        <%= profile_pic(@showing_user.parent, size: 20, style: 'vertical-align:middle;margin-right:4px;border-radius:50%;') %>
        <strong><%= @showing_user.parent.display_name %></strong>
      </a>
    </div>
  <% end %>

  <% if @showing_user.human? && @ai_agent_count && @ai_agent_count > 0 %>
    <div class="pulse-user-ai_agent-count">
      <%= octicon 'people', height: 14 %>
      Has <%= @ai_agent_count %> AI agent<%= @ai_agent_count == 1 ? "" : "s" %>
    </div>
  <% end %>

  <% blocked_either_way = @viewer_blocks_target || @viewer_blocked_by_target %>

  <% if @current_user != @showing_user && @common_collective_count > 0 && !blocked_either_way %>
    <div class="pulse-user-common-counts">
      <span class="pulse-common-count-item">
        <%= octicon 'lock', height: 14 %>
        <%= @common_collective_count %> common collective<%= 's' unless @common_collective_count == 1 %>
      </span>
    </div>
  <% end %>

  <% if @current_user != @showing_user && @common_collectives.count > 0 && !blocked_either_way %>
    <%# Common Collectives Section %>
    <%= render 'shared/pulse_accordion', title: 'Common Collectives', count: @common_collectives.count + @additional_common_collective_count, open: true do %>
      <div class="pulse-collectives-list">
        <% @common_collectives.each do |collective| %>
          <div class="pulse-collective-item">
            <%= render "shared/avatar_div", record: collective, style: "border-radius:6px;" %>
            <div class="pulse-collective-info">
              <a href="<%= collective.path %>" class="pulse-collective-name"><%= collective.name %></a>
            </div>
          </div>
        <% end %>
        <% if @additional_common_collective_count > 0 %>
          <p class="pulse-form-hint">and <%= @additional_common_collective_count %> more...</p>
        <% end %>
      </div>
    <% end %>
  <% end %>

  <% if @proximity_users.present? %>
    <%= render 'shared/pulse_accordion', title: 'Social Proximity', count: @proximity_users.size, icon: 'people', open: false do %>
      <%= render 'users/proximity_connections' %>
    <% end %>
  <% end %>

  <% viewer_is_owner = @current_user && @current_user.id == @showing_user.id %>
  <% if (@showing_user_lists.present? || viewer_is_owner) && !blocked_either_way %>
    <% showing_handle = @showing_user.tenant_users.find_by(tenant_id: @current_tenant.id)&.handle %>
    <%= render 'shared/pulse_accordion', title: 'Lists', icon: 'list-unordered', count: @showing_user_lists.size, open: false do %>
      <% if @showing_user_lists.empty? %>
        <p class="pulse-body-text-muted">No lists yet.</p>
      <% else %>
        <ul class="pulse-collectives-list" style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: 8px;">
          <% @showing_user_lists.each do |list| %>
            <li class="pulse-collective-item">
              <div class="pulse-collective-info">
                <a href="<%= list.path %>" class="pulse-collective-name"><%= list.name %></a>
                <% if list.is_primary && viewer_is_owner %>
                  <span class="pulse-badge">your list</span>
                <% end %>
                <% if list.private? %>
                  <span class="pulse-badge pulse-badge-muted">private</span>
                <% end %>
                <div class="pulse-body-text-muted">
                  <%= list.members.size %> member<%= list.members.size == 1 ? "" : "s" %>
                </div>
              </div>
            </li>
          <% end %>
        </ul>
      <% end %>
      <% if viewer_is_owner %>
        <p style="margin-top: 8px; display: flex; gap: 8px;">
          <a href="/lists/new" class="pulse-action-btn-secondary">
            <%= octicon 'plus', height: 14 %> New list
          </a>
          <% if showing_handle && @showing_user_lists.any? %>
            <a href="/u/<%= showing_handle %>/lists" class="pulse-action-btn-secondary">
              See all lists
            </a>
          <% end %>
        </p>
      <% elsif showing_handle && @showing_user_lists.any? %>
        <p style="margin-top: 8px;">
          <a href="/u/<%= showing_handle %>/lists" class="pulse-action-btn-secondary">
            See all lists
          </a>
        </p>
      <% end %>
    <% end %>
  <% end %>

  <% if @feed_items.present? && !blocked_either_way %>
    <%= render 'shared/pulse_accordion', title: 'Recent Activity', icon: 'pulse', count: @feed_items.size, open: true do %>
      <div class="pulse-feed" style="padding: 0;">
        <% @feed_items.each do |feed_item| %>
          <%= render 'pulse/feed_item', feed_item: feed_item %>
        <% end %>
      </div>
    <% end %>
  <% end %>
</article>
