<%= render 'shared/pulse_breadcrumb', items: [
  [@current_tenant.subdomain, '/'],
  [@showing_user.display_name, @showing_user.path],
  'Mutuals'
] %>

<article class="pulse-resource-detail">
  <header class="pulse-resource-header">
    <h1 class="pulse-resource-title">
      <% if @filter == "common" %>
        Mutually tuned in with <%= @showing_user.display_name %> &middot; in common with you
      <% else %>
        Mutually tuned in with <%= @showing_user.display_name %>
      <% end %>
    </h1>
    <p class="pulse-resource-meta">
      <%= @mutuals.size %> <%= @mutuals.size == 1 ? "person" : "people" %>
      <% if @filter == "common" %>
        &middot; <a href="<%= @showing_user.path %>/mutuals">show all</a>
      <% end %>
    </p>
  </header>

  <section style="margin-top: 24px;">
    <% if @mutuals.empty? %>
      <p class="pulse-body-text-muted">
        <% if @filter == "common" %>No common mutuals yet.<% else %>No mutuals yet.<% end %>
      </p>
    <% else %>
      <ul class="pulse-list-members">
        <% @mutuals.each do |person| %>
          <li class="pulse-collective-item">
            <%= render "shared/avatar_div", record: person, variant: :thumbnail %>
            <div class="pulse-collective-info" style="flex: 1;">
              <a href="<%= person.path %>" class="pulse-collective-name"><%= person.display_name.presence || person.handle %></a>
              <% if person.display_name.present? %>
                <span class="pulse-body-text-muted">@<%= person.handle %></span>
              <% end %>
            </div>
            <% if @show_tune_in_on_mutuals %>
              <%= render "shared/tune_in_button",
                    viewer:  @current_user,
                    target:  person,
                    on_list: @tune_in_state.on_list_ids.include?(person.id),
                    blocked: @tune_in_state.blocked_pair_ids.include?(person.id) %>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% end %>
  </section>
</article>
