# <%= @page_title %>

<% is_own_settings = @settings_user == @current_user %>

## Profile

Name: <%= @settings_user.name %>
Handle: `<%= @settings_user.handle %>`

<% if is_own_settings %>
## Notification Preferences

How each notification type is delivered. Update with the `update_notification_preferences` action (POST `/settings/actions/update_notification_preferences`), passing a `notifications` object such as `{ "comment": { "email": true } }`.

<%# Columns derive from the tenant's editable channels — the same list the
    HTML matrix renders and the form parser accepts — so a new channel (e.g.
    web_push) appears here the moment it's available instead of being
    writable-but-invisible on this surface. %>
<% channels = @current_tenant.editable_notification_channels %>
<% channel_label = { "in_app" => "In-app", "email" => "Email", "web_push" => "Push" } %>
| Type | <%= channels.map { |c| channel_label.fetch(c) }.join(" | ") %> |
|------|<%= "--------|" * channels.size %>
<% TenantUser::NOTIFICATION_TYPE_LABELS.each do |type, label| %>
| <%= label %> (`<%= type %>`) | <%= channels.map { |c| @settings_user.tenant_user.notification_enabled?(type, c) ? "on" : "off" }.join(" | ") %> |
<% end %>
<% end %>

<% if is_own_settings && @settings_user.external_oauth_identities.any? %>
## Connected Accounts

<% @settings_user.external_oauth_identities.each do |identity| %>
* <%= identity.provider.titleize %> ([<%= identity.username %>](<%= identity.url %>)) - Connected <%= time_ago_in_words(identity.created_at) %> ago
<% end %>
<% end %>

<% if @current_tenant.api_enabled? %>
## API Tokens

<% if @all_api_tokens.any? %>
| Identity | Name | Created | Last Used | Expires | Active |
|----------|------|---------|-----------|---------|--------|
<% @all_api_tokens.each do |token| %>
| <%= token.user == @settings_user ? 'you' : "[@#{token.user.handle}](#{token.user.path})#{token.user.ai_agent? ? ' (agent)' : ''}" %> | <%= token.name || 'Unnamed' %> | <%= time_ago_in_words(token.created_at) %> ago | <%= token.last_used_at ? time_ago_in_words(token.last_used_at) + ' ago' : 'Never' %> | <%= time_ago_in_words(token.expires_at) %> | <%= token.active? ? 'Yes' : 'No' %> |
<% end %>
<% else %>
No API tokens.
<% end %>

