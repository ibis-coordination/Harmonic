<%= render 'shared/pulse_breadcrumb', items: [
  [@current_tenant.subdomain, '/'],
  'Users',
  [@settings_user.display_name, @settings_user.path],
  'Settings'
] %>

<% is_own_settings = @settings_user == @current_user %>

<article class="pulse-user-profile">
  <header class="pulse-user-header">
    <%= render "shared/avatar_div", record: @settings_user, css_class: "pulse-user-avatar-large", variant: :thumbnail %>
    <div class="pulse-user-info">
      <h1 class="pulse-user-name"><%= @settings_user.display_name %></h1>
      <p class="pulse-user-handle">@<%= @settings_user.handle %></p>
      <% if @settings_user.ai_agent? %>
        <span class="pulse-badge" title="This is an AI agent managed by <%= @settings_user.parent&.display_name %>">AI agent</span>
      <% end %>
    </div>
    <div class="pulse-user-actions">
      <a href="<%= @settings_user.path %>" class="pulse-action-btn">
        <%= octicon 'person', height: 14 %>
        View Profile
      </a>
    </div>
  </header>

  <%# Profile Section %>
  <%= render 'shared/pulse_accordion', title: 'Profile', open: true do %>
    <%# Profile image upload has its own form so must be outside the main profile form %>
    <div class="pulse-form-section">
      <label class="pulse-form-label">Profile Image</label>
      <p class="pulse-form-hint">Click the image to upload a new one</p>
      <%= render 'shared/profile_image_upload', resource: @settings_user, size: 64 %>
    </div>

    <%= form_with url: "#{@settings_user.path}/settings/profile", class: 'pulse-form' do |form| %>
      <div class="pulse-form-section">
        <label class="pulse-form-label" for="name">Display Name</label>
        <%= form.text_field :name, value: @settings_user.name, placeholder: 'Your name', class: 'pulse-input' %>
      </div>

      <div class="pulse-form-section">
        <label class="pulse-form-label" for="new_handle">Handle</label>
        <div class="pulse-input-prefix-wrapper">
          <span class="pulse-input-prefix">@</span>
          <%= form.text_field :new_handle, value: @settings_user.handle, placeholder: 'handle', class: 'pulse-input pulse-input-with-prefix' %>
        </div>
        <p class="pulse-form-hint">This is your unique identifier used in URLs and mentions</p>
      </div>

      <div class="pulse-form-actions">
        <%= form.submit 'Save Changes', class: 'pulse-action-btn-primary' %>
      </div>
    <% end %>
  <% end %>

  <% if is_own_settings && @settings_user.human? && @current_tenant.trio_enabled? %>
    <%# Workspace AI Assistant — opt-in to Trio inside the user's private workspace.
        CollectivesController#settings redirects workspace owners away from the
        collective-settings page, so the per-workspace flag is exposed here. %>
    <% workspace = @settings_user.private_workspace %>
    <% if workspace %>
      <% trio_active = workspace.trio_user_id.present? %>
      <% workspace_tier_locked = @current_tenant.feature_enabled?("stripe_billing") && !workspace.paid_tier? && !workspace.is_main_collective? %>
      <%= render 'shared/pulse_accordion', title: 'Workspace AI Assistant' do %>
        <div style="margin-bottom: 12px;">
          <%= render 'shared/collective_tier_badge', collective: workspace %>
        </div>

        <% if workspace_tier_locked %>
          <p class="pulse-muted" style="margin-bottom: 12px; font-size: 13px;">
            <%= octicon 'credit-card', height: 12 %>
            Trio is a paid feature.
            <% if workspace.requires_stripe_billing? %>
              Your workspace billing has lapsed — restore your subscription to resume.
              <%= button_to "Resume billing", "/billing", method: :get,
                            class: "pulse-action-btn",
                            form: { style: "display: inline; margin-top: 8px;" } %>
            <% else %>
              Upgrade your workspace to the paid plan ($3/month) to enable it.
              <%# Link to the GET upgrade preview, which shows the prorated %>
              <%# charge (for users with billing) or explains the Stripe %>
              <%# Checkout next step (for users without). %>
              <a href="<%= workspace.path %>/upgrade" class="pulse-action-btn" style="margin-top: 8px;">Upgrade Workspace to Paid ($3/month)</a>
            <% end %>
          </p>
        <% end %>

        <%= form_with url: "/u/#{@settings_user.handle}/settings/workspace_trio", class: 'pulse-form' do |form| %>
          <div class="pulse-form-section">
            <label class="pulse-checkbox-label">
              <%= form.check_box :feature_trio, { checked: trio_active, disabled: workspace_tier_locked }, "true", "false" %>
              <span>
                <strong>Enable Trio in my workspace</strong>
                <span class="pulse-form-hint" style="display: block; margin-top: 2px;">
                  When on, @trio in your workspace notes and comments routes to a Trio
                  agent dedicated to your workspace, and Trio responds to mentions and
                  replies on its own comments. Turning it off archives the agent —
                  re-enabling restores it and preserves any rule customizations.
                </span>
              </span>
            </label>
          </div>
          <div class="pulse-form-actions">
            <%= form.submit 'Save', class: 'pulse-action-btn-primary', disabled: workspace_tier_locked %>
          </div>
        <% end %>
      <% end %>
    <% end %>

    <%# Email Section %>
    <%= render 'shared/pulse_accordion', title: 'Email' do %>
      <div class="pulse-form-section">
        <label class="pulse-form-label">Current Email</label>
        <p style="font-size: 14px;"><%= @settings_user.email %></p>
      </div>

      <% if @settings_user.pending_email.present? %>
        <div class="pulse-alert" style="margin-bottom: 16px; background: var(--color-attention-subtle);">
          A confirmation email has been sent to <strong><%= @settings_user.pending_email %></strong>. Please check your inbox to complete the change. The link expires in 24 hours.
        </div>
        <div style="display: flex; gap: 8px;">
          <%= form_with url: "/u/#{@settings_user.handle}/settings/email", method: :patch, style: "display: inline;" do |form| %>
            <%= form.hidden_field :email, value: @settings_user.pending_email %>
            <%= form.submit 'Resend Confirmation', class: 'pulse-action-btn' %>
          <% end %>
          <%= form_with url: "/u/#{@settings_user.handle}/settings/email", method: :delete, style: "display: inline;" do |form| %>
            <%= form.submit 'Cancel', class: 'pulse-action-btn' %>
          <% end %>
        </div>
      <% end %>

      <%= form_with url: "/u/#{@settings_user.handle}/settings/email", method: :patch, class: 'pulse-form' do |form| %>
        <div class="pulse-form-section">
          <label class="pulse-form-label" for="email"><%= @settings_user.pending_email.present? ? 'Change to a Different Email' : 'New Email' %></label>
          <%= form.email_field :email, placeholder: 'Enter new email address', class: 'pulse-input' %>
        </div>
        <div class="pulse-form-actions">
          <%= form.submit 'Change Email', class: 'pulse-action-btn-primary' %>
        </div>
      <% end %>
    <% end %>
  <% end %>

  <% if is_own_settings %>
    <% if @settings_user.external_oauth_identities.any? %>
      <%# Connected Accounts Section %>
      <%= render 'shared/pulse_accordion', title: 'Connected Accounts', count: @settings_user.external_oauth_identities.count do %>
        <div class="pulse-connected-accounts-list">
          <% @settings_user.external_oauth_identities.each do |identity| %>
            <div class="pulse-connected-account-item">
              <div class="pulse-connected-account-info">
                <span class="pulse-connected-account-provider"><%= identity.provider.titleize %></span>
                <a href="<%= identity.url %>" class="pulse-connected-account-username">@<%= identity.username %></a>
              </div>
              <span class="pulse-connected-account-date">Connected <%= time_ago_in_words(identity.created_at) %> ago</span>
            </div>
          <% end %>
        </div>
      <% end %>
    <% end %>

    <% # Two-Factor Authentication Section (only for identity provider users) %>
    <% identity_for_2fa = @settings_user.omni_auth_identity %>
    <% if identity_for_2fa %>
      <%= render 'shared/pulse_accordion', title: 'Two-Factor Authentication' do %>
        <p class="pulse-form-hint" style="margin-bottom:16px;">
          Add an extra layer of security to your account by requiring a verification code in addition to your password.
        </p>
        <% if identity_for_2fa.otp_enabled %>
          <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 16px;">
            <span class="pulse-badge pulse-badge-success">Enabled</span>
            <span class="pulse-form-hint">since <%= identity_for_2fa.otp_enabled_at.strftime('%B %d, %Y') %></span>
          </div>
          <p class="pulse-form-hint" style="margin-bottom:16px;">
            You have <strong><%= identity_for_2fa.remaining_recovery_codes_count %></strong> recovery codes remaining.
          </p>
          <div class="pulse-form-actions">
            <a href="<%= two_factor_settings_path %>" class="pulse-action-btn">
              <%= octicon 'shield-lock', height: 14 %>
              Manage 2FA
            </a>
          </div>
        <% else %>
          <div class="pulse-form-actions">
            <a href="<%= two_factor_setup_path %>" class="pulse-action-btn">
              <%= octicon 'shield-lock', height: 14 %>
              Enable Two-Factor Authentication
            </a>
          </div>
        <% end %>
      <% end %>
    <% end %>
  <% end %>

  <% if @current_tenant.api_enabled? %>
    <%# API Tokens Section - includes user's own tokens + AI agents' tokens %>
    <%= render 'shared/pulse_accordion', title: 'API Tokens', count: @all_api_tokens.count do %>
      <p class="pulse-form-hint" style="margin-bottom:16px;">
        API tokens authenticate requests to the API. Actions taken through the API using these tokens are attributed to the identity shown.
        <% if @settings_user.human? && @ai_agents.any? %>
          This includes tokens for your AI agents.
        <% end %>
      </p>
      <% if @all_api_tokens.any? %>
        <div class="pulse-table-wrapper">
          <table class="pulse-table">
            <thead>
              <tr>
                <th>Identity</th>
                <th>Name</th>
                <th>Token</th>
                <th>Created</th>
                <th>Last Used</th>
                <th>Expires</th>
                <th>Status</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% @all_api_tokens.each do |token| %>
                <tr>
                  <td>
                    <% if token.user == @settings_user %>
                      you
                    <% else %>
                      <a href="<%= token.user.path %>" class="pulse-link">@<%= token.user.handle %></a>
                      <% if token.user.ai_agent? %>
                        <span class="pulse-badge pulse-badge-muted" style="font-size: 10px; padding: 2px 4px;">agent</span>
                      <% end %>
                    <% end %>
                  </td>
                  <td><%= token.name || 'Unnamed' %></td>
                  <td>
                    <code class="pulse-code"><%= token.obfuscated_token %></code>
                    <% if token.plaintext_token.present? %>
                      <%= render 'shared/copy_button', text: token.plaintext_token %>
                    <% end %>
                  </td>
                  <td><%= timeago(token.created_at) %></td>
                  <td><%= token.last_used_at ? timeago(token.last_used_at) : 'Never' %></td>
                  <td><%= timeago(token.expires_at) %></td>
                  <td>
                    <% if token.active? %>
                      <span class="pulse-badge pulse-badge-success">Active</span>
                    <% else %>
                      <span class="pulse-badge pulse-badge-muted">Inactive</span>
                    <% end %>
                  </td>
                  <td><a href="<%= token.path %>" class="pulse-link">View</a></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% end %>
      <% if @current_user.human? %>
        <div class="pulse-form-actions" style="margin-top:16px;">
          <a href="<%= @settings_user.path %>/settings/tokens/new" class="pulse-action-btn">
            <%= octicon 'key', height: 14 %>
            Create API Token
          </a>
        </div>
      <% end %>
    <% end %>

    <%# Trustee Grants Section %>
    <% pending_count = @settings_user.pending_trustee_grant_requests.count %>
    <%= render 'shared/pulse_accordion', title: 'Trustee Grants', count: pending_count > 0 ? pending_count : nil do %>
      <p class="pulse-form-hint" style="margin-bottom:16px;">
        Manage who can act on your behalf and whose behalf you can act on.
      </p>
      <% if pending_count > 0 %>
        <div style="margin-bottom:16px;">
          <span class="pulse-badge pulse-badge-warning">
            <%= pluralize(pending_count, 'pending request') %>
          </span>
        </div>
      <% end %>
      <div class="pulse-form-actions">
        <a href="<%= @settings_user.path %>/settings/trustee-grants" class="pulse-action-btn">
          <%= octicon 'people', height: 14 %>
          Manage Trustee Grants
        </a>
      </div>
    <% end %>

    <%# Download My Data — gated by the user_data_export feature flag %>
    <% if @settings_user.human? && is_own_settings && @current_tenant.feature_enabled?("user_data_export") %>
      <%= render 'shared/pulse_accordion', title: 'Download My Data' do %>
        <p class="pulse-form-hint" style="margin-bottom:16px;">
          Download a ZIP of the data you've shared publicly and the actions you've taken in public spaces.
          See the export page for what's included.
        </p>
        <div class="pulse-form-actions">
          <a href="<%= @settings_user.path %>/settings/data-export" class="pulse-action-btn">
            <%= octicon 'download', height: 14 %>
            Download My Data
          </a>
        </div>
      <% end %>
    <% end %>

    <% if @settings_user.human? && is_own_settings %>
      <% blocked_count = @settings_user.user_blocks_given.count %>
      <%= render 'shared/pulse_accordion', title: 'Blocked Users', count: blocked_count > 0 ? blocked_count : nil do %>
        <p class="pulse-form-hint" style="margin-bottom:8px;">
          When you block someone:
        </p>
        <ul class="pulse-form-hint" style="margin-bottom:8px; padding-left: 20px;">
          <li>Their content is hidden from your feed</li>
          <li>They cannot comment on your content, @mention you, vote on your decisions, or join your commitments</li>
          <li>Notifications from them are suppressed</li>
        </ul>
        <p class="pulse-form-hint" style="margin-bottom:16px;">
          Blocking does not affect their ability to view your content directly. They are not notified that you blocked them.
        </p>
        <div class="pulse-form-actions">
          <a href="/user-blocks" class="pulse-action-btn">
            <%= octicon 'blocked', height: 14 %>
            Manage Blocked Users
          </a>
        </div>
      <% end %>
    <% end %>

    <% if @settings_user.human? && is_own_settings && @current_tenant.feature_enabled?("stripe_billing") %>
      <%# Billing Link %>
      <%= render 'shared/pulse_accordion', title: 'Billing' do %>
        <p class="pulse-form-hint" style="margin-bottom:16px;">
          Manage your billing and subscription for AI agent usage.
        </p>
        <div class="pulse-form-actions">
          <a href="/billing" class="pulse-action-btn">
            <%= octicon 'credit-card', height: 14 %>
            Manage Billing
          </a>
        </div>
      <% end %>
    <% end %>

  <% end %>
</article>
