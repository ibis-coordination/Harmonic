<% if @showing_user.ai_agent? %>
Type: AI Agent
<% end %>
<% if @showing_user.ai_agent? && @showing_user.parent %>

Managed by: [<%= @showing_user.parent.display_name %>](<%= @showing_user.parent.path %>)
<% end %>
<% if @showing_user.human? && @ai_agent_count && @ai_agent_count > 0 %>

Has <%= @ai_agent_count %> AI agent<%= @ai_agent_count == 1 ? "" : "s" %>
<% end %>
<% if @current_user && @current_user.id != @showing_user.id %>

<% if @viewer_blocks_target %>
You have blocked <%= @showing_user.display_name %>.
<% elsif @viewer_blocked_by_target %>
<%= @showing_user.display_name %> has blocked you.
<% elsif @target_on_my_list && @viewer_on_target_list %>
You and <%= @showing_user.display_name %> are _mutually tuned in_ to each other.
<% elsif @target_on_my_list %>
You are _tuned in_ to <%= @showing_user.display_name %>.
<% elsif @viewer_on_target_list %>
<%= @showing_user.display_name %> is _tuned in_ to you.
<% else %>
You are _not tuned in_ to <%= @showing_user.display_name %>.
<% end %>
<% end %>
<% blocked_either_way = @viewer_blocks_target || @viewer_blocked_by_target %>
<% if @current_user != @showing_user && @common_collective_count > 0 && !blocked_either_way %>

You and <%= @showing_user.display_name %> have <%= @common_collective_count %> common collective<%= 's' unless @common_collective_count == 1 %>.
<% end %>

<% if @current_user != @showing_user && @common_collectives.length > 0 && !blocked_either_way %>
## Common Collectives

<% @common_collectives.each do |collective| %>
* [<%= collective.name %>](<%= collective.path %>)
<% end %>
<% if @additional_common_collective_count > 0 %>
And <%= @additional_common_collective_count %> more...
<% end %>
<% end %>
<% if @proximity_users.present? && !blocked_either_way %>

## Social Proximity (<%= @proximity_users.size %>)

<% @proximity_users.each do |user| %>
* [<%= user.display_name %>](<%= user.path %>) (@<%= user.handle %>)
<% end %>
<% end %>
<% if @feed_items.present? && !blocked_either_way %>

## Recent Activity (<%= @feed_items.size %>)

<% @feed_items.each do |feed_item| -%>
<% next if feed_item[:created_by] && block_related_user_ids.include?(feed_item[:created_by].id) -%>
* [<%= feed_item[:type] %>] **<%= feed_item[:item].title %>** by <%= feed_item[:created_by]&.display_name || 'Anonymous' %> (<%= time_ago_in_words(feed_item[:created_at]) %> ago) - [View](<%= feed_item[:item].path %>)
<% end -%>
<% end %>

